use "testing"
use "cookie"

// Cookie grain: parse/build single headers, parseSet for response
// attributes, sign/verify (HMAC), encrypt/decrypt (AEAD), and the
// Jar class that emulates browser-style cookie state across requests.

// ── parse / build / clear (existing surface) ──────────────────

testing.test("parse: simple cookie header", lam{ in
    let c = cookie.parse("name=value; other=2")
    testing.expectEqual(c.name, "value", nil)
    testing.expectEqual(c.other, "2", nil)
})

testing.test("parse: empty / nil header → empty map", lam{ in
    testing.expectEqual(len(keys(cookie.parse(""))), 0, nil)
    testing.expectEqual(len(keys(cookie.parse(nil))), 0, nil)
})

testing.test("parse: URL-decodes values", lam{ in
    let c = cookie.parse("greeting=hello%20world")
    testing.expectEqual(c.greeting, "hello world", nil)
})

testing.test("build: defaults apply Path=/; HttpOnly; SameSite=Lax", lam{ in
    let h = cookie.build("session", "abc", nil)
    testing.expect(h.contains("Path=/"), nil)
    testing.expect(h.contains("HttpOnly"), nil)
    testing.expect(h.contains("SameSite=Lax"), nil)
})

// ── attribute-injection rejection (regression) ───────────────

testing.test("build: rejects '; Secure' injection via path", lam{ in
    // Probe value from the audit. The semicolon would let an attacker
    // smuggle additional cookie attributes if path were concatenated raw.
    testing.expectThrows(
        lam{ in cookie.build("session", "abc", {path: "/; Secure"}) },
        "invalid character in path")
})

testing.test("build: rejects CRLF in domain", lam{ in
    testing.expectThrows(
        lam{ in cookie.build("session", "abc", {domain: "evil.com\r\n"}) },
        "invalid byte in domain")
})

testing.test("build: rejects every CTL + DEL in path/domain", lam{ in
    // Spot-check a few CTLs that the previous deny-list missed:
    // \x01, \x08 (BS), \x0B (VT), \x1F (US), \x7F (DEL).
    testing.expectThrows(lam{ in cookie.build("s", "v", {path: "/a\x01b"}) }, "invalid byte in path")
    testing.expectThrows(lam{ in cookie.build("s", "v", {path: "/a\x08b"}) }, "invalid byte in path")
    testing.expectThrows(lam{ in cookie.build("s", "v", {path: "/a\x0bb"}) }, "invalid byte in path")
    testing.expectThrows(lam{ in cookie.build("s", "v", {path: "/a\x1fb"}) }, "invalid byte in path")
    testing.expectThrows(lam{ in cookie.build("s", "v", {path: "/a\x7fb"}) }, "invalid byte in path")
    testing.expectThrows(lam{ in cookie.build("s", "v", {domain: "x\x7fy"}) }, "invalid byte in domain")
})

testing.test("build: rejects '=' / ';' / whitespace in name", lam{ in
    testing.expectThrows(lam{ in cookie.build("ses;sion", "x", nil) }, "invalid character in name")
    testing.expectThrows(lam{ in cookie.build("ses=sion", "x", nil) }, "invalid character in name")
    testing.expectThrows(lam{ in cookie.build("ses sion", "x", nil) }, "invalid character in name")
})

testing.test("build: rejects control bytes and non-ASCII in name", lam{ in
    // CTLs (< 0x20 and == 0x7F) and any non-ASCII grapheme are outside
    // the RFC 7230 tchar allow-list and must be rejected.
    testing.expectThrows(lam{ in cookie.build("ses\x01ion", "x", nil) }, "invalid character in name")
    testing.expectThrows(lam{ in cookie.build("ses\x7fion", "x", nil) }, "invalid character in name")
    testing.expectThrows(lam{ in cookie.build("ses\x1fion", "x", nil) }, "invalid character in name")
    testing.expectThrows(lam{ in cookie.build("café",       "x", nil) }, "invalid character in name")
    testing.expectThrows(lam{ in cookie.build("名前",       "x", nil) }, "invalid character in name")
})

testing.test("build: accepts the full tchar punctuation set in names", lam{ in
    // Valid tchar punctuation per RFC 7230 — used by some real cookie
    // schemes (e.g. csrf-token, _ga, .session_id).
    let h = cookie.build("!#$%&'*+-.^_`|~", "x", nil)
    testing.expect(h.startsWith("!#$%&'*+-.^_`|~="),
        "tchar punctuation must round-trip into the name unchanged")
})

testing.test("build: rejects unknown sameSite values", lam{ in
    testing.expectThrows(
        lam{ in cookie.build("session", "abc", {sameSite: "Bogus"}) },
        "sameSite must be 'Strict', 'Lax', or 'None'")
})

testing.test("build: accepts the three legal sameSite values", lam{ in
    testing.expect(cookie.build("a", "b", {sameSite: "Strict"}).contains("SameSite=Strict"), nil)
    testing.expect(cookie.build("a", "b", {sameSite: "Lax"}).contains("SameSite=Lax"), nil)
    testing.expect(cookie.build("a", "b", {sameSite: "None"}).contains("SameSite=None"), nil)
})

testing.test("build: rejects non-numeric / NaN / infinite maxAge", lam{ in
    // Previously these values went through `toString()` and produced
    // malformed `Max-Age=...` attributes that browsers silently ignore.
    testing.expectThrows(
        lam{ in cookie.build("a", "b", {maxAge: "soon"}) },
        "maxAge must be a finite number")
    testing.expectThrows(
        lam{ in cookie.build("a", "b", {maxAge: nil}) },
        "maxAge must be a finite number")
    testing.expectThrows(
        lam{ in cookie.build("a", "b", {maxAge: math.sqrt(-1.0)}) },
        "maxAge must be a finite number")
    // Positive and negative infinity must also be rejected — they
    // exercise the math.isInf(m) branch the NaN test misses. `1.0/0.0`
    // throws in Praia, so we produce inf via the canonical
    // double-overflow trick.
    testing.expectThrows(
        lam{ in cookie.build("a", "b", {maxAge: 1e308 * 10}) },
        "maxAge must be a finite number")
    testing.expectThrows(
        lam{ in cookie.build("a", "b", {maxAge: -1e308 * 10}) },
        "maxAge must be a finite number")
})

testing.test("build: accepts integer + zero + negative maxAge", lam{ in
    testing.expect(cookie.build("a", "b", {maxAge: 3600}).contains("Max-Age=3600"), nil)
    testing.expect(cookie.build("a", "b", {maxAge: 0}).contains("Max-Age=0"),
        "Max-Age=0 means delete — must still emit")
    testing.expect(cookie.build("a", "b", {maxAge: -1}).contains("Max-Age=-1"),
        "negative is non-RFC but common-in-the-wild for cookie deletion")
})

testing.test("clear: emits a maxAge=0 expiry", lam{ in
    let h = cookie.clear("session", nil)
    testing.expect(h.contains("Max-Age=0"), nil)
    testing.expect(h.startsWith("session="), nil)
})

// ── parseSet ─────────────────────────────────────────────────

testing.test("parseSet: simple Set-Cookie value", lam{ in
    let c = cookie.parseSet("session=abc123")
    testing.expectEqual(c.name, "session", nil)
    testing.expectEqual(c.value, "abc123", nil)
    testing.expectEqual(c.path, nil, "no path attr → nil at parse time")
    testing.expectEqual(c.secure, false, nil)
    testing.expectEqual(c.httpOnly, false, nil)
})

testing.test("parseSet: full attribute set", lam{ in
    let c = cookie.parseSet("token=xyz; Path=/api; Domain=example.com; Max-Age=3600; HttpOnly; Secure; SameSite=Strict")
    testing.expectEqual(c.name, "token", nil)
    testing.expectEqual(c.value, "xyz", nil)
    testing.expectEqual(c.path, "/api", nil)
    testing.expectEqual(c.domain, "example.com", "domain lower-cased")
    testing.expectEqual(c.maxAge, 3600, nil)
    testing.expectEqual(c.httpOnly, true, nil)
    testing.expectEqual(c.secure, true, nil)
    testing.expectEqual(c.sameSite, "Strict", nil)
})

testing.test("parseSet: attribute names are case-insensitive", lam{ in
    let c = cookie.parseSet("k=v; PATH=/x; httponly; Max-Age=10")
    testing.expectEqual(c.path, "/x", nil)
    testing.expectEqual(c.httpOnly, true, nil)
    testing.expectEqual(c.maxAge, 10, nil)
})

testing.test("parseSet: malformed input returns nil", lam{ in
    testing.expectEqual(cookie.parseSet(""), nil, nil)
    testing.expectEqual(cookie.parseSet("no-equals"), nil, nil)
})

// ── sign / verify ────────────────────────────────────────────

testing.test("sign / verify roundtrip", lam{ in
    let signed = cookie.sign("uid=42", "secret")
    testing.expect(signed.startsWith("uid=42."), "value preserved as plaintext")
    testing.expectEqual(cookie.verify(signed, "secret"), "uid=42", nil)
})

testing.test("verify rejects tampered value", lam{ in
    let signed = cookie.sign("uid=42", "secret")
    // Swap "42" → "43"; the MAC suffix no longer covers the new value.
    let tampered = "uid=43" + signed.slice(signed.indexOf("."), len(signed))
    testing.expectEqual(cookie.verify(tampered, "secret"), nil, nil)
})

testing.test("verify rejects wrong key", lam{ in
    let signed = cookie.sign("uid=42", "secret")
    testing.expectEqual(cookie.verify(signed, "different-secret"), nil, nil)
})

testing.test("verify on malformed input returns nil", lam{ in
    testing.expectEqual(cookie.verify("no-dot-in-here", "key"), nil, nil)
    testing.expectEqual(cookie.verify(nil, "key"), nil, nil)
    testing.expectEqual(cookie.verify("", "key"), nil, nil)
})

testing.test("sign: deterministic for same input + key", lam{ in
    // HMAC is deterministic. Two signs of the same value+key produce
    // the same string — required for cookie equality checks.
    testing.expectEqual(cookie.sign("k=v", "secret"),
                        cookie.sign("k=v", "secret"), nil)
})

// ── encrypt / decrypt ────────────────────────────────────────

testing.test("encrypt / decrypt roundtrip", lam{ in
    let key = secrets.token(32)
    let sealed = cookie.encrypt("uid=42; role=admin", key)
    testing.expectEqual(cookie.decrypt(sealed, key), "uid=42; role=admin", nil)
})

testing.test("encrypt output is URL-safe base64 (no padding, no +/)", lam{ in
    let key = secrets.token(32)
    let sealed = cookie.encrypt("payload", key)
    for (i in 0..len(sealed)) {
        let c = sealed[i]
        testing.expect(
            "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_".contains(c),
            "non-urlsafe char at " + i + ": " + c)
    }
})

testing.test("encrypt: two seals of same plaintext produce different output", lam{ in
    // AES-GCM nonce is fresh per call, so identical plaintexts MUST
    // produce different sealed blobs (otherwise we'd be deterministic
    // and vulnerable to chosen-plaintext attacks).
    let key = secrets.token(32)
    let a = cookie.encrypt("same", key)
    let b = cookie.encrypt("same", key)
    testing.expect(a != b, nil)
})

testing.test("decrypt rejects wrong key", lam{ in
    let sealed = cookie.encrypt("payload", secrets.token(32))
    testing.expectEqual(cookie.decrypt(sealed, secrets.token(32)), nil, nil)
})

testing.test("decrypt rejects tampered blob", lam{ in
    let key = secrets.token(32)
    let sealed = cookie.encrypt("payload", key)
    // Flip a character at the start of the blob (inside the nonce). We
    // can't flip the *last* base64url char: the final group has 2 unused
    // padding bits, so 4 different chars decode to the same byte, and
    // ~25% of random nonces would let a "tampered" blob round-trip
    // unchanged at the byte level — flaky across runs.
    let tampered = (sealed[0] == "A" ? "B" : "A") + sealed.slice(1, len(sealed))
    testing.expectEqual(cookie.decrypt(tampered, key), nil, nil)
})

testing.test("decrypt on garbage / nil returns nil (no throw)", lam{ in
    let key = secrets.token(32)
    testing.expectEqual(cookie.decrypt("not_base64_at_all~~", key), nil, nil)
    testing.expectEqual(cookie.decrypt("", key), nil, nil)
    testing.expectEqual(cookie.decrypt(nil, key), nil, nil)
})

// ── Jar — single-request and roundtrip ───────────────────────

testing.test("Jar: empty jar emits empty Cookie header", lam{ in
    let jar = cookie.Jar()
    testing.expectEqual(jar.headerFor("https://example.com/"), "", nil)
    testing.expectEqual(jar.size(), 0, nil)
})

testing.test("Jar: accepts a Set-Cookie response and emits it back", lam{ in
    let jar = cookie.Jar()
    jar.acceptResponse("https://example.com/", {
        cookies: ["session=abc123; Path=/"]
    })
    testing.expectEqual(jar.headerFor("https://example.com/"), "session=abc123", nil)
})

testing.test("Jar: longer paths sort before shorter paths in the header", lam{ in
    // RFC 6265 §5.4: cookies with longer paths come first so a
    // request to /api/v1/x sees /api-scoped before /-scoped.
    let jar = cookie.Jar()
    jar.acceptResponse("https://example.com/api/v1/x", {
        cookies: [
            "g=root; Path=/",
            "api=v1; Path=/api",
            "specific=deep; Path=/api/v1"
        ]
    })
    let h = jar.headerFor("https://example.com/api/v1/items")
    testing.expect(h.startsWith("specific=deep"),
                   "longest path first; got: " + h)
})

testing.test("Jar: host-only cookies don't leak to other hosts", lam{ in
    // No Domain attribute → host-only. Subdomains must NOT receive it.
    let jar = cookie.Jar()
    jar.acceptResponse("https://api.example.com/", {
        cookies: ["session=abc; Path=/"]
    })
    testing.expectEqual(jar.headerFor("https://api.example.com/"),
                        "session=abc", "same host gets it")
    testing.expectEqual(jar.headerFor("https://www.example.com/"), "",
                        "sibling subdomain does NOT get a host-only cookie")
})

testing.test("Jar: Domain attribute scopes to subdomains", lam{ in
    let jar = cookie.Jar()
    jar.acceptResponse("https://api.example.com/", {
        cookies: ["shared=yes; Domain=example.com; Path=/"]
    })
    testing.expectEqual(jar.headerFor("https://www.example.com/"),
                        "shared=yes", "subdomain receives it")
    testing.expectEqual(jar.headerFor("https://example.com/"),
                        "shared=yes", "apex receives it")
    testing.expectEqual(jar.headerFor("https://unrelated.test/"), "",
                        "unrelated host does NOT")
})

testing.test("Jar: rejects Domain attribute for an unrelated origin", lam{ in
    // Attacker-controlled server tries to set a cookie for
    // bank.example.com from evil.com → must NOT be stored.
    let jar = cookie.Jar()
    jar.acceptResponse("https://evil.com/", {
        cookies: ["fake-session=hijack; Domain=bank.example.com; Path=/"]
    })
    testing.expectEqual(jar.headerFor("https://bank.example.com/"), "",
                        "cross-origin Domain attribute rejected")
    testing.expectEqual(jar.size(), 0, "cookie was dropped, not stored")
})

testing.test("Jar: Secure cookies only emit over https", lam{ in
    let jar = cookie.Jar()
    jar.acceptResponse("https://example.com/", {
        cookies: ["secret=v; Path=/; Secure"]
    })
    testing.expectEqual(jar.headerFor("https://example.com/"), "secret=v", nil)
    testing.expectEqual(jar.headerFor("http://example.com/"),  "",
                        "Secure cookie withheld from plaintext")
})

testing.test("Jar: path-match enforcement", lam{ in
    let jar = cookie.Jar()
    jar.acceptResponse("https://example.com/api/v1/x", {
        cookies: ["scoped=yes; Path=/api"]
    })
    testing.expectEqual(jar.headerFor("https://example.com/api/v1/"),
                        "scoped=yes", "sub-path match")
    testing.expectEqual(jar.headerFor("https://example.com/api"),
                        "scoped=yes", "exact match")
    testing.expectEqual(jar.headerFor("https://example.com/other"), "",
                        "outside the path scope")
    testing.expectEqual(jar.headerFor("https://example.com/apix"), "",
                        "false-prefix collision (no slash boundary)")
})

testing.test("Jar: re-setting (name, domain, path) replaces", lam{ in
    let jar = cookie.Jar()
    jar.acceptResponse("https://example.com/", {
        cookies: ["s=v1; Path=/"]
    })
    jar.acceptResponse("https://example.com/", {
        cookies: ["s=v2; Path=/"]
    })
    testing.expectEqual(jar.size(), 1, "same key → replaced not appended")
    testing.expectEqual(jar.headerFor("https://example.com/"), "s=v2", nil)
})

testing.test("Jar: Max-Age=0 deletes the matching cookie", lam{ in
    let jar = cookie.Jar()
    jar.acceptResponse("https://example.com/", {
        cookies: ["s=v; Path=/"]
    })
    testing.expectEqual(jar.size(), 1, nil)
    jar.acceptResponse("https://example.com/", {
        cookies: ["s=ignored; Path=/; Max-Age=0"]
    })
    testing.expectEqual(jar.size(), 0, "Max-Age=0 → delete")
    testing.expectEqual(jar.headerFor("https://example.com/"), "", nil)
})

testing.test("Jar: clear() empties the jar", lam{ in
    let jar = cookie.Jar()
    jar.acceptResponse("https://example.com/", {
        cookies: ["a=1; Path=/", "b=2; Path=/"]
    })
    testing.expectEqual(jar.size(), 2, nil)
    jar.clear()
    testing.expectEqual(jar.size(), 0, nil)
    testing.expectEqual(jar.headerFor("https://example.com/"), "", nil)
})

testing.test("Jar: no cookies on response is a no-op", lam{ in
    let jar = cookie.Jar()
    jar.acceptResponse("https://example.com/", {cookies: []})
    jar.acceptResponse("https://example.com/", {body: "x"})  // no cookies field
    testing.expectEqual(jar.size(), 0, nil)
})

// ── Integration: full request → response → next request ──────

testing.test("Integration: login + scoped subsequent request", lam{ in
    // Simulate a login response that sets session + csrf cookies
    // (different paths), then check that the right cookies surface
    // for two different subsequent endpoints.
    let jar = cookie.Jar()
    jar.acceptResponse("https://api.example.com/login", {
        cookies: [
            "session=sess-token; Path=/; HttpOnly; Secure",
            "csrf=csrf-tok; Path=/api"
        ]
    })

    // /api/profile is in the /api scope and over https
    let h1 = jar.headerFor("https://api.example.com/api/profile")
    testing.expect(h1.contains("session=sess-token"), nil)
    testing.expect(h1.contains("csrf=csrf-tok"), nil)

    // /static is NOT in /api, so only session leaks
    let h2 = jar.headerFor("https://api.example.com/static/app.js")
    testing.expectEqual(h2, "session=sess-token", nil)

    // Plain http: Secure cookie withheld; csrf still depends on path
    let h3 = jar.headerFor("http://api.example.com/api/x")
    testing.expectEqual(h3, "csrf=csrf-tok",
                        "Secure session withheld; non-secure csrf still emitted")
})

testing.done()
