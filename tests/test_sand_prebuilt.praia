use "testing"
use "../sand/grains/prebuilt"
use "../sand/grains/manifest"

// ── platformKey() ──────────────────────────────────────────────

testing.test("platformKey returns <platform>-<arch>", lam{ in
    let k = prebuilt.platformKey()
    testing.expect(k.contains("-"), "key must contain hyphen, got: %{k}")
    let firstHy = k.indexOf("-")
    let plat = k.slice(0, firstHy)
    testing.expect(plat == "darwin" || plat == "linux", "platform prefix must be darwin or linux, got: %{plat}")
})

// ── resolveEntry() ─────────────────────────────────────────────

testing.test("resolveEntry picks the exact platform key", lam{ in
    let key = prebuilt.platformKey()
    let m = {prebuilt: {}}
    m.prebuilt[key] = {url: "https://example.com/a.dylib",
                      integrity: "sha256-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"}
    let entry = prebuilt.resolveEntry(m)
    testing.expect(entry != nil, "expected to resolve our own platform key")
    testing.expectEqual(entry.url, "https://example.com/a.dylib", nil)
})

testing.test("resolveEntry returns nil when no key matches", lam{ in
    let m = {prebuilt: {"freebsd-riscv64": {url: "https://x/y", integrity: "sha256-bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"}}}
    testing.expectEqual(prebuilt.resolveEntry(m), nil, "no match → nil")
})

testing.test("resolveEntry returns nil when prebuilt block is absent", lam{ in
    let m = {name: "no-natives"}
    testing.expectEqual(prebuilt.resolveEntry(m), nil, "missing block → nil")
})

testing.test("resolveEntry falls back to darwin-universal on macOS", lam{ in
    if (sys.platform != "darwin") { return }
    let m = {prebuilt: {"darwin-universal": {url: "https://example.com/uni.dylib",
                                            integrity: "sha256-cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc"}}}
    let entry = prebuilt.resolveEntry(m)
    testing.expect(entry != nil, "darwin-universal should match on darwin")
    testing.expectEqual(entry.url, "https://example.com/uni.dylib", nil)
})

// ── manifest.read accept/reject ────────────────────────────────

testing.test("manifest.read accepts a well-formed prebuilt block", lam{ in
    let dir = testing.tempDir(nil)
    let m = manifest.create("widget", nil)
    m.prebuilt = {
        "darwin-arm64": {
            url: "https://example.com/widget.dylib",
            integrity: "sha256-1111111111111111111111111111111111111111111111111111111111111111"
        }
    }
    manifest.write(dir, m)
    let r = manifest.read(dir)
    testing.expectEqual(r.prebuilt["darwin-arm64"].url, "https://example.com/widget.dylib", nil)
})

testing.test("manifest.read rejects http (non-https) URL", lam{ in
    let dir = testing.tempDir(nil)
    fs.write(path.join(dir, "grain.yaml"),
        "name: bad\nversion: 0.1.0\nmain: main.praia\nprebuilt:\n  darwin-arm64:\n    url: http://oops\n    integrity: sha256-1111111111111111111111111111111111111111111111111111111111111111\ndependencies:\n")
    let threw = false
    try { manifest.read(dir) } catch (e) { threw = true }
    testing.expect(threw, "http:// URL must be rejected")
})

testing.test("manifest.read rejects malformed integrity", lam{ in
    let dir = testing.tempDir(nil)
    fs.write(path.join(dir, "grain.yaml"),
        "name: bad\nversion: 0.1.0\nmain: main.praia\nprebuilt:\n  linux-x86_64:\n    url: https://example.com/x.so\n    integrity: sha256-short\ndependencies:\n")
    let threw = false
    try { manifest.read(dir) } catch (e) { threw = true }
    testing.expect(threw, "short sha256 hex must be rejected")
})

testing.test("manifest.read rejects unknown platform name", lam{ in
    // 'plan9' isn't in ALLOWED_PLATFORMS — accepted shape, but the
    // platform allow-list catches it before fetch time.
    let dir = testing.tempDir(nil)
    fs.write(path.join(dir, "grain.yaml"),
        "name: bad\nversion: 0.1.0\nmain: main.praia\nprebuilt:\n  plan9-x86_64:\n    url: https://example.com/x.so\n    integrity: sha256-1111111111111111111111111111111111111111111111111111111111111111\ndependencies:\n")
    let threw = false
    try { manifest.read(dir) } catch (e) { threw = true }
    testing.expect(threw, "unknown platform name must be rejected")
})

testing.test("manifest.read rejects https URL with empty host", lam{ in
    let dir = testing.tempDir(nil)
    fs.write(path.join(dir, "grain.yaml"),
        "name: bad\nversion: 0.1.0\nmain: main.praia\nprebuilt:\n  linux-x86_64:\n    url: \"https://\"\n    integrity: sha256-1111111111111111111111111111111111111111111111111111111111111111\ndependencies:\n")
    let threw = false
    try { manifest.read(dir) } catch (e) { threw = true }
    testing.expect(threw, "https:// (empty host) must be rejected")
})

testing.test("manifest.read rejects https URL with dot-only host", lam{ in
    let dir = testing.tempDir(nil)
    fs.write(path.join(dir, "grain.yaml"),
        "name: bad\nversion: 0.1.0\nmain: main.praia\nprebuilt:\n  linux-x86_64:\n    url: \"https://...\"\n    integrity: sha256-1111111111111111111111111111111111111111111111111111111111111111\ndependencies:\n")
    let threw = false
    try { manifest.read(dir) } catch (e) { threw = true }
    testing.expect(threw, "host of only dots must be rejected")
})

testing.test("manifest.write emits prebuilt keys sorted", lam{ in
    let dir = testing.tempDir(nil)
    let m = manifest.create("widget", nil)
    // Insert in deliberately non-sorted order; expect alpha output.
    m.prebuilt = {}
    m.prebuilt["linux-x86_64"] = {url: "https://example.com/a.so",
                                  integrity: "sha256-1111111111111111111111111111111111111111111111111111111111111111"}
    m.prebuilt["darwin-arm64"] = {url: "https://example.com/b.dylib",
                                  integrity: "sha256-2222222222222222222222222222222222222222222222222222222222222222"}
    manifest.write(dir, m)
    let text = fs.read(path.join(dir, "grain.yaml"))
    let darwinIdx = text.indexOf("darwin-arm64")
    let linuxIdx = text.indexOf("linux-x86_64")
    testing.expect(darwinIdx >= 0 && linuxIdx >= 0, "both keys present")
    testing.expect(darwinIdx < linuxIdx, "darwin-arm64 must sort before linux-x86_64")
})

testing.test("manifest.read rejects upper-case platform key", lam{ in
    let dir = testing.tempDir(nil)
    fs.write(path.join(dir, "grain.yaml"),
        "name: bad\nversion: 0.1.0\nmain: main.praia\nprebuilt:\n  Darwin-arm64:\n    url: https://example.com/x.dylib\n    integrity: sha256-1111111111111111111111111111111111111111111111111111111111111111\ndependencies:\n")
    let threw = false
    try { manifest.read(dir) } catch (e) { threw = true }
    testing.expect(threw, "non-lowercase platform key must be rejected")
})

testing.test("manifest.read rejects non-map entry", lam{ in
    let dir = testing.tempDir(nil)
    fs.write(path.join(dir, "grain.yaml"),
        "name: bad\nversion: 0.1.0\nmain: main.praia\nprebuilt:\n  darwin-arm64: \"just a string\"\ndependencies:\n")
    let threw = false
    try { manifest.read(dir) } catch (e) { threw = true }
    testing.expect(threw, "scalar entry must be rejected")
})

testing.test("manifest round-trips a prebuilt block", lam{ in
    let dir = testing.tempDir(nil)
    let m = manifest.create("widget", nil)
    m.prebuilt = {
        "darwin-arm64": {url: "https://example.com/w.dylib",
                         integrity: "sha256-1111111111111111111111111111111111111111111111111111111111111111"},
        "linux-x86_64": {url: "https://example.com/w-linux-x86_64.so",
                         integrity: "sha256-2222222222222222222222222222222222222222222222222222222222222222"}
    }
    manifest.write(dir, m)
    let r = manifest.read(dir)
    testing.expectEqual(r.prebuilt["darwin-arm64"].url, "https://example.com/w.dylib", nil)
    testing.expectEqual(r.prebuilt["linux-x86_64"].integrity,
                       "sha256-2222222222222222222222222222222222222222222222222222222222222222", nil)
})

// ── Integration: installEntry against a local HTTP server ──────
//
// Spins an in-process server on an ephemeral port, publishes the
// bound port through a SharedMap, then exercises the happy and
// failure paths of prebuilt.installEntry against it. No external
// network, no python dependency.

let _state = SharedMap()

// A 12-byte fixture "binary." Tiny so the test runs fast; the
// content doesn't have to be a real Mach-O / ELF — installEntry
// just verifies the byte hash and chmods the file.
let _binBytes = "PRAIA_BIN_OK"
let _binSha   = "sha256-" + crypto.sha256(_binBytes)

let _serverFuture = async lam{ in
    let s = net.listen(0)
    _state.set("port", net.localAddr(s).port)
    while (true) {
        let c = net.accept(s)
        let req = ""
        while (!req.contains("\r\n\r\n")) {
            let chunk = net.recv(c, 4096)
            if (len(chunk) == 0) { break }
            req = req + chunk
        }
        let firstSp = req.indexOf(" ")
        let after = req.slice(firstSp + 1, len(req))
        let p = after.slice(0, after.indexOf(" "))
        // Drop any query string so the route table can stay
        // path-only — the query-string round-trip test relies on
        // this so a request for `/widget.dylib?token=...` still
        // returns the body for `/widget.dylib`.
        let q = p.indexOf("?")
        if (q >= 0) { p = p.slice(0, q) }
        let body = ""
        let status = "200 OK"
        if (p == "/widget.dylib") { body = _binBytes }
        elif (p == "/widget-linux-x86_64.so") { body = _binBytes }
        else { status = "404 Not Found"; body = "not here" }
        let resp = "HTTP/1.1 %{status}\r\nContent-Length: %{len(body)}\r\nConnection: close\r\n\r\n%{body}"
        net.send(c, resp)
        net.close(c)
    }
}()

// Wait for the server to publish its port (avoid the sleep+race).
let _port = nil
while (_port == nil) {
    _port = _state.get("port")
    if (_port == nil) { time.sleep(5) }
}
let _baseUrl = "http://127.0.0.1:%{_port}"

// installEntry validates URL scheme via isValidPrebuiltUrl (https
// only) but installEntry itself doesn't — the schema check is done
// at manifest.read time, and installEntry trusts whatever the
// upstream resolver hands it. So we can point at a local http:// URL
// for tests.

testing.test("installEntry downloads, hashes, writes plugins/<basename>", lam{ in
    let stage = testing.tempDir(nil)
    let entry = {url: "%{_baseUrl}/widget.dylib", integrity: _binSha}
    let ok = prebuilt.installEntry(entry, stage, false, {blockPrivateHosts: false})
    testing.expect(ok, "installEntry must return true on success")
    let dest = path.join(stage, "plugins", "widget.dylib")
    testing.expect(fs.exists(dest), "binary should land at plugins/widget.dylib")
    testing.expectEqual(fs.read(dest), _binBytes, "bytes round-trip intact")
})

testing.test("installEntry throws on hash mismatch", lam{ in
    let stage = testing.tempDir(nil)
    let wrong = "sha256-" + "0123456789abcdef" + "0123456789abcdef" +
                            "0123456789abcdef" + "0123456789abcdef"
    let entry = {url: "%{_baseUrl}/widget.dylib", integrity: wrong}
    let threw = false
    try { prebuilt.installEntry(entry, stage, false, {blockPrivateHosts: false}) } catch (e) { threw = true }
    testing.expect(threw, "mismatched hash must throw")
    testing.expect(!fs.exists(path.join(stage, "plugins", "widget.dylib")),
                   "no binary should be written on mismatch")
})

testing.test("installEntry throws on HTTP 404", lam{ in
    let stage = testing.tempDir(nil)
    let entry = {url: "%{_baseUrl}/missing.dylib", integrity: _binSha}
    let threw = false
    try { prebuilt.installEntry(entry, stage, false, {blockPrivateHosts: false}) } catch (e) { threw = true }
    testing.expect(threw, "404 must throw, not silently install garbage")
})

// ── fetchAndStage: end-to-end resolver + install ───────────────

testing.test("fetchAndStage returns false when no entry matches", lam{ in
    let stage = testing.tempDir(nil)
    let m = {prebuilt: {"freebsd-riscv64": {url: "%{_baseUrl}/widget.dylib", integrity: _binSha}}}
    testing.expectEqual(prebuilt.fetchAndStage(m, stage, false, {blockPrivateHosts: false}), false,
                       "no-match must return false (caller falls back to source)")
})

testing.test("fetchAndStage installs the matching entry", lam{ in
    let stage = testing.tempDir(nil)
    let key = prebuilt.platformKey()
    let m = {prebuilt: {}}
    m.prebuilt[key] = {url: "%{_baseUrl}/widget.dylib", integrity: _binSha}
    testing.expectEqual(prebuilt.fetchAndStage(m, stage, false, {blockPrivateHosts: false}), true, "match → true")
    testing.expect(fs.exists(path.join(stage, "plugins", "widget.dylib")), "binary written")
})

testing.test("installEntry strips query string from filename", lam{ in
    // Presigned-S3 / CDN URLs often carry a query string;
    // path.basename(url) would otherwise land the binary at
    // `plugins/widget.dylib?token=abc`, where the runtime loader
    // (which looks for the plain `widget.dylib`) can't find it.
    let stage = testing.tempDir(nil)
    let entry = {url: "%{_baseUrl}/widget.dylib?token=abc&exp=1", integrity: _binSha}
    let ok = prebuilt.installEntry(entry, stage, false, {blockPrivateHosts: false})
    testing.expect(ok, "install should succeed")
    testing.expect(fs.exists(path.join(stage, "plugins", "widget.dylib")),
                   "binary lands at the clean basename")
    testing.expect(!fs.exists(path.join(stage, "plugins", "widget.dylib?token=abc&exp=1")),
                   "no garbage-named file")
})

testing.done()
