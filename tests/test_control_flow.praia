use "testing"

testing.test("if/else", lam{ in
    let x = 10
    let result = ""
    if (x > 5) { result = "big" } else { result = "small" }
    testing.expectEqual(result, "big", nil)
})

testing.test("elif chain", lam{ in
    func classify(n) {
        if (n < 0) { return "negative" }
        elif (n == 0) { return "zero" }
        elif (n < 10) { return "small" }
        else { return "large" }
    }
    testing.expectEqual(classify(-5), "negative", nil)
    testing.expectEqual(classify(0), "zero", nil)
    testing.expectEqual(classify(3), "small", nil)
    testing.expectEqual(classify(100), "large", nil)
})

testing.test("while loop", lam{ in
    let i = 0
    let sum = 0
    while (i < 5) {
        sum = sum + i
        i = i + 1
    }
    testing.expectEqual(sum, 10, nil)
})

testing.test("for range loop", lam{ in
    let sum = 0
    for (i in 1 .. 11) {
        sum = sum + i
    }
    testing.expectEqual(sum, 55, nil)
})

testing.test("break", lam{ in
    let found = -1
    for (i in 0 .. 100) {
        if (i == 42) {
            found = i
            break
        }
    }
    testing.expectEqual(found, 42, nil)
})

testing.test("continue", lam{ in
    let evens = []
    for (i in 0 .. 10) {
        if (i % 2 != 0) { continue }
        evens.push(i)
    }
    testing.expectEqual(len(evens), 5, nil)
    testing.expectEqual(evens[0], 0, nil)
    testing.expectEqual(evens[4], 8, nil)
})

testing.test("truthiness", lam{ in
    // Only nil and false are falsy — everything else is truthy
    testing.expect(1, nil)
    testing.expect("hello", nil)
    testing.expect([1], nil)
    testing.expect(0, "0 is truthy")
    testing.expect("", "empty string is truthy")
    testing.expect([], "empty array is truthy")
    testing.expect(!nil, "nil is falsy")
    testing.expect(!false, "false is falsy")
})

testing.test("short-circuit or", lam{ in
    let x = nil || "default"
    testing.expectEqual(x, "default", nil)
    let y = "set" || "default"
    testing.expectEqual(y, "set", nil)
})

testing.done()
