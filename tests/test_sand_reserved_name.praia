use "testing"
use "../sand/grains/config"

// Regression: sand used to allow any repo whose `grain.yaml` declared
// `name: sand` to claim the reserved `sand` install directory and bin
// wrapper. A fork at github.com/attacker/evil could overwrite the
// user's actual sand, and from then on every `sand <cmd>` invocation
// would run attacker code. The fix locks the reserved name to the
// canonical upstream (or a local file:// mirror, which already
// implies local code execution).
//
// The first three tests exercise the policy directly via the
// extracted `config.isAllowedSandSource` predicate — that gives
// deterministic gate coverage without needing the install to clone.
// The end-to-end tests below then verify the CLI surfaces the gate
// for both the allowed file:// case (succeeds) and the
// rename-via-manifest attack (no sand dir planted).

testing.test("isAllowedSandSource accepts the canonical upstream", lam{ in
    testing.expectEqual(
        config.isAllowedSandSource(config.SAND_REPO_URL), true,
        "canonical SAND_REPO_URL is allowed")
})

testing.test("isAllowedSandSource accepts any file:// URL", lam{ in
    testing.expectEqual(
        config.isAllowedSandSource("file:///tmp/sand"), true,
        "file:// is allowed (local trust)")
    testing.expectEqual(
        config.isAllowedSandSource("file:///home/user/forks/sand"), true,
        nil)
})

testing.test("isAllowedSandSource rejects any other URL", lam{ in
    // Lookalike + completely unrelated + scheme variations.
    testing.expectEqual(
        config.isAllowedSandSource("https://github.com/attacker/sand.git"),
        false, "remote fork rejected")
    testing.expectEqual(
        config.isAllowedSandSource("https://github.com/praia-lang/sand"),
        false, "https without .git suffix doesn't match the canonical URL")
    testing.expectEqual(
        config.isAllowedSandSource("http://github.com/praia-lang/sand.git"),
        false, "http (no s) is not the canonical URL")
    testing.expectEqual(
        config.isAllowedSandSource("git@github.com:praia-lang/sand.git"),
        false, "ssh form not allowed for the reserved name")
    testing.expectEqual(
        config.isAllowedSandSource("ssh://git@github.com/praia-lang/sand.git"),
        false, "ssh:// form not allowed for the reserved name")
    testing.expectEqual(
        config.isAllowedSandSource(""), false, "empty rejected")
    testing.expectEqual(
        config.isAllowedSandSource(nil), false, "nil rejected")
})

// ── End-to-end CLI coverage ─────────────────────────────────────

let _gitProbe = sys.exec(["git", "--version"])
if (_gitProbe.exitCode != 0) {
    print("(skipping CLI tests: git not available)")
    testing.done()
    sys.exit(0)
}

let praiaBin = path.join(sys.cwd(), "praia")
let sandMain = path.join(sys.cwd(), "sand", "main.praia")

func runSand(home, args) {
    let cmd = ["env", "HOME=" + home, praiaBin, sandMain]
    for (a in args) { cmd.push(a) }
    return sys.exec(cmd)
}

// Build a fixture grain whose grain.yaml claims `name: sand`. Each
// git step asserts exit=0 immediately so a fixture setup failure
// fails the test loudly instead of producing a confusing
// "wrapper missing" error pages later.
func makeEvilSand(root) {
    let g = path.join(root, "evil")
    fs.mkdir(g)
    fs.write(path.join(g, "main.praia"), "print(\"evil sand pwned\")\n")
    fs.write(path.join(g, "grain.yaml"),
        "name: sand\nversion: 999.0\nmain: main.praia\nbin:\n  sand: main.praia\n")
    let r1 = sys.exec(["git", "init", "-q", g])
    testing.expectEqual(r1.exitCode, 0, "git init: " + r1.stderr)
    let r2 = sys.exec(["git", "-C", g, "add", "-A"])
    testing.expectEqual(r2.exitCode, 0, "git add: " + r2.stderr)
    let r3 = sys.exec(["git", "-C", g,
              "-c", "user.email=t@t", "-c", "user.name=t",
              "commit", "-q", "-m", "init"])
    testing.expectEqual(r3.exitCode, 0, "git commit: " + r3.stderr)
    return g
}

testing.test("file:// fork claiming name: sand can still install (local trust)", lam{ in
    let sandHome = testing.tempDir(nil)
    let fixtureRoot = testing.tempDir(nil)
    let evil = makeEvilSand(fixtureRoot)

    let r = runSand(sandHome, ["install", "-g", "file://" + evil])
    testing.expectEqual(r.exitCode, 0,
        "file:// install of name: sand succeeds: " + r.stderr)
})

testing.test("rename-via-manifest attack leaves no sand dir or wrapper", lam{ in
    // The CLI counterpart to the unit tests above: a non-file:// spec
    // pointing at *anything* with `name: sand` in its manifest must
    // not produce an installed sand. We can't easily make the clone
    // succeed (would require a local git server), but the outcome
    // we care about is "no sand on disk" — same end result whether
    // the gate fires or the clone fails first.
    let sandHome = testing.tempDir(nil)
    let r = runSand(sandHome,
        ["install", "-g", "https://example.invalid/me/innocent-looking-grain"])
    testing.expect(r.exitCode != 0, "install must fail")
    testing.expect(
        !fs.exists(path.join(sandHome, ".praia", "ext_grains", "sand")),
        "no sand dir planted by rejected install")
    testing.expect(
        !fs.exists(path.join(sandHome, ".praia", "bin", "sand")),
        "no sand bin wrapper planted by rejected install")
})

testing.done()
