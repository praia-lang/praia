use "testing"

// ── map .delete() ──

testing.test("delete existing key returns true", lam{ in
    let m = {a: 1, b: 2}
    testing.expect(m.delete("a"), nil)
    testing.expect(!m.has("a"), "key should be gone")
    testing.expectEqual(m.b, 2, "other keys unchanged")
})

testing.test("delete missing key returns false", lam{ in
    let m = {a: 1}
    testing.expect(!m.delete("z"), nil)
})

testing.test("delete with non-string key", lam{ in
    let m = {[1]: "one", [2]: "two"}
    m.delete(1)
    testing.expect(!m.has(1), nil)
    testing.expect(m.has(2), nil)
})

// ── map .merge() ──

testing.test("merge combines maps", lam{ in
    let result = {a: 1}.merge({b: 2})
    testing.expectEqual(result.a, 1, nil)
    testing.expectEqual(result.b, 2, nil)
})

testing.test("merge overwrites duplicates", lam{ in
    let result = {a: 1, b: 2}.merge({b: 99, c: 3})
    testing.expectEqual(result.b, 99, "second map wins")
    testing.expectEqual(result.c, 3, nil)
})

testing.test("merge returns new map", lam{ in
    let orig = {a: 1}
    let merged = orig.merge({b: 2})
    testing.expect(!orig.has("b"), "original unchanged")
})

testing.test("merge empty maps", lam{ in
    let r1 = {a: 1}.merge({})
    testing.expectEqual(r1.a, 1, nil)
    let r2 = {}.merge({b: 2})
    testing.expectEqual(r2.b, 2, nil)
})

// ── groupBy ──

testing.test("groupBy groups elements", lam{ in
    let items = [{t: "a", v: 1}, {t: "b", v: 2}, {t: "a", v: 3}]
    let groups = items |> groupBy(lam{ x in x.t })
    testing.expectEqual(len(groups.a), 2, nil)
    testing.expectEqual(len(groups.b), 1, nil)
    testing.expectEqual(groups.a[0].v, 1, nil)
    testing.expectEqual(groups.a[1].v, 3, nil)
})

testing.test("groupBy with numbers", lam{ in
    let groups = [1, 2, 3, 4, 5, 6] |> groupBy(lam{ x in x % 2 == 0 ? "even" : "odd" })
    testing.expectEqual(len(groups.even), 3, nil)
    testing.expectEqual(len(groups.odd), 3, nil)
})

testing.test("groupBy empty array", lam{ in
    let groups = [] |> groupBy(lam{ x in x })
    testing.expectEqual(len(keys(groups)), 0, nil)
})

// ── sys.envAll ──

testing.test("envAll returns map with PATH", lam{ in
    let env = sys.envAll()
    testing.expect(env.has("PATH"), "PATH should exist")
    testing.expect(len(env.get("PATH", "")) > 0, "PATH should be non-empty")
})

// ── sys.chdir ──

testing.test("chdir changes directory", lam{ in
    let orig = sys.cwd()
    sys.chdir("/tmp")
    let after = sys.cwd()
    sys.chdir(orig)
    testing.expect(after.contains("tmp"), nil)
    testing.expectEqual(sys.cwd(), orig, "restored")
})

testing.test("chdir invalid path throws", lam{ in
    testing.expectThrows(lam{ in sys.chdir("/nonexistent_dir_12345") }, nil)
})

// ── fs.readLines ──

testing.test("readLines returns array of lines", lam{ in
    let tmpFile = "/tmp/praia_test_readlines.txt"
    fs.write(tmpFile, "alpha\nbeta\ngamma\n")
    let lines = fs.readLines(tmpFile)
    testing.expectEqual(len(lines), 3, nil)
    testing.expectEqual(lines[0], "alpha", nil)
    testing.expectEqual(lines[1], "beta", nil)
    testing.expectEqual(lines[2], "gamma", nil)
    fs.remove(tmpFile)
})

testing.test("readLines empty file", lam{ in
    let tmpFile = "/tmp/praia_test_empty.txt"
    fs.write(tmpFile, "")
    let lines = fs.readLines(tmpFile)
    testing.expectEqual(len(lines), 0, nil)
    fs.remove(tmpFile)
})

testing.test("readLines nonexistent file throws", lam{ in
    testing.expectThrows(lam{ in fs.readLines("/nonexistent_file.txt") }, nil)
})

testing.done()
