use "testing"

// ── Hashing ──

testing.test("md5", lam{ in
    testing.expectEqual(crypto.md5("hello"), "5d41402abc4b2a76b9719d911017c592", nil)
    testing.expectEqual(crypto.md5(""), "d41d8cd98f00b204e9800998ecf8427e", nil)
})

testing.test("sha1", lam{ in
    testing.expectEqual(crypto.sha1("hello"), "aaf4c61ddcc5e8a2dabede0f3b482cd9aea9434d", nil)
    testing.expectEqual(crypto.sha1(""), "da39a3ee5e6b4b0d3255bfef95601890afd80709", nil)
})

testing.test("sha256", lam{ in
    testing.expectEqual(crypto.sha256("hello"), "2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824", nil)
    testing.expectEqual(crypto.sha256(""), "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855", nil)
})

testing.test("sha512", lam{ in
    let hash = crypto.sha512("hello")
    testing.expectEqual(len(hash), 128, "sha512 produces 128 hex chars")
    testing.expect(hash.startsWith("9b71d224bd62f378"), "sha512 starts correctly")
})

// ── HMAC ──

testing.test("hmac sha256", lam{ in
    testing.expectEqual(
        crypto.hmac("key", "message", "sha256"),
        "6e9ef29b75fffc5b7abae527d58fdadb2fe42e7219011976917343065f58ed4a",
        nil
    )
})

testing.test("hmac sha1", lam{ in
    let result = crypto.hmac("key", "message", "sha1")
    testing.expectEqual(len(result), 40, "hmac-sha1 produces 40 hex chars")
})

testing.test("hmac sha512", lam{ in
    let result = crypto.hmac("key", "message", "sha512")
    testing.expectEqual(len(result), 128, "hmac-sha512 produces 128 hex chars")
})

// ── Random bytes ──

testing.test("randomBytes length", lam{ in
    let r = crypto.randomBytes(16)
    testing.expectEqual(bytes.len(r), 16, nil)
    let r2 = crypto.randomBytes(32)
    testing.expectEqual(bytes.len(r2), 32, nil)
})

testing.test("randomBytes are random", lam{ in
    let a = crypto.randomBytes(16)
    let b = crypto.randomBytes(16)
    testing.expect(a != b, "two random byte strings should differ")
})

testing.test("randomBytes zero", lam{ in
    let r = crypto.randomBytes(0)
    testing.expectEqual(bytes.len(r), 0, nil)
})

// ── AES encrypt/decrypt ──

testing.test("aes encrypt decrypt roundtrip", lam{ in
    let key = crypto.randomBytes(32)
    let iv = crypto.randomBytes(16)
    let plaintext = "hello world"
    let ciphertext = crypto.encrypt(plaintext, key, iv)
    let decrypted = crypto.decrypt(ciphertext, key, iv)
    testing.expectEqual(decrypted, plaintext, nil)
})

testing.test("aes different key fails", lam{ in
    let key1 = crypto.randomBytes(32)
    let key2 = crypto.randomBytes(32)
    let iv = crypto.randomBytes(16)
    let ciphertext = crypto.encrypt("secret", key1, iv)
    let ok = false
    try {
        crypto.decrypt(ciphertext, key2, iv)
    } catch (e) {
        ok = true
    }
    testing.expect(ok, "wrong key should fail")
})

testing.test("aes empty string", lam{ in
    let key = crypto.randomBytes(32)
    let iv = crypto.randomBytes(16)
    let enc = crypto.encrypt("", key, iv)
    testing.expectEqual(crypto.decrypt(enc, key, iv), "", nil)
})

// ── Password hashing ──

testing.test("hashPassword and verifyPassword", lam{ in
    let result = crypto.hashPassword("mypassword")
    testing.expect(result.hash != nil, "has hash")
    testing.expect(result.salt != nil, "has salt")
    testing.expect(crypto.verifyPassword("mypassword", result.hash, result.salt), "correct password")
    testing.expect(!crypto.verifyPassword("wrong", result.hash, result.salt), "wrong password")
})

testing.test("hashPassword custom iterations", lam{ in
    let result = crypto.hashPassword("test", nil, 1000)
    testing.expectEqual(result.iterations, 1000, nil)
    testing.expect(crypto.verifyPassword("test", result.hash, result.salt, 1000), nil)
})

// ── Input-validation regressions ──────────────────────────────

testing.test("verifyPassword rejects odd-length salt hex", lam{ in
    // Regression: an odd trailing nibble used to be silently dropped,
    // so e.g. "616263f" decoded the same as "616263" ("abc") and
    // verified a hash made with that shorter salt.
    let result = crypto.hashPassword("pw", "abc", 1000)
    testing.expectEqual(result.salt, "616263", "sanity: salt encodes as 616263")
    testing.expectThrows(
        lam{ in crypto.verifyPassword("pw", result.hash, "616263f", 1000) },
        "even length")
})

testing.test("hashPassword rejects non-string salt", lam{ in
    // Regression: previously silently generated a random salt when
    // the salt arg wasn't a string, masking caller bugs.
    testing.expectThrows(
        lam{ in crypto.hashPassword("pw", 42) },
        "salt must be a string")
    testing.expectThrows(
        lam{ in crypto.hashPassword("pw", {"x": 1}) },
        "salt must be a string")
})

testing.test("hashPassword rejects iterations < 1", lam{ in
    // Regression: previously clamped < 1 to 1 silently.
    testing.expectThrows(
        lam{ in crypto.hashPassword("pw", "salt", 0) },
        "iterations must be >= 1")
    testing.expectThrows(
        lam{ in crypto.hashPassword("pw", "salt", -5) },
        "iterations must be >= 1")
})

testing.test("hashPassword rejects non-number iterations", lam{ in
    testing.expectThrows(
        lam{ in crypto.hashPassword("pw", "salt", "lots") },
        "iterations must be a number")
})

testing.test("hashPassword rejects fractional iterations", lam{ in
    // Regression: 1.9 silently truncated to 1 (caller asked for >= 2
    // work, silently got the absolute minimum).
    testing.expectThrows(
        lam{ in crypto.hashPassword("pw", "salt", 1.9) },
        "must be an integer")
})

testing.test("hashPassword rejects non-finite iterations", lam{ in
    // Regression: math.INF cast to int64 is UB; on most arches it
    // happened to hit the < 1 branch, but the behavior was platform-
    // dependent and the input itself is the bug.
    testing.expectThrows(
        lam{ in crypto.hashPassword("pw", "salt", math.INF) },
        "finite number")
    testing.expectThrows(
        lam{ in crypto.hashPassword("pw", "salt", -math.INF) },
        "finite number")
})

testing.test("hashPassword rejects iterations > INT32_MAX", lam{ in
    // Regression: values above INT32_MAX got std::min'd down to
    // INT32_MAX, so iterations=1e10 silently ran ~2 billion HMAC
    // rounds — effectively a self-DoS.
    testing.expectThrows(
        lam{ in crypto.hashPassword("pw", "salt", 1e10) },
        "1e10 exceeds INT32_MAX")
    testing.expectThrows(
        lam{ in crypto.hashPassword("pw", "salt", 2147483648) },
        "INT32_MAX + 1 rejected as out of range")
})

testing.test("verifyPassword applies the same iterations rigor", lam{ in
    testing.expectThrows(
        lam{ in crypto.verifyPassword("pw", "00", "00", 1.5) },
        "fractional rejected")
    testing.expectThrows(
        lam{ in crypto.verifyPassword("pw", "00", "00", math.INF) },
        "infinity rejected")
    testing.expectThrows(
        lam{ in crypto.verifyPassword("pw", "00", "00", 1e10) },
        "out-of-range rejected")
})

// ── AES-256-GCM AEAD (seal / open) ────────────────────────────

testing.test("seal/open roundtrip", lam{ in
    let key = crypto.randomBytes(32)
    let pt  = "Hello, AEAD world."
    let sealed = crypto.seal(pt, key)
    testing.expectEqual(crypto.open(sealed, key), pt, nil)
})

testing.test("seal/open empty plaintext", lam{ in
    let key = crypto.randomBytes(32)
    let sealed = crypto.seal("", key)
    testing.expectEqual(crypto.open(sealed, key), "", nil)
})

testing.test("seal produces a different blob each call (fresh nonce)", lam{ in
    let key = crypto.randomBytes(32)
    let a = crypto.seal("same plaintext", key)
    let b = crypto.seal("same plaintext", key)
    testing.expect(a != b, "two seals of the same plaintext must differ")
})

testing.test("open rejects tampered ciphertext", lam{ in
    let key = crypto.randomBytes(32)
    let sealed = crypto.seal("important data", key)
    // Flip a bit somewhere in the ciphertext portion (offset 15 lands
    // past the 12-byte nonce, before the tag).
    let arr = bytes.toArray(sealed)
    arr[15] = arr[15] ^ 1
    let tampered = bytes.from(arr)
    testing.expectThrows(lam{ in crypto.open(tampered, key) },
                         "authentication failed")
})

testing.test("open rejects wrong key", lam{ in
    let key1 = crypto.randomBytes(32)
    let key2 = crypto.randomBytes(32)
    let sealed = crypto.seal("x", key1)
    testing.expectThrows(lam{ in crypto.open(sealed, key2) },
                         "authentication failed")
})

testing.test("AAD binds context to tag", lam{ in
    let key = crypto.randomBytes(32)
    let sealed = crypto.seal("payload", key, "user-id:42")
    // Correct AAD verifies.
    testing.expectEqual(crypto.open(sealed, key, "user-id:42"), "payload", nil)
    // Different AAD fails.
    testing.expectThrows(lam{ in crypto.open(sealed, key, "user-id:43") },
                         "authentication failed")
    // Missing AAD on a sealed-with-AAD blob fails.
    testing.expectThrows(lam{ in crypto.open(sealed, key) },
                         "authentication failed")
})

testing.test("seal rejects wrong-size key", lam{ in
    testing.expectThrows(lam{ in crypto.seal("x", "short") }, "32 bytes")
})

testing.test("open rejects short sealed blob", lam{ in
    let key = crypto.randomBytes(32)
    testing.expectThrows(lam{ in crypto.open("tooshort", key) }, "too short")
})

testing.done()
