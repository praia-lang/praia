use "testing"

// ── Primitive type checks ──

testing.test("is nil", lam{ in
    testing.expect(nil is "nil", nil)
    testing.expect(!(0 is "nil"), nil)
    testing.expect(!("" is "nil"), nil)
})

testing.test("is bool", lam{ in
    testing.expect(true is "bool", nil)
    testing.expect(false is "bool", nil)
    testing.expect(!(1 is "bool"), nil)
})

testing.test("is int", lam{ in
    testing.expect(42 is "int", nil)
    testing.expect(0 is "int", nil)
    testing.expect(!(3.14 is "int"), nil)
    testing.expect(!("42" is "int"), nil)
})

testing.test("is float", lam{ in
    testing.expect(3.14 is "float", nil)
    testing.expect(!(42 is "float"), nil)
})

testing.test("is string", lam{ in
    testing.expect("hello" is "string", nil)
    testing.expect("" is "string", nil)
    testing.expect(!(42 is "string"), nil)
})

testing.test("is array", lam{ in
    testing.expect([1, 2] is "array", nil)
    testing.expect([] is "array", nil)
    testing.expect(!("[]" is "array"), nil)
})

testing.test("is map", lam{ in
    testing.expect({a: 1} is "map", nil)
    testing.expect(!([1] is "map"), nil)
})

testing.test("is function", lam{ in
    func f() {}
    testing.expect(f is "function", nil)
    let lam1 = lam{ in 1 }
    testing.expect(lam1 is "function", nil)
    testing.expect(!(42 is "function"), nil)
})

// ── Class instanceof ──

testing.test("is class", lam{ in
    class Foo {
        func init() {}
    }
    let f = Foo()
    testing.expect(f is Foo, nil)
    testing.expect(!(42 is Foo), nil)
    testing.expect(!("hello" is Foo), nil)
})

testing.test("is with inheritance", lam{ in
    class Animal {
        func init(name) { this.name = name }
    }
    class Dog extends Animal {
        func init(name) { super.init(name) }
    }
    let d = Dog("Rex")
    testing.expect(d is Dog, nil)
    testing.expect(d is Animal, "Dog is also an Animal")
    let a = Animal("Cat")
    testing.expect(a is Animal, nil)
    testing.expect(!(a is Dog), "Animal is not a Dog")
})

testing.test("is with deep inheritance", lam{ in
    class A {}
    class B extends A {}
    class C extends B {}
    let c = C()
    testing.expect(c is C, nil)
    testing.expect(c is B, nil)
    testing.expect(c is A, nil)
})

// ── Negation ──

testing.test("negation with !", lam{ in
    testing.expect(!(42 is "string"), nil)
    testing.expect(!("hi" is "int"), nil)
})

// ── In conditionals ──

testing.test("is in if condition", lam{ in
    let x = 42
    let result = ""
    if (x is "int") {
        result = "integer"
    } elif (x is "string") {
        result = "string"
    }
    testing.expectEqual(result, "integer", nil)
})

testing.test("is with match", lam{ in
    func describe(x) {
        if (x is "int") { return "integer" }
        if (x is "string") { return "text" }
        if (x is "array") { return "list" }
        return "other"
    }
    testing.expectEqual(describe(42), "integer", nil)
    testing.expectEqual(describe("hi"), "text", nil)
    testing.expectEqual(describe([1]), "list", nil)
    testing.expectEqual(describe(nil), "other", nil)
})

testing.done()
