use "testing"
use "args"

testing.test("parse long flags", lam{ in
    let cli = args.parse({
        port: {type: "number", default: 8080},
        verbose: {type: "bool"}
    }, ["--port", "3000", "--verbose"])
    testing.expectEqual(cli.port, 3000, nil)
    testing.expectEqual(cli.verbose, true, nil)
})

testing.test("parse short flags", lam{ in
    let cli = args.parse({
        port: {type: "number", short: "p", default: 8080},
        verbose: {type: "bool", short: "v"}
    }, ["-p", "9090", "-v"])
    testing.expectEqual(cli.port, 9090, nil)
    testing.expectEqual(cli.verbose, true, nil)
})

testing.test("equals syntax", lam{ in
    let cli = args.parse({
        port: {type: "number", default: 8080}
    }, ["--port=4000"])
    testing.expectEqual(cli.port, 4000, nil)
})

testing.test("short equals syntax", lam{ in
    let cli = args.parse({
        output: {type: "string", short: "o"}
    }, ["-o=file.txt"])
    testing.expectEqual(cli.output, "file.txt", nil)
})

testing.test("combined bool flags", lam{ in
    let cli = args.parse({
        verbose: {type: "bool", short: "v"},
        force: {type: "bool", short: "f"},
        debug: {type: "bool", short: "d"}
    }, ["-vfd"])
    testing.expectEqual(cli.verbose, true, nil)
    testing.expectEqual(cli.force, true, nil)
    testing.expectEqual(cli.debug, true, nil)
})

testing.test("default values", lam{ in
    let cli = args.parse({
        port: {type: "number", default: 8080},
        host: {type: "string", default: "localhost"},
        verbose: {type: "bool"}
    }, [])
    testing.expectEqual(cli.port, 8080, nil)
    testing.expectEqual(cli.host, "localhost", nil)
    testing.expectEqual(cli.verbose, false, nil)
})

testing.test("positional arguments", lam{ in
    let cli = args.parse({
        verbose: {type: "bool", short: "v"}
    }, ["-v", "file1.txt", "file2.txt"])
    testing.expectEqual(cli.verbose, true, nil)
    testing.expectEqual(cli.args, ["file1.txt", "file2.txt"], nil)
})

testing.test("-- stops flag parsing", lam{ in
    let cli = args.parse({
        verbose: {type: "bool", short: "v"}
    }, ["-v", "--", "--not-a-flag", "file"])
    testing.expectEqual(cli.verbose, true, nil)
    testing.expectEqual(cli.args, ["--not-a-flag", "file"], nil)
})

testing.test("unknown flag throws", lam{ in
    testing.expectThrows(lam{ in
        args.parse({verbose: {type: "bool"}}, ["--unknown"])
    }, nil)
})

testing.test("missing value throws", lam{ in
    testing.expectThrows(lam{ in
        args.parse({port: {type: "number"}}, ["--port"])
    }, nil)
})

// ── Help path (no sys.exit, returns data) ───────────────────────
// Regression: args.parse used to call sys.exit(0) when --help was
// passed, which broke testing, embedding, and reuse. Help is now a
// data result the caller acts on.

testing.test("--help sets help flag and renders helpText", lam{ in
    let cli = args.parse({
        port: {type: "number", short: "p", default: 8080, help: "Port"},
        verbose: {type: "bool", short: "v", help: "Verbose"}
    }, ["--help"])
    testing.expectEqual(cli.help, true, "help flag should be set")
    testing.expect(cli.helpText.contains("--port"), "renders --port option")
    testing.expect(cli.helpText.contains("--verbose"), "renders --verbose option")
    testing.expect(cli.helpText.contains("--help"), "renders --help line")
})

testing.test("-h short form behaves the same", lam{ in
    let cli = args.parse({
        verbose: {type: "bool", help: "Verbose"}
    }, ["-h"])
    testing.expectEqual(cli.help, true, nil)
    testing.expect(cli.helpText.contains("Verbose"), nil)
})

testing.test("--help short-circuits before unknown-flag throw", lam{ in
    // The whole point of asking for help is that you don't know the
    // correct flags yet — failing on a typo before showing usage is
    // hostile. --help wins over later validation.
    let cli = args.parse({
        port: {type: "number", help: "Port"}
    }, ["--help", "--not-a-flag"])
    testing.expectEqual(cli.help, true, nil)
})

testing.test("no help flag when --help absent", lam{ in
    let cli = args.parse({
        port: {type: "number", default: 8080, help: "Port"}
    }, ["--port", "9000"])
    // help is unset (or false-y) on the normal path.
    testing.expect(cli.help == nil || cli.help == false,
                   "help should not be set on the normal path")
    testing.expectEqual(cli.port, 9000, nil)
})

testing.test("renderHelp is pure and idempotent", lam{ in
    let spec = {
        port: {type: "number", short: "p", default: 8080, help: "Port"},
        verbose: {type: "bool", help: "Verbose"}
    }
    let a = args.renderHelp(spec)
    let b = args.renderHelp(spec)
    testing.expectEqual(a, b, "renderHelp must be deterministic")
    testing.expect(a.contains("Options:"), nil)
    testing.expect(a.contains("(default: 8080)"), nil)
})

testing.done()
