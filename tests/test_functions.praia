use "testing"

testing.test("basic function", lam{ in
    func add(a, b) { return a + b }
    testing.expectEqual(add(3, 4), 7, nil)
})

testing.test("default parameters", lam{ in
    func greet(name = "world") { return "hello " + name }
    testing.expectEqual(greet(), "hello world", nil)
    testing.expectEqual(greet("Ada"), "hello Ada", nil)
})

testing.test("default param references earlier param", lam{ in
    func f(a = 1, b = a + 1) { return b }
    testing.expectEqual(f(), 2, nil)
    testing.expectEqual(f(10), 11, nil)
})

testing.test("defaults resolve in definition scope", lam{ in
    let y = 10
    func f(x = y) { return x }
    // Even if called from a scope with a different y, the default uses the definition scope
    testing.expectEqual(f(), 10, nil)
})

testing.test("implicit nil return", lam{ in
    func nothing() {}
    testing.expectEqual(nothing(), nil, nil)
})

testing.test("recursion", lam{ in
    func fib(n) {
        if (n <= 1) { return n }
        return fib(n - 1) + fib(n - 2)
    }
    testing.expectEqual(fib(10), 55, nil)
})

testing.test("closure captures variable", lam{ in
    func makeCounter() {
        let count = 0
        return lam{ in
            count += 1
            return count
        }
    }
    let c = makeCounter()
    testing.expectEqual(c(), 1, nil)
    testing.expectEqual(c(), 2, nil)
    testing.expectEqual(c(), 3, nil)
})

testing.test("lambda with defaults", lam{ in
    let f = lam{ x = 5 in x * 2 }
    testing.expectEqual(f(), 10, nil)
    testing.expectEqual(f(3), 6, nil)
})

testing.test("pipe operator", lam{ in
    func double(x) { return x * 2 }
    func addOne(x) { return x + 1 }
    testing.expectEqual(5 |> double, 10, nil)
    testing.expectEqual(5 |> double |> addOne, 11, nil)
})

testing.test("higher-order: passing functions", lam{ in
    func apply(fn, x) { return fn(x) }
    func square(x) { return x * x }
    testing.expectEqual(apply(square, 5), 25, nil)
    testing.expectEqual(apply(lam{ x in x + 1 }, 10), 11, nil)
})

testing.done()
