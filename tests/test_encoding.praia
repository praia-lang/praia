use "testing"

// Phase 2 of the text/Unicode rework: charset conversions via
// `s.encode(encoding)` and `bytes.decode(b, encoding)`. Supports
// utf-8, utf-16le, utf-16be, latin-1, ascii. Asian legacy encodings
// (Shift-JIS, GBK, etc.) are out of scope.

// ── UTF-8 (identity + validation) ──────────────────────────────

testing.test("utf-8 roundtrip on ASCII", lam{ in
    let s = "hello"
    testing.expectEqual(bytes.decode(s.encode("utf-8"), "utf-8"), s, nil)
    testing.expectEqual(len(s.encode("utf-8").bytes()), 5, nil)
})

testing.test("utf-8 roundtrip on mixed text", lam{ in
    let s = "h\u{E9}llo \u{1F600}"
    let bs = s.encode("utf-8")
    testing.expectEqual(len(bs.bytes()), 11, "1+2+1+1+1+1+1+4 = 11")
    testing.expectEqual(bytes.decode(bs, "utf-8"), s, nil)
})

testing.test("utf-8 decode rejects invalid lead byte", lam{ in
    // 0xC0 followed by ASCII is an invalid (overlong) UTF-8 sequence;
    // 0xFE / 0xFF are reserved.
    testing.expectThrows(lam{ in bytes.decode(bytes.from([0xFE]), "utf-8") },
                         "invalid UTF-8")
})

testing.test("utf-8 decode rejects truncated sequence", lam{ in
    testing.expectThrows(lam{ in bytes.decode(bytes.from([0xC2]), "utf-8") },
                         "truncated")
})

// ── latin-1 (ISO-8859-1) ───────────────────────────────────────

testing.test("latin-1 roundtrip on ASCII", lam{ in
    let s = "hello"
    testing.expectEqual(bytes.decode(s.encode("latin-1"), "latin-1"), s, nil)
})

testing.test("latin-1 keeps each codepoint as a single byte", lam{ in
    // "café" = c (0x63), a (0x61), f (0x66), é (U+00E9 → byte 0xE9).
    let b = "caf\u{E9}".encode("latin-1")
    testing.expectEqual(len(b.bytes()), 4, nil)
    testing.expectEqual(bytes.hex(b), "636166e9", nil)
    testing.expectEqual(bytes.decode(b, "latin-1"), "caf\u{E9}", nil)
})

testing.test("latin-1 rejects codepoints > 0xFF", lam{ in
    testing.expectThrows(lam{ in "\u{0100}".encode("latin-1") },
                         "not encodable in latin-1")
    testing.expectThrows(lam{ in "\u{1F600}".encode("latin-1") },
                         "not encodable in latin-1")
})

testing.test("iso-8859-1 is an alias for latin-1", lam{ in
    testing.expectEqual(bytes.hex("caf\u{E9}".encode("iso-8859-1")),
                        bytes.hex("caf\u{E9}".encode("latin-1")), nil)
})

// ── ascii ──────────────────────────────────────────────────────

testing.test("ascii roundtrip", lam{ in
    let s = "hello, world!"
    testing.expectEqual(bytes.decode(s.encode("ascii"), "ascii"), s, nil)
})

testing.test("ascii rejects codepoints >= 0x80", lam{ in
    testing.expectThrows(lam{ in "caf\u{E9}".encode("ascii") },
                         "not encodable in ASCII")
})

testing.test("ascii decode rejects high bytes", lam{ in
    testing.expectThrows(lam{ in bytes.decode(bytes.from([0x80]), "ascii") },
                         "not valid ASCII")
})

// ── utf-16le / utf-16be ───────────────────────────────────────

testing.test("utf-16le roundtrip BMP", lam{ in
    let s = "hi"
    let b = s.encode("utf-16le")
    // Each ASCII codepoint → 2 bytes little-endian: "hi" → 68 00 69 00.
    testing.expectEqual(bytes.hex(b), "68006900", nil)
    testing.expectEqual(bytes.decode(b, "utf-16le"), s, nil)
})

testing.test("utf-16be roundtrip BMP", lam{ in
    let b = "hi".encode("utf-16be")
    testing.expectEqual(bytes.hex(b), "00680069", nil)
    testing.expectEqual(bytes.decode(b, "utf-16be"), "hi", nil)
})

testing.test("utf-16 surrogate pair for supplementary plane", lam{ in
    // U+1F600 (😀) → surrogate pair D83D DE00.
    let leHex = bytes.hex("\u{1F600}".encode("utf-16le"))
    let beHex = bytes.hex("\u{1F600}".encode("utf-16be"))
    testing.expectEqual(leHex, "3dd800de", "LE: D8 3D, DE 00 (bytes swapped within each unit)")
    testing.expectEqual(beHex, "d83dde00", "BE: D8 3D DE 00")
    // Roundtrip through both.
    testing.expectEqual(bytes.decode("\u{1F600}".encode("utf-16le"), "utf-16le"),
                        "\u{1F600}", nil)
    testing.expectEqual(bytes.decode("\u{1F600}".encode("utf-16be"), "utf-16be"),
                        "\u{1F600}", nil)
})

testing.test("utf-16le rejects odd byte length", lam{ in
    testing.expectThrows(lam{ in bytes.decode(bytes.from([0x68, 0x00, 0x69]), "utf-16le") },
                         "byte length must be even")
})

testing.test("utf-16le rejects truncated surrogate pair", lam{ in
    // High surrogate alone (D8 3D in LE) with nothing after.
    testing.expectThrows(lam{ in bytes.decode(bytes.from([0x3D, 0xD8]), "utf-16le") },
                         "truncated utf-16 surrogate pair")
})

testing.test("utf-16le rejects lone low surrogate", lam{ in
    // Low surrogate without a preceding high surrogate.
    testing.expectThrows(lam{ in bytes.decode(bytes.from([0x00, 0xDC]), "utf-16le") },
                         "unexpected low surrogate")
})

// ── Aliases / name canonicalization ───────────────────────────

testing.test("encoding names ignore case, hyphens, and underscores", lam{ in
    let canonical = "hi".encode("utf-8")
    testing.expectEqual(bytes.hex("hi".encode("UTF-8")), bytes.hex(canonical), nil)
    testing.expectEqual(bytes.hex("hi".encode("utf8")),  bytes.hex(canonical), nil)
    testing.expectEqual(bytes.hex("hi".encode("Utf_8")), bytes.hex(canonical), nil)
})

testing.test("unknown encoding throws with helpful message", lam{ in
    testing.expectThrows(lam{ in "x".encode("klingon") },
                         "unknown encoding")
    testing.expectThrows(lam{ in bytes.decode(bytes.from([0]), "shift-jis") },
                         "unknown encoding")
})

testing.done()
