use "testing"

// Phase 3: file handles via fs.open. The handle is a map of methods
// closing over shared state (fd + read buffer), so all the usual
// stateful-object operations work: read advances position, seek
// resets, close is idempotent, use-after-close throws.

// ── open modes ─────────────────────────────────────────────────

testing.test("fs.open 'w' creates and truncates", lam{ in
    let d = fs.tempDir("p3-open-w")
    let p = d + "/x"
    fs.write(p, "old content")
    let h = fs.open(p, "w")
    h.write("new")
    h.close()
    testing.expectEqual(fs.read(p), "new", "old content was truncated")
    fs.remove(d)
})

testing.test("fs.open 'a' appends", lam{ in
    let d = fs.tempDir("p3-open-a")
    let p = d + "/x"
    fs.write(p, "first ")
    let h = fs.open(p, "a")
    h.write("second")
    h.close()
    testing.expectEqual(fs.read(p), "first second", nil)
    fs.remove(d)
})

testing.test("fs.open 'r' on missing file throws", lam{ in
    testing.expectThrows(lam{ in fs.open("/var/no/such/p3-r/file", "r") },
                         "fs.open()")
})

testing.test("fs.open with invalid mode throws", lam{ in
    let d = fs.tempDir("p3-bad-mode")
    let p = d + "/x"
    fs.write(p, "")
    testing.expectThrows(lam{ in fs.open(p, "rw") }, "invalid mode")
    fs.remove(d)
})

testing.test("handle exposes path and mode", lam{ in
    let d = fs.tempDir("p3-meta")
    let p = d + "/x"
    fs.write(p, "")
    let h = fs.open(p, "r")
    testing.expectEqual(h.path, p, nil)
    testing.expectEqual(h.mode, "r", nil)
    h.close()
    fs.remove(d)
})

// ── read / readLine ───────────────────────────────────────────

testing.test("handle.read returns up to n bytes", lam{ in
    let d = fs.tempDir("p3-read")
    let p = d + "/x"
    fs.write(p, "abcdefghij")
    let h = fs.open(p, "r")
    testing.expectEqual(h.read(3), "abc", nil)
    testing.expectEqual(h.read(4), "defg", nil)
    testing.expectEqual(h.read(100), "hij", "EOF caps the result")
    testing.expectEqual(h.read(100), "", "further reads return ''")
    h.close()
    fs.remove(d)
})

testing.test("handle.readLine yields lines without trailing \\n", lam{ in
    let d = fs.tempDir("p3-readline")
    let p = d + "/log"
    fs.write(p, "alpha\nbeta\ngamma\n")
    let h = fs.open(p, "r")
    testing.expectEqual(h.readLine(), "alpha", nil)
    testing.expectEqual(h.readLine(), "beta", nil)
    testing.expectEqual(h.readLine(), "gamma", nil)
    testing.expectEqual(h.readLine(), nil, "EOF returns nil")
    h.close()
    fs.remove(d)
})

testing.test("handle.readLine returns trailing partial line at EOF", lam{ in
    let d = fs.tempDir("p3-partial")
    let p = d + "/x"
    fs.write(p, "first\nno-newline-end")
    let h = fs.open(p, "r")
    testing.expectEqual(h.readLine(), "first", nil)
    testing.expectEqual(h.readLine(), "no-newline-end",
                        "trailing partial line is returned")
    testing.expectEqual(h.readLine(), nil, nil)
    h.close()
    fs.remove(d)
})

testing.test("read and readLine can be mixed on the same handle", lam{ in
    let d = fs.tempDir("p3-mixed")
    let p = d + "/x"
    fs.write(p, "header\nbody-bytes\n")
    let h = fs.open(p, "r")
    testing.expectEqual(h.readLine(), "header", "consume header line")
    testing.expectEqual(h.read(4), "body", "byte-precise read picks up where readLine left off")
    testing.expectEqual(h.readLine(), "-bytes", "readLine resumes from same place")
    h.close()
    fs.remove(d)
})

// ── seek / tell ───────────────────────────────────────────────

testing.test("handle.seek + tell with string whence", lam{ in
    let d = fs.tempDir("p3-seek")
    let p = d + "/x"
    fs.write(p, "0123456789")
    let h = fs.open(p, "r")
    h.seek(4)
    testing.expectEqual(h.tell(), 4, "default whence is 'start'")
    testing.expectEqual(h.read(2), "45", nil)
    h.seek(-3, "end")
    testing.expectEqual(h.tell(), 7, nil)
    testing.expectEqual(h.read(3), "789", nil)
    h.seek(0, "current")
    testing.expectEqual(h.tell(), 10, "current+0 stays put")
    h.close()
    fs.remove(d)
})

testing.test("tell accounts for unread buffered bytes", lam{ in
    // Bug class: a naive impl would return the kernel position (which
    // is ahead by the 4 KiB readahead), not the user's logical
    // position. After reading exactly 5 bytes from a 20-byte file,
    // tell() must return 5.
    let d = fs.tempDir("p3-tell-buf")
    let p = d + "/x"
    fs.write(p, "0123456789ABCDEFGHIJ")
    let h = fs.open(p, "r")
    h.read(5)
    testing.expectEqual(h.tell(), 5, "logical position is 5")
    h.close()
    fs.remove(d)
})

testing.test("seek invalidates the read buffer", lam{ in
    let d = fs.tempDir("p3-seek-invalidate")
    let p = d + "/x"
    fs.write(p, "abcdefgh")
    let h = fs.open(p, "r")
    h.read(3)         // pulls all 8 bytes into buffer, advances pos to 3
    h.seek(6)
    testing.expectEqual(h.read(2), "gh", "post-seek read pulls from new offset, not stale buffer")
    h.close()
    fs.remove(d)
})

// ── write semantics ───────────────────────────────────────────

testing.test("write on 'r+' updates in place; read/write mix syncs position", lam{ in
    let d = fs.tempDir("p3-rw")
    let p = d + "/x"
    fs.write(p, "AAAABBBBCCCCDDDD")
    let h = fs.open(p, "r+")
    testing.expectEqual(h.read(4), "AAAA", nil)
    h.write("xxxx")
    h.close()
    testing.expectEqual(fs.read(p), "AAAAxxxxCCCCDDDD",
                        "write landed at logical position 4, not kernel-buffered position")
    fs.remove(d)
})

testing.test("write returns bytes written", lam{ in
    let d = fs.tempDir("p3-write-ret")
    let h = fs.open(d + "/x", "w")
    testing.expectEqual(h.write("hello"), 5, nil)
    testing.expectEqual(h.write(""), 0, nil)
    h.close()
    fs.remove(d)
})

// ── close lifecycle ───────────────────────────────────────────

testing.test("close is idempotent", lam{ in
    let d = fs.tempDir("p3-close-twice")
    let h = fs.open(d + "/x", "w")
    h.close()
    h.close()
    testing.expect(true, "second close did not throw")
    fs.remove(d)
})

testing.test("use after close throws", lam{ in
    let d = fs.tempDir("p3-use-after-close")
    let h = fs.open(d + "/x", "w")
    h.close()
    testing.expectThrows(lam{ in h.write("x") }, "FileHandle is closed")
    testing.expectThrows(lam{ in h.read(1)   }, "FileHandle is closed")
    testing.expectThrows(lam{ in h.readLine() }, "FileHandle is closed")
    testing.expectThrows(lam{ in h.seek(0)   }, "FileHandle is closed")
    testing.expectThrows(lam{ in h.tell()    }, "FileHandle is closed")
    testing.expectThrows(lam{ in h.flush()   }, "FileHandle is closed")
    fs.remove(d)
})

// ── flush ─────────────────────────────────────────────────────

testing.test("flush doesn't throw on a freshly written handle", lam{ in
    // We can't easily assert "data is durable on disk" from Praia,
    // but we can at least assert the call doesn't error on a normal
    // path.
    let d = fs.tempDir("p3-flush")
    let h = fs.open(d + "/x", "w")
    h.write("durable")
    h.flush()
    h.close()
    testing.expectEqual(fs.read(d + "/x"), "durable", nil)
    fs.remove(d)
})

testing.done()
