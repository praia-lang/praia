use "testing"

testing.test("construction and printing", lam{ in
    let ok = Ok(42)
    testing.expectEqual(str(ok), "Ok(42)", nil)
    testing.expectEqual(str(Point(1, 2)), "Point(1, 2)", nil)
    testing.expectEqual(str(None()), "None()", nil)
})

testing.test("type is tagged", lam{ in
    testing.expectEqual(type(Ok(1)), "tagged", nil)
})

testing.test("tag and values fields", lam{ in
    let ok = Ok(42)
    testing.expectEqual(ok.tag, "Ok", nil)
    testing.expectEqual(ok.values, [42], nil)
    let pt = Point(1, 2)
    testing.expectEqual(pt.tag, "Point", nil)
    testing.expectEqual(pt.values, [1, 2], nil)
})

testing.test("equality", lam{ in
    testing.expect(Ok(1) == Ok(1), nil)
    testing.expect(Ok(1) != Ok(2), nil)
    testing.expect(Ok(1) != Err(1), nil)
    testing.expect(None() == None(), nil)
    testing.expect(Point(1, 2) == Point(1, 2), nil)
})

testing.test("match single value", lam{ in
    let result = ""
    match (Ok(42)) {
        Ok(val) { result = str(val) }
        Err(msg) { result = msg }
    }
    testing.expectEqual(result, "42", nil)
})

testing.test("match multiple values", lam{ in
    let sum = 0
    match (Point(3, 4)) {
        Point(x, y) { sum = x + y }
    }
    testing.expectEqual(sum, 7, nil)
})

testing.test("match with fallthrough", lam{ in
    let result = ""
    match (Err("oops")) {
        Ok(val) { result = "ok" }
        Err(msg) { result = msg }
    }
    testing.expectEqual(result, "oops", nil)
})

testing.test("match three values", lam{ in
    let r = 0
    match (RGB(10, 20, 30)) {
        RGB(r2, g, b) { r = r2 + g + b }
    }
    testing.expectEqual(r, 60, nil)
})

testing.test("class construction still works", lam{ in
    class Foo {}
    testing.expectEqual(type(Foo()), "instance", nil)
})

testing.done()
