use "testing"

testing.test("class requires func before methods", lam{ in
    // This test verifies the new syntax works
    class Animal {
        func init(name) { this.name = name }
        func speak() { return this.name + " speaks" }
    }
    let a = Animal("Rex")
    testing.expectEqual(a.speak(), "Rex speaks", nil)
})

testing.test("class with default params", lam{ in
    class Config {
        func init(host = "localhost", port = 8080) {
            this.host = host
            this.port = port
        }
    }
    let c1 = Config()
    testing.expectEqual(c1.host, "localhost", nil)
    testing.expectEqual(c1.port, 8080, nil)

    let c2 = Config("0.0.0.0", 3000)
    testing.expectEqual(c2.host, "0.0.0.0", nil)
    testing.expectEqual(c2.port, 3000, nil)
})

testing.test("inheritance with func syntax", lam{ in
    class Base {
        func greet() { return "base" }
    }
    class Child extends Base {
        func greet() { return "child+" + super.greet() }
    }
    testing.expectEqual(Child().greet(), "child+base", nil)
})

testing.test("str() calls toString()", lam{ in
    class Point {
        func init(x, y) { this.x = x; this.y = y }
        func toString() { return "%{this.x},%{this.y}" }
    }
    testing.expectEqual(str(Point(3, 4)), "3,4", nil)
})

testing.test("type() returns int and float", lam{ in
    testing.expectEqual(type(42), "int", nil)
    testing.expectEqual(type(3.14), "float", nil)
    testing.expectEqual(type(0), "int", nil)
    testing.expectEqual(type(7 / 2), "float", nil)
})

testing.test("only nil and false are falsy", lam{ in
    // All non-nil, non-false values are truthy
    testing.expect("", "empty string should be truthy")
    testing.expect("x", "non-empty string should be truthy")
    testing.expect([], "empty array should be truthy")
    testing.expect([0], "non-empty array should be truthy")
    testing.expect(0, "zero should be truthy")
    testing.expect(!nil, "nil should be falsy")
    testing.expect(!false, "false should be falsy")
})

testing.done()
