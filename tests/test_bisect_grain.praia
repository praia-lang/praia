use "testing"
use "bisect"

// Binary search and sorted-list insertion. Mirrors Python's bisect.

// ── left / right insertion points ─────────────────────────────

testing.test("left on a basic ascending array", lam{ in
    let s = [1, 3, 5, 7, 9]
    testing.assertEqual(bisect.left(s, 0), 0, "smaller than all → 0")
    testing.assertEqual(bisect.left(s, 5), 2, "equal to existing → leftmost")
    testing.assertEqual(bisect.left(s, 6), 3, "between elements")
    testing.assertEqual(bisect.left(s, 9), 4, nil)
    testing.assertEqual(bisect.left(s, 100), 5, "larger than all → end")
})

testing.test("right on a basic ascending array", lam{ in
    let s = [1, 3, 5, 7, 9]
    testing.assertEqual(bisect.right(s, 0), 0, nil)
    testing.assertEqual(bisect.right(s, 5), 3, "equal to existing → rightmost")
    testing.assertEqual(bisect.right(s, 6), 3, nil)
    testing.assertEqual(bisect.right(s, 9), 5, nil)
    testing.assertEqual(bisect.right(s, 100), 5, nil)
})

testing.test("left vs right differ only on equal elements", lam{ in
    let s = [1, 3, 3, 3, 5]
    testing.assertEqual(bisect.left(s, 3),  1, "first occurrence of 3")
    testing.assertEqual(bisect.right(s, 3), 4, "one past the last occurrence")
    testing.assertEqual(bisect.right(s, 3) - bisect.left(s, 3), 3,
                        "the run of 3s has length 3 — left/right brackets it")
})

testing.test("left / right on empty array", lam{ in
    testing.assertEqual(bisect.left([], 5),  0, nil)
    testing.assertEqual(bisect.right([], 5), 0, nil)
})

testing.test("left / right on single-element array", lam{ in
    testing.assertEqual(bisect.left([5], 5),  0, nil)
    testing.assertEqual(bisect.right([5], 5), 1, nil)
    testing.assertEqual(bisect.left([5], 3),  0, nil)
    testing.assertEqual(bisect.left([5], 7),  1, nil)
})

// ── keyFn ─────────────────────────────────────────────────────

testing.test("keyFn searches by derived value", lam{ in
    // Sorted by timestamp, but we pass the bare timestamp as `val`.
    let events = [
        {t: 100, msg: "a"},
        {t: 200, msg: "b"},
        {t: 300, msg: "c"},
        {t: 400, msg: "d"}
    ]
    let keyFn = lam{ e in e.t }
    testing.assertEqual(bisect.left(events, 250, keyFn),  2, nil)
    testing.assertEqual(bisect.right(events, 200, keyFn), 2, nil)
    testing.assertEqual(bisect.left(events, 200, keyFn),  1, nil)
})

// ── insort ────────────────────────────────────────────────────

testing.test("insort builds a sorted array from arbitrary inputs", lam{ in
    let xs = []
    for (v in [5, 1, 8, 3, 2, 9, 4, 7, 6]) {
        bisect.insort(xs, v)
    }
    testing.assertEqual(xs, [1, 2, 3, 4, 5, 6, 7, 8, 9], nil)
})

testing.test("insort keeps duplicates and places new at left", lam{ in
    let xs = [1, 3, 5, 7]
    bisect.insort(xs, 3)
    bisect.insort(xs, 3)
    // After two inserts of 3, we should have three 3s starting at
    // index 1 (their leftmost insertion point).
    testing.assertEqual(xs, [1, 3, 3, 3, 5, 7], nil)
})

testing.test("insort with keyFn maintains sort by derived key", lam{ in
    let events = []
    let keyFn = lam{ e in e.t }
    for (e in [{t: 5, m: "e"}, {t: 1, m: "a"}, {t: 3, m: "c"}, {t: 2, m: "b"}, {t: 4, m: "d"}]) {
        bisect.insort(events, e, keyFn)
    }
    // Build a string from sorted msgs to assert order without comparing maps.
    let ms = ""
    for (e in events) { ms = ms + e.m }
    testing.assertEqual(ms, "abcde", nil)
})

testing.test("insort on empty creates a single-element array", lam{ in
    let xs = []
    bisect.insort(xs, 42)
    testing.assertEqual(xs, [42], nil)
})

// ── contains ─────────────────────────────────────────────────

testing.test("contains hits and misses", lam{ in
    let s = [1, 3, 5, 7, 9]
    testing.assertEqual(bisect.contains(s, 5),  true, nil)
    testing.assertEqual(bisect.contains(s, 4),  false, "between elements")
    testing.assertEqual(bisect.contains(s, 0),  false, "smaller than all")
    testing.assertEqual(bisect.contains(s, 99), false, "larger than all")
})

testing.test("contains on duplicates", lam{ in
    let s = [1, 3, 3, 3, 5]
    testing.assertEqual(bisect.contains(s, 3), true, nil)
})

testing.test("contains with keyFn", lam{ in
    let events = [{t: 100}, {t: 200}, {t: 300}]
    let keyFn = lam{ e in e.t }
    testing.assertEqual(bisect.contains(events, 200, keyFn), true,  nil)
    testing.assertEqual(bisect.contains(events, 250, keyFn), false, nil)
})

// ── Big-N correctness ────────────────────────────────────────

testing.test("left/right scale to 10k elements", lam{ in
    let s = []
    for (i in 0..10000) { s.push(i * 2) }   // 0, 2, 4, ..., 19998
    testing.assertEqual(bisect.left(s, 4998),  2499, nil)
    testing.assertEqual(bisect.right(s, 4998), 2500, nil)
    testing.assertEqual(bisect.left(s, 4999),  2500, "between 4998 and 5000")
    testing.assertEqual(bisect.contains(s, 4998), true, nil)
    testing.assertEqual(bisect.contains(s, 4999), false, nil)
})

testing.done()
