use "testing"

testing.test("array destructuring", lam{ in
    let [a, b, c] = [1, 2, 3]
    testing.expectEqual(a, 1, nil)
    testing.expectEqual(b, 2, nil)
    testing.expectEqual(c, 3, nil)
})

testing.test("array rest pattern", lam{ in
    let [first, ...rest] = [1, 2, 3, 4, 5]
    testing.expectEqual(first, 1, nil)
    testing.expectEqual(rest, [2, 3, 4, 5], nil)
})

testing.test("map destructuring", lam{ in
    let {name: n, age: a} = {name: "Ada", age: 36}
    testing.expectEqual(n, "Ada", nil)
    testing.expectEqual(a, 36, nil)
})

testing.test("array spread in literal", lam{ in
    let base = [1, 2]
    let extended = [...base, 3, 4]
    testing.expectEqual(extended, [1, 2, 3, 4], nil)
})

testing.test("map spread in literal", lam{ in
    let base = {a: 1, b: 2}
    let extended = {...base, c: 3}
    testing.expectEqual(extended.a, 1, nil)
    testing.expectEqual(extended.c, 3, nil)
})

testing.test("map spread override", lam{ in
    let defaults = {color: "red", size: 10}
    let custom = {...defaults, color: "blue"}
    testing.expectEqual(custom.color, "blue", nil)
    testing.expectEqual(custom.size, 10, nil)
})

testing.done()
