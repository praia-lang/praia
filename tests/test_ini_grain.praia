use "testing"
use "ini"

testing.test("parse simple", lam{ in
    let data = ini.parse("key=value\nname=Ada")
    testing.expectEqual(data.key, "value", nil)
    testing.expectEqual(data.name, "Ada", nil)
})

testing.test("parse with sections", lam{ in
    let data = ini.parse("[server]\nhost=localhost\nport=8080\n[db]\nname=test")
    testing.expectEqual(data.server.host, "localhost", nil)
    testing.expectEqual(data.server.port, 8080, nil)
    testing.expectEqual(data.db.name, "test", nil)
})

testing.test("parse type conversion", lam{ in
    let data = ini.parse("a=42\nb=3.14\nc=true\nd=false")
    testing.expectEqual(data.a, 42, nil)
    testing.expectEqual(data.b, 3.14, nil)
    testing.expectEqual(data.c, true, nil)
    testing.expectEqual(data.d, false, nil)
})

testing.test("stringify", lam{ in
    let result = ini.stringify({name: "Ada", age: 36})
    testing.expect(result.contains("name"), nil)
    testing.expect(result.contains("Ada"), nil)
    testing.expect(result.contains("36"), nil)
})

testing.test("stringify with sections", lam{ in
    let result = ini.stringify({server: {host: "localhost", port: 8080}})
    testing.expect(result.contains("[server]"), nil)
    testing.expect(result.contains("localhost"), nil)
})

testing.test("quoted values keep embedded comment characters", lam{ in
    let data = ini.parse("[s]\nkey = \"hello # world\"")
    testing.assertEqual(data.s.key, "hello # world", nil)
})

testing.test("quoted value followed by trailing comment", lam{ in
    let data = ini.parse("[s]\nkey = \"hello # world\" # note")
    testing.assertEqual(data.s.key, "hello # world", "embedded # preserved, trailing # stripped")
})

testing.test("unquoted values strip inline comments", lam{ in
    let data = ini.parse("[s]\nkey = bare # comment")
    testing.assertEqual(data.s.key, "bare", nil)
})

testing.done()
