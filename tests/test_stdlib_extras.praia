use "testing"

// ── flatMap ──

testing.test("flatMap expands arrays", lam{ in
    let result = [1, 2, 3] |> flatMap(lam{ x in [x, x * 10] })
    testing.assertEqual(result, [1, 10, 2, 20, 3, 30], nil)
})

testing.test("flatMap with non-array return", lam{ in
    let result = [1, 2, 3] |> flatMap(lam{ x in x * 2 })
    testing.assertEqual(result, [2, 4, 6], nil)
})

testing.test("flatMap empty inner arrays", lam{ in
    let result = [1, 2, 3] |> flatMap(lam{ x in [] })
    testing.assertEqual(result, [], nil)
})

// ── unique ──

testing.test("unique removes duplicates", lam{ in
    testing.assertEqual([1, 2, 2, 3, 1] |> unique, [1, 2, 3], nil)
})

testing.test("unique preserves order", lam{ in
    testing.assertEqual([3, 1, 2, 1, 3] |> unique, [3, 1, 2], nil)
})

testing.test("unique with strings", lam{ in
    testing.assertEqual(["a", "b", "a", "c"] |> unique, ["a", "b", "c"], nil)
})

testing.test("unique empty array", lam{ in
    testing.assertEqual([] |> unique, [], nil)
})

// ── zip ──

testing.test("zip two arrays", lam{ in
    let result = zip(["a", "b", "c"], [1, 2, 3])
    testing.assertEqual(len(result), 3, nil)
    testing.assertEqual(result[0], ["a", 1], nil)
    testing.assertEqual(result[2], ["c", 3], nil)
})

testing.test("zip unequal lengths truncates", lam{ in
    let result = zip([1, 2], [10, 20, 30])
    testing.assertEqual(len(result), 2, nil)
})

testing.test("zip empty", lam{ in
    testing.assertEqual(zip([], [1, 2]), [], nil)
})

// ── enumerate ──

testing.test("enumerate returns index-value pairs", lam{ in
    let result = enumerate(["a", "b", "c"])
    testing.assertEqual(result[0], [0, "a"], nil)
    testing.assertEqual(result[1], [1, "b"], nil)
    testing.assertEqual(result[2], [2, "c"], nil)
})

testing.test("enumerate empty", lam{ in
    testing.assertEqual(enumerate([]), [], nil)
})

testing.test("enumerate in pipe chain", lam{ in
    let result = ["x", "y"] |> enumerate |> map(lam{ pair in "%{pair[0]}:%{pair[1]}" })
    testing.assertEqual(result, ["0:x", "1:y"], nil)
})

// ── math.atan2 ──

testing.test("atan2", lam{ in
    testing.assert(math.approx(math.atan2(1, 1), math.PI / 4), nil)
    testing.assert(math.approx(math.atan2(0, 1), 0), nil)
    testing.assert(math.approx(math.atan2(1, 0), math.PI / 2), nil)
})

// ── math.isNan / math.isInf ──

testing.test("isNan", lam{ in
    testing.assert(math.isNan(math.INF - math.INF), "INF - INF is NaN")
    testing.assert(!math.isNan(1), nil)
    testing.assert(!math.isNan(0), nil)
    testing.assert(!math.isNan("hello"), "non-number returns false")
})

testing.test("isInf", lam{ in
    testing.assert(math.isInf(math.INF), nil)
    testing.assert(math.isInf(-math.INF), nil)
    testing.assert(!math.isInf(1), nil)
    testing.assert(!math.isInf(0), nil)
    testing.assert(!math.isInf("hello"), "non-number returns false")
})

testing.done()
