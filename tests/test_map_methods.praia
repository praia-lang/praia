use "testing"

// ── .has() ──

testing.test("has returns true for existing key", lam{ in
    let m = {a: 1, b: 2}
    testing.expect(m.has("a"), nil)
    testing.expect(m.has("b"), nil)
})

testing.test("has returns false for missing key", lam{ in
    let m = {a: 1}
    testing.expect(!m.has("z"), nil)
    testing.expect(!m.has(""), nil)
})

testing.test("has with non-string keys", lam{ in
    let m = {[1]: "one", [true]: "yes"}
    testing.expect(m.has(1), nil)
    testing.expect(m.has(true), nil)
    testing.expect(!m.has(2), nil)
})

testing.test("has on empty map", lam{ in
    testing.expect(!({}).has("anything"), nil)
})

testing.test("has with nil value", lam{ in
    let m = {a: nil}
    testing.expect(m.has("a"), "key exists even if value is nil")
})

// ── .get() ──

testing.test("get returns value for existing key", lam{ in
    let m = {a: 1, b: "hello"}
    testing.expectEqual(m.get("a"), 1, nil)
    testing.expectEqual(m.get("b"), "hello", nil)
})

testing.test("get returns nil for missing key", lam{ in
    testing.expectEqual({a: 1}.get("z"), nil, nil)
})

testing.test("get returns default for missing key", lam{ in
    testing.expectEqual({a: 1}.get("z", 99), 99, nil)
    testing.expectEqual({a: 1}.get("z", "default"), "default", nil)
})

testing.test("get returns value not default when key exists", lam{ in
    testing.expectEqual({a: 1}.get("a", 99), 1, "should return value, not default")
})

testing.test("get with nil value returns nil not default", lam{ in
    testing.expectEqual({a: nil}.get("a", 99), nil, "nil value is still a value")
})

testing.test("get with non-string keys", lam{ in
    let m = {[42]: "answer"}
    testing.expectEqual(m.get(42), "answer", nil)
    testing.expectEqual(m.get(43, "nope"), "nope", nil)
})

// ── shadowing ──

testing.test("map key named 'has' shadows method", lam{ in
    let m = {has: 42}
    testing.expectEqual(m.has, 42, nil)
})

testing.test("map key named 'get' shadows method", lam{ in
    let m = {get: "value"}
    testing.expectEqual(m.get, "value", nil)
})

testing.test("trailing comma in map literal is accepted", lam{ in
    let m = {x: 1, y: 2,}
    testing.expectEqual(m.x, 1, nil)
    testing.expectEqual(m.y, 2, nil)
    testing.expectEqual(len(m), 2, "trailing comma does not add a key")

    let single = {only: "yes",}
    testing.expectEqual(single.only, "yes", nil)
})

testing.test("trailing comma in array literal is accepted", lam{ in
    let a = [1, 2, 3,]
    testing.expectEqual(len(a), 3, "trailing comma does not add an element")
    testing.expectEqual(a[2], 3, nil)

    let single = [42,]
    testing.expectEqual(len(single), 1, nil)
})

testing.done()
