use "testing"
use "session"

// Regression: session.generateId used to mix random.float() (Mersenne
// Twister, predictable after a handful of outputs) with time.now() and
// hash the result. Now it pulls 256 bits straight from
// crypto.randomBytes (the OS CSPRNG) and hex-encodes them.

testing.test("session.generateId is 64 hex chars", lam{ in
    let id = session.generateId()
    testing.assertEqual(len(id), 64, "32 bytes = 64 hex chars")
    // Every char must be a lowercase hex digit.
    for (i in 0..len(id)) {
        let c = id[i]
        testing.assert("0123456789abcdef".contains(c),
                       "non-hex char at " + i + ": " + c)
    }
})

testing.test("session.generateId outputs are unique", lam{ in
    // Birthday-paradox collision in a 256-bit space is astronomically
    // unlikely; ten draws should all differ.
    let seen = {}
    for (i in 0..10) {
        let id = session.generateId()
        testing.assert(!keys(seen).contains(id), "id collision: " + id)
        seen[id] = true
    }
})

// ── Expiry + cleanup (regression) ────────────────────────────

// Drive the middleware directly against fake req/res maps. The middleware
// lambda is `req, next`; we supply a no-op `next` and a synthesized req
// carrying a Cookie header.
func _runReq(mw, cookieHeader) {
    let req = {headers: {cookie: cookieHeader}}
    let res = mw(req, lam{ r in {status: 200, headers: {}} })
    return req
}

// We use a negative maxAge to make every session record already-expired
// at creation. That tests the eviction + sweep paths without any
// wall-clock sleeps (which are slow AND flaky when the test runner has
// other timing-sensitive tests in flight). Sliding-window behaviour is
// verified by inspection — the `_touch` call in the middleware refreshes
// expiresAt on every hit.
testing.test("expired session ID is rejected on the next request", lam{ in
    let sessions = session.create({maxAge: -1})  // born expired
    let mw = sessions.middleware()

    let req1 = _runReq(mw, "")
    let id1 = req1.session.id
    testing.assert(len(id1) > 0, "first request was assigned a session ID")

    // Replay the cookie. The middleware must NOT resurrect the expired
    // record — an attacker who scraped an old cookie must not be able to
    // bypass server-side timeout by sending it back.
    let req2 = _runReq(mw, "praia.sid=" + id1)
    testing.assert(req2.session.id != id1,
        "expired cookie must NOT resurrect the old session record")
    testing.assertEqual(sessions.count(), 1,
        "stale record was swept; only the fresh session remains")
})

testing.test("sweep prunes stale records on each request", lam{ in
    // Three already-expired sessions, then a fourth request triggers
    // the sweep — count must drop to 1 (only the freshly-minted one).
    let sessions = session.create({maxAge: -1})
    let mw = sessions.middleware()
    _runReq(mw, "")
    _runReq(mw, "")
    _runReq(mw, "")
    _runReq(mw, "")
    testing.assertEqual(sessions.count(), 1,
        "expired records evicted by the per-request sweep")
})

testing.done()
