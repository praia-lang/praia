use "testing"

// Modern memory-hard password KDFs: scrypt (RFC 7914) and argon2id
// (RFC 9106). Both return self-describing PHC strings that carry
// algorithm + cost parameters, so a stored hash can be verified
// without any side-table metadata.
//
// These tests deliberately use small cost parameters so the suite
// runs fast. Real applications should use the function defaults
// (which target ~250 ms per call on a modest server).

// ── scrypt PHC roundtrip ──────────────────────────────────────

testing.test("scrypt produces a recognizable PHC string", lam{ in
    let h = crypto.scrypt("password", {ln: 10, r: 8, p: 1, length: 32})
    testing.assert(h.startsWith("$scrypt$"), "PHC starts with $scrypt$")
    testing.assert(h.contains("ln=10"), "ln param visible in PHC")
    testing.assert(h.contains("r=8"), nil)
    testing.assert(h.contains("p=1"), nil)
    // Format: $scrypt$ln=...,r=...,p=...$<salt>$<hash>  → 4 segments
    // after the leading empty (from initial $). split() returns 5.
    testing.assertEqual(len(h.split("$")), 5, "PHC has 5 $-delimited parts")
})

testing.test("scrypt verify accepts the original password", lam{ in
    let h = crypto.scrypt("hunter2", {ln: 10})
    testing.assertEqual(crypto.verifyScrypt("hunter2", h), true, nil)
})

testing.test("scrypt verify rejects the wrong password", lam{ in
    let h = crypto.scrypt("hunter2", {ln: 10})
    testing.assertEqual(crypto.verifyScrypt("hunter3", h), false, nil)
    testing.assertEqual(crypto.verifyScrypt("",        h), false, nil)
})

testing.test("scrypt salt defaults to 16 random bytes (two hashes differ)", lam{ in
    let h1 = crypto.scrypt("same", {ln: 10})
    let h2 = crypto.scrypt("same", {ln: 10})
    testing.assert(h1 != h2, "fresh salt makes the hashes distinct")
})

testing.test("scrypt with explicit salt is deterministic", lam{ in
    let salt = bytes.fromHex("0011223344556677")
    let h1 = crypto.scrypt("pw", {ln: 10, salt: salt})
    let h2 = crypto.scrypt("pw", {ln: 10, salt: salt})
    testing.assertEqual(h1, h2, "same salt + same pw → same PHC")
})

testing.test("scrypt rejects too-short salt", lam{ in
    testing.assertThrows(
        lam{ in crypto.scrypt("pw", {salt: "short"}) },
        "at least 8 bytes")
})

testing.test("scrypt rejects ln out of range", lam{ in
    testing.assertThrows(
        lam{ in crypto.scrypt("pw", {ln: 0}) },
        "must be in")
    testing.assertThrows(
        lam{ in crypto.scrypt("pw", {ln: 100}) },
        "must be in")
})

// ── argon2id PHC roundtrip ────────────────────────────────────

testing.test("argon2id produces a recognizable PHC string", lam{ in
    let h = crypto.argon2id("password", {t: 1, m: 64, p: 1, length: 32})
    testing.assert(h.startsWith("$argon2id$"), nil)
    testing.assert(h.contains("v=19"), "Argon2 v=19 segment present")
    testing.assert(h.contains("m=64"), nil)
    testing.assert(h.contains("t=1"), nil)
    testing.assert(h.contains("p=1"), nil)
})

testing.test("argon2id verify accepts the original password", lam{ in
    let h = crypto.argon2id("hunter2", {t: 1, m: 64, p: 1})
    testing.assertEqual(crypto.verifyArgon2id("hunter2", h), true, nil)
})

testing.test("argon2id verify rejects the wrong password", lam{ in
    let h = crypto.argon2id("hunter2", {t: 1, m: 64, p: 1})
    testing.assertEqual(crypto.verifyArgon2id("wrong", h), false, nil)
})

testing.test("argon2id salt defaults to 16 random bytes", lam{ in
    let h1 = crypto.argon2id("same", {t: 1, m: 64, p: 1})
    let h2 = crypto.argon2id("same", {t: 1, m: 64, p: 1})
    testing.assert(h1 != h2, nil)
})

testing.test("argon2id with explicit salt is deterministic", lam{ in
    let salt = bytes.fromHex("0011223344556677")
    let h1 = crypto.argon2id("pw", {t: 1, m: 64, p: 1, salt: salt})
    let h2 = crypto.argon2id("pw", {t: 1, m: 64, p: 1, salt: salt})
    testing.assertEqual(h1, h2, nil)
})

testing.test("argon2id rejects m < 8 * p", lam{ in
    // RFC 9106 §3.1: memory must be at least 8 KiB per lane.
    testing.assertThrows(
        lam{ in crypto.argon2id("pw", {t: 1, m: 8, p: 4}) },
        ">= 8 * p")
})

testing.test("argon2id custom length yields longer hash bytes", lam{ in
    // The hash segment length grows with `length`. PHC base64 expands
    // by ~4/3, so a 64-byte hash → ~86 base64 chars; a 32-byte hash
    // → ~43. Strict equality wouldn't be robust to base64 padding so
    // we just assert ordering.
    let short = crypto.argon2id("pw", {t: 1, m: 64, p: 1, length: 16})
    let long  = crypto.argon2id("pw", {t: 1, m: 64, p: 1, length: 64})
    testing.assert(len(long) > len(short),
                   "64-byte output produces a longer PHC than 16-byte")
})

// ── PHC parsing (verifier robustness) ─────────────────────────

testing.test("verifyScrypt rejects algorithm mismatch", lam{ in
    let argonHash = crypto.argon2id("pw", {t: 1, m: 64, p: 1})
    testing.assertThrows(
        lam{ in crypto.verifyScrypt("pw", argonHash) },
        "expected 'scrypt'")
})

testing.test("verifyArgon2id rejects algorithm mismatch", lam{ in
    let scryptHash = crypto.scrypt("pw", {ln: 10})
    testing.assertThrows(
        lam{ in crypto.verifyArgon2id("pw", scryptHash) },
        "expected 'argon2id'")
})

testing.test("PHC missing leading $ is rejected", lam{ in
    testing.assertThrows(
        lam{ in crypto.verifyArgon2id("pw", "argon2id$v=19$...") },
        "must start with")
})

testing.test("PHC with garbled base64 is rejected", lam{ in
    // Stuff a `*` (not in the base64 alphabet) into the salt.
    let h = crypto.scrypt("pw", {ln: 10})
    let parts = h.split("$")
    let mangled = "$" + parts[1] + "$" + parts[2] + "$" + parts[3] + "*$" + parts[4]
    testing.assertThrows(
        lam{ in crypto.verifyScrypt("pw", mangled) },
        "invalid base64")
})

testing.test("PHC missing required parameter is rejected", lam{ in
    // Drop the r param from a scrypt PHC.
    testing.assertThrows(
        lam{ in crypto.verifyScrypt("pw", "$scrypt$ln=10,p=1$YWJjZGVmZ2g$AAAA") },
        "required parameter")
})

// ── PHC strictness regressions ────────────────────────────────
// Each of these is an attack vector against lenient parsing: if the
// verifier silently accepts the malformed PHC, the password verifies
// under different (weaker) cost parameters than the generator stored.

testing.test("PHC param with trailing junk is rejected (argon2id m=64x)", lam{ in
    let h = crypto.argon2id("pw", {t: 1, m: 64, p: 1})
    let mangled = h.replace("m=64,", "m=64x,")
    testing.assertThrows(
        lam{ in crypto.verifyArgon2id("pw", mangled) },
        "base-10 integer")
})

testing.test("PHC param with trailing junk is rejected (scrypt ln=10x)", lam{ in
    let h = crypto.scrypt("pw", {ln: 10})
    let mangled = h.replace("ln=10,", "ln=10x,")
    testing.assertThrows(
        lam{ in crypto.verifyScrypt("pw", mangled) },
        "base-10 integer")
})

testing.test("PHC with extra trailing segment is rejected", lam{ in
    let h = crypto.scrypt("pw", {ln: 10})
    testing.assertThrows(
        lam{ in crypto.verifyScrypt("pw", h + "$extra") },
        "expected 4 segments")
})

testing.test("PHC param exceeding uint32 is rejected (argon2id m=2^32+64)", lam{ in
    // Regression: parsed as uint64 then narrowed to uint32, so
    // 4294967360 would wrap to 64 and verify against an m=64 hash.
    let h = crypto.argon2id("pw", {t: 1, m: 64, p: 1})
    let mangled = h.replace("m=64,", "m=4294967360,")
    testing.assertThrows(
        lam{ in crypto.verifyArgon2id("pw", mangled) },
        "out of range")
})

testing.test("PHC param with leading sign is rejected", lam{ in
    let h = crypto.argon2id("pw", {t: 1, m: 64, p: 1})
    let mangled = h.replace("t=1,", "t=+1,")
    testing.assertThrows(
        lam{ in crypto.verifyArgon2id("pw", mangled) },
        "base-10 integer")
})

testing.test("PHC duplicate parameter is rejected", lam{ in
    // Regression: phcParseUint used to return the first match, so an
    // attacker could pair a benign m=8 with a wrap-target m=4294967360
    // and have the verifier silently pick the first.
    let h = crypto.argon2id("pw", {t: 1, m: 64, p: 1})
    let mangled = h.replace("m=64,", "m=64,m=4294967360,")
    testing.assertThrows(
        lam{ in crypto.verifyArgon2id("pw", mangled) },
        "duplicate parameter")
})

testing.test("argon2id PHC without v=NN segment is rejected", lam{ in
    // Regression: an argon2id string with 4 segments (no version)
    // used to parse fine; the spec requires v=NN.
    let bad = "$argon2id$m=64,t=1,p=1$YWJjZGVmZ2g$AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
    testing.assertThrows(
        lam{ in crypto.verifyArgon2id("pw", bad) },
        "5 segments")
})

testing.test("argon2id PHC with unsupported v is rejected", lam{ in
    // Regression: v wasn't validated past "exists" — v=20 (or v=16
    // legacy) used to be folded into params and ignored.
    let h = crypto.argon2id("pw", {t: 1, m: 64, p: 1})
    let mangled = h.replace("v=19", "v=20")
    testing.assertThrows(
        lam{ in crypto.verifyArgon2id("pw", mangled) },
        "unsupported argon2 version")
})

testing.test("scrypt PHC with injected $v=19$ segment is rejected", lam{ in
    // Scrypt doesn't have a version segment; injecting one would
    // previously bump parts.size() to 5 and the parser would treat
    // the real params segment as a version segment.
    let h = crypto.scrypt("pw", {ln: 10})
    let parts = h.split("$")
    let mangled = "$" + parts[1] + "$v=19$" + parts[2] + "$" + parts[3] + "$" + parts[4]
    testing.assertThrows(
        lam{ in crypto.verifyScrypt("pw", mangled) },
        "4 segments")
})

testing.test("scrypt PHC with empty hash segment is rejected", lam{ in
    // Regression: with an empty hash segment the verifier derived
    // zero bytes and ctEqual("", "") matched any password.
    testing.assertThrows(
        lam{ in crypto.verifyScrypt("wrong", "$scrypt$ln=10,r=8,p=1$MTIzNDU2Nzg$") },
        "hash length")
})

testing.test("scrypt PHC with 1-char hash segment is rejected", lam{ in
    // A single base64 char decodes to zero bytes — same bypass as
    // an empty segment, just less obvious.
    testing.assertThrows(
        lam{ in crypto.verifyScrypt("wrong", "$scrypt$ln=10,r=8,p=1$MTIzNDU2Nzg$A") },
        "non-canonical base64")
})

testing.test("scrypt PHC with too-short salt is rejected", lam{ in
    // 4-char b64 → 3-byte salt, below the 8-byte minimum.
    testing.assertThrows(
        lam{ in crypto.verifyScrypt("wrong", "$scrypt$ln=10,r=8,p=1$YWJj$AAAAAAAAAAAAAAAAAAAAAA") },
        "salt must be at least 8 bytes")
})

testing.test("argon2id PHC with empty hash segment is rejected", lam{ in
    testing.assertThrows(
        lam{ in crypto.verifyArgon2id("wrong",
            "$argon2id$v=19$m=64,t=1,p=1$MTIzNDU2Nzg$") },
        "hash length")
})

testing.test("argon2id PHC with too-short salt is rejected", lam{ in
    testing.assertThrows(
        lam{ in crypto.verifyArgon2id("wrong",
            "$argon2id$v=19$m=64,t=1,p=1$YWJj$AAAAAAAAAAAAAAAAAAAAAA") },
        "salt must be at least 8 bytes")
})

testing.test("PHC base64 segment containing '=' is rejected", lam{ in
    // Regression: phcB64Decode used to `break` on '=', so an attacker
    // could splice "=" into the hash segment to truncate decoding —
    // e.g. a 32-byte stored hash collapsed to its 16-byte prefix.
    // The verifier derived outLen = hash.size() = 16, and matched
    // only the prefix, gifting the attacker a 2^128 brute-force win.
    let h = crypto.scrypt("pw", {ln: 10})
    let parts = h.split("$")
    let hashB64 = parts[4]
    let truncated = hashB64.slice(0, 22) + "=" + hashB64.slice(22, len(hashB64))
    let bad = "$" + parts[1] + "$" + parts[2] + "$" + parts[3] + "$" + truncated
    testing.assertThrows(
        lam{ in crypto.verifyScrypt("pw", bad) },
        "invalid base64 character")
})

testing.done()
