use "testing"
use "../sand/grains/git" as gitmod

// Regression: parseSpec used to treat the @ in SCP-style SSH URLs
// (`git@host:user/repo`) as a version pin, leaving the URL part as
// just "git" and the "version" as everything past the @. That broke
// every documented SSH spec form. The fix detects version pins by
// matching a tag-like trailing token, so SSH user@host @ stays put.

testing.test("SCP-style SSH without a version pin", lam{ in
    let r = gitmod.parseSpec("git@github.com:user/repo")
    testing.expectEqual(r.url, "git@github.com:user/repo.git",
        "URL preserved verbatim with .git appended")
    testing.expectEqual(r.name, "repo", nil)
    testing.expectEqual(r.version, nil, "no spurious version pin")
})

testing.test("SCP-style SSH already ending in .git", lam{ in
    let r = gitmod.parseSpec("git@github.com:user/repo.git")
    testing.expectEqual(r.url, "git@github.com:user/repo.git",
        ".git not double-appended")
    testing.expectEqual(r.name, "repo", nil)
    testing.expectEqual(r.version, nil, nil)
})

testing.test("SCP-style SSH with a version pin", lam{ in
    let r = gitmod.parseSpec("git@github.com:user/repo@v1.2.3")
    testing.expectEqual(r.url, "git@github.com:user/repo.git",
        "version stripped from URL")
    testing.expectEqual(r.version, "v1.2.3",
        "tag-like suffix recognized as the pin")
    testing.expectEqual(r.name, "repo", nil)
})

testing.test("ssh:// URL with user", lam{ in
    let r = gitmod.parseSpec("ssh://git@github.com/user/repo")
    testing.expectEqual(r.url, "ssh://git@github.com/user/repo.git", nil)
    testing.expectEqual(r.name, "repo", nil)
    testing.expectEqual(r.version, nil,
        "ssh:// user@host @ isn't mistaken for a version separator")
})

testing.test("ssh:// URL with user and version pin", lam{ in
    let r = gitmod.parseSpec("ssh://git@github.com/user/repo@v2")
    testing.expectEqual(r.url, "ssh://git@github.com/user/repo.git", nil)
    testing.expectEqual(r.version, "v2", nil)
})

testing.test("regression hold: previously-working https forms still parse", lam{ in
    let cases = [
        ["https://github.com/user/repo", "https://github.com/user/repo.git", nil, "repo"],
        ["https://github.com/user/repo@v1.2", "https://github.com/user/repo.git", "v1.2", "repo"],
        ["github.com/user/repo", "https://github.com/user/repo.git", nil, "repo"],
        ["github.com/user/repo@v1.2", "https://github.com/user/repo.git", "v1.2", "repo"],
        ["praia-lang/sand", "https://praia-lang/sand.git", nil, "sand"],
        ["file:///tmp/repo", "file:///tmp/repo", nil, "repo"],
        ["file:///tmp/repo@v1", "file:///tmp/repo", "v1", "repo"],
    ]
    for (c in cases) {
        let r = gitmod.parseSpec(c[0])
        testing.expectEqual(r.url,     c[1], "url for " + c[0])
        testing.expectEqual(r.version, c[2], "version for " + c[0])
        testing.expectEqual(r.name,    c[3], "name for " + c[0])
    }
})

testing.test("multi-segment branch name in pin is rejected (use SHA or tag)", lam{ in
    // The new "tag-like trailing token" rule excludes `/` in version
    // pins, so `feature/x` doesn't get interpreted as a version. The
    // whole spec falls through as-is (no split), and the validator
    // downstream rejects the resulting URL with an embedded `/`. The
    // user-visible effect: a clearer "Invalid grain URL" error rather
    // than a confusing "Invalid grain version".
    let r = gitmod.parseSpec("github.com/user/repo@feature/x")
    // No version split — everything past the @ stays in the URL,
    // which won't be a valid clone target but isn't the security
    // surprise the old code produced.
    testing.expectEqual(r.version, nil,
        "branch-with-/ does not silently parse as version")
    // And the @feature/x suffix is preserved in the URL — the spec
    // falls through whole instead of getting carved up. That's what
    // makes the later "Invalid grain URL" error clearer than the old
    // "Invalid grain version" misdiagnosis.
    testing.expect(r.url.contains("@feature/x"),
        "URL still carries the @feature/x suffix verbatim: " + r.url)
})

testing.done()
