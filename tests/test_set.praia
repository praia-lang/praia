use "testing"

// `#{...}` set literals + the set value type. Runs on both engines
// (VM and tree-walker) so any divergence in OP_BUILD_SET vs the
// interpreter's SetLiteral path surfaces here.

// ── Literal parsing ────────────────────────────────────────────

testing.test("set literal: dedup on construction", lam{ in
    let s = #{1, 2, 3, 2, 1}
    testing.expectEqual(len(s), 3, "duplicate inserts collapse")
    testing.expect(s.has(1), nil)
    testing.expect(s.has(2), nil)
    testing.expect(s.has(3), nil)
})

testing.test("empty set literal", lam{ in
    let s = #{}
    testing.expectEqual(len(s), 0, nil)
    testing.expectEqual(type(s), "set", "type() reports 'set'")
})

testing.test("set literal: trailing comma allowed", lam{ in
    let s = #{1, 2, 3,}
    testing.expectEqual(len(s), 3, nil)
})

testing.test("set literal: mixed primitive types", lam{ in
    let s = #{1, "two", true, nil, 3.14}
    testing.expectEqual(len(s), 5, nil)
    testing.expect(s.has("two"), nil)
    testing.expect(s.has(true), nil)
    testing.expect(s.has(nil), nil)
})

testing.test("set literal: expressions are evaluated", lam{ in
    let x = 5
    let s = #{x, x + 1, x * 2}
    testing.expectEqual(len(s), 3, nil)
    testing.expect(s.has(5), nil)
    testing.expect(s.has(6), nil)
    testing.expect(s.has(10), nil)
})

testing.test("set literal: unhashable element rejected", lam{ in
    testing.expectThrows(
        lam{ in #{[1, 2]} },
        "arrays aren't hashable, so they can't be set elements")
})

// ── Spread in set literals ────────────────────────────────────
//
// Regression: the VM compiler used to throw at compile time on any
// spread inside #{...}, which propagated as an uncaught RuntimeError
// and aborted the process. Spread is now lowered to an OP_BUILD_SET 0
// accumulator followed by per-element OP_SET_INSERT / OP_SET_SPREAD
// instructions — one allocation total, every operation mutates the
// accumulator in place.

testing.test("set literal: spread another set", lam{ in
    let a = #{1, 2}
    let s = #{0, ...a}
    testing.expectEqual(s, #{0, 1, 2}, nil)
})

testing.test("set literal: spread an array", lam{ in
    let s = #{0, ...[1, 2, 3]}
    testing.expectEqual(s, #{0, 1, 2, 3}, nil)
})

testing.test("set literal: multiple spreads interleaved with literals", lam{ in
    let a = #{1, 2}
    let b = #{4, 5}
    testing.expectEqual(#{0, ...a, 3, ...b}, #{0, 1, 2, 3, 4, 5}, nil)
})

testing.test("set literal: pure spread (no static elements)", lam{ in
    let a = #{1, 2}
    testing.expectEqual(#{...a}, a, "spread of set roundtrips")
})

testing.test("set literal: spread dedups against static elements", lam{ in
    // 1 is in both the spread and the literal — set semantics dedup.
    testing.expectEqual(#{1, ...#{1, 2}}, #{1, 2}, nil)
})

testing.test("set + set = union", lam{ in
    testing.expectEqual(#{1, 2} + #{3, 4}, #{1, 2, 3, 4}, nil)
    testing.expectEqual(#{1, 2} + #{2, 3}, #{1, 2, 3}, "overlapping deduped")
    testing.expectEqual(#{} + #{1}, #{1}, nil)
})

testing.test("spread accumulator mutates in place across interleaved batches", lam{ in
    // Regression: the VM lowering used to flush each batch of static
    // elements via OP_BUILD_SET + OP_ADD (a fresh union), which
    // copied the accumulator at every batch boundary. The new
    // lowering uses OP_SET_INSERT / OP_SET_SPREAD against a single
    // accumulator allocated by OP_BUILD_SET 0 — verify a heavily
    // interleaved literal still produces the right set without any
    // missing elements or duplicates leaking through.
    let a = #{10, 11}
    let b = #{20, 21}
    let c = #{30, 31}
    let r = #{0, ...a, 1, ...b, 2, ...c, 3}
    testing.expectEqual(r, #{0, 1, 2, 3, 10, 11, 20, 21, 30, 31}, nil)
})

testing.test("set spread doesn't go through a name-resolvable global", lam{ in
    // Regression: the VM used to lower `#{...other}` to
    // `OP_GET_GLOBAL __toSet + OP_CALL + OP_ADD`. A user defining
    // `let __toSet = ...` could then silently change set-literal
    // semantics on VM while tree-walker stayed correct. The fix is
    // a dedicated OP_SET_SPREAD opcode that operates directly on
    // the stack — no name lookup involved.
    let __toSet = lam{ x in #{9999} }
    testing.expectEqual(#{...#{1, 2}}, #{1, 2},
                        "spread ignores user-defined __toSet")
    testing.expectEqual(#{0, ...[1, 2]}, #{0, 1, 2},
                        "array spread also ignores user-defined __toSet")
})

// ── Equality ──────────────────────────────────────────────────

testing.test("set equality: order-independent", lam{ in
    testing.expectEqual(#{1, 2, 3}, #{3, 2, 1}, "same elements, any order")
    testing.expectEqual(#{}, #{}, "empty sets are equal")
})

testing.test("set inequality: different elements", lam{ in
    testing.expectNotEqual(#{1, 2}, #{1, 2, 3}, nil)
    testing.expectNotEqual(#{1, 2}, #{1, 3}, nil)
})

testing.test("set vs map are not equal", lam{ in
    testing.expectNotEqual(#{1, 2}, {[1]: true, [2]: true}, "different types")
})

// ── Mutating methods ──────────────────────────────────────────

testing.test("set.add returns true for new, false for existing", lam{ in
    let s = #{1, 2}
    testing.expectEqual(s.add(3), true, "new element returns true")
    testing.expectEqual(s.add(1), false, "existing element returns false")
    testing.expectEqual(len(s), 3, nil)
})

testing.test("set.remove returns true if present, false otherwise", lam{ in
    let s = #{1, 2, 3}
    testing.expectEqual(s.remove(2), true, nil)
    testing.expectEqual(s.remove(99), false, "absent returns false")
    testing.expectEqual(len(s), 2, nil)
    testing.expect(!s.has(2), nil)
})

testing.test("set.clear empties the set", lam{ in
    let s = #{1, 2, 3}
    s.clear()
    testing.expectEqual(len(s), 0, nil)
    testing.expect(!s.has(1), nil)
})

testing.test("set.add rejects unhashable", lam{ in
    let s = #{}
    testing.expectThrows(lam{ in s.add([1, 2]) }, "array unhashable")
})

// ── Read methods ──────────────────────────────────────────────

testing.test("set.size matches len()", lam{ in
    let s = #{1, 2, 3, 4}
    testing.expectEqual(s.size(), len(s), nil)
})

testing.test("set.toArray returns all elements", lam{ in
    let s = #{1, 2, 3}
    let arr = s.toArray()
    testing.expectEqual(type(arr), "array", nil)
    testing.expectEqual(len(arr), 3, nil)
    // Order is unspecified — sort for deterministic comparison.
    let sorted = arr.sorted()
    testing.expectEqual(sorted, [1, 2, 3], nil)
})

testing.test("set.clone produces an independent copy", lam{ in
    let s = #{1, 2, 3}
    let c = s.clone()
    c.add(99)
    testing.expect(!s.has(99), "original not mutated")
    testing.expectEqual(len(s), 3, nil)
    testing.expectEqual(len(c), 4, nil)
})

// ── Set algebra ───────────────────────────────────────────────

testing.test("set.union", lam{ in
    let a = #{1, 2, 3}
    let b = #{3, 4, 5}
    testing.expectEqual(a.union(b), #{1, 2, 3, 4, 5}, nil)
    // Both operands unmodified.
    testing.expectEqual(a, #{1, 2, 3}, nil)
    testing.expectEqual(b, #{3, 4, 5}, nil)
})

testing.test("set.intersection", lam{ in
    let a = #{1, 2, 3}
    let b = #{2, 3, 4}
    testing.expectEqual(a.intersection(b), #{2, 3}, nil)
    testing.expectEqual(#{1, 2}.intersection(#{3, 4}), #{}, "disjoint sets give empty")
})

testing.test("set.difference", lam{ in
    let a = #{1, 2, 3}
    let b = #{2, 3, 4}
    testing.expectEqual(a.difference(b), #{1}, nil)
    testing.expectEqual(b.difference(a), #{4}, "not commutative")
})

testing.test("set.isSubset", lam{ in
    testing.expectEqual(#{1, 2}.isSubset(#{1, 2, 3}), true, nil)
    testing.expectEqual(#{1, 2, 3}.isSubset(#{1, 2}), false, nil)
    testing.expectEqual(#{}.isSubset(#{1, 2, 3}), true, "empty is subset of everything")
    testing.expectEqual(#{1, 2}.isSubset(#{1, 2}), true, "set is subset of itself")
})

testing.test("set.union rejects non-set arg", lam{ in
    testing.expectThrows(lam{ in #{1}.union([1, 2]) }, "argument must be a set")
})

// ── for-in iteration ──────────────────────────────────────────

testing.test("for-in over a set visits each element exactly once", lam{ in
    let s = #{10, 20, 30}
    let seen = []
    for (x in s) { seen.push(x) }
    testing.expectEqual(len(seen), 3, nil)
    // Order is unspecified — sort for comparison.
    testing.expectEqual(seen.sorted(), [10, 20, 30], nil)
})

testing.test("for-in over empty set is a no-op", lam{ in
    let count = 0
    for (x in #{}) { count = count + 1 }
    testing.expectEqual(count, 0, nil)
})

// ── toString rendering ───────────────────────────────────────

testing.test("set.toString uses #{...} syntax", lam{ in
    let s = #{1}
    testing.expectEqual(s.toString(), "#{1}", nil)
})

testing.test("empty set renders as #{}", lam{ in
    testing.expectEqual(#{}.toString(), "#{}", nil)
})

// ── Type introspection + parser lookahead ────────────────────

testing.test("`value is \"set\"` works on both engines", lam{ in
    // Regression: VM and tree-walker each had their own checkIs
    // implementations; neither initially knew about the new
    // PraiaSet type, so `#{1, 2} is "set"` threw "Unknown type
    // name 'set'" under the VM.
    testing.expectEqual(#{1, 2} is "set", true, nil)
    testing.expectEqual([1, 2] is "set", false, "array isn't a set")
    testing.expectEqual({a: 1} is "set", false, "map isn't a set")
    testing.expectEqual(nil is "set", false, nil)
})

testing.test("set literal usable in return / yield position", lam{ in
    // Regression: ReturnStmt's "can next token start an expression?"
    // lookahead listed LBRACE but not HASH_LBRACE, so `return #{...}`
    // produced an empty return + parse error on the trailing literal.
    func mkSet() { return #{1, 2, 3} }
    testing.expectEqual(mkSet(), #{1, 2, 3}, nil)
})

testing.test("set literal inside lambda body doesn't confuse hasIn scan", lam{ in
    // Regression: the lambda's `hasIn` scan tracked brace depth via
    // LBRACE only. A set literal inside the body opens via HASH_LBRACE
    // and closes with RBRACE — without the fix, the closing brace
    // of #{...} prematurely closed the lambda.
    let f = lam{ x in
        let s = #{1, 2, 3}
        return s.has(x)
    }
    testing.expectEqual(f(2), true, nil)
    testing.expectEqual(f(9), false, nil)
})

testing.test("shebang lines still work, including with #{...} in the body", lam{ in
    // Regression sentinel: the lexer's `case '#':` for set literals
    // mustn't break the existing shebang skip. The skip happens
    // BEFORE tokenization, gated on `source[0..1] == "#!"`, so plain
    // `#{...}` at the start of a file is correctly tokenized as a
    // set literal, and a real shebang is correctly skipped — but it
    // would be easy for a future refactor to break either path.
    let praiaBin = path.join(sys.cwd(), "praia")
    let f = sys.exec(["mktemp", "/tmp/praia-shebang-test.XXXXXX"]).stdout.strip()
    // Plain shebang + set literal in the body.
    fs.write(f, "#!/usr/bin/env praia\nprint(#{1, 2, 3})\n")
    let r = sys.exec([praiaBin, f])
    testing.expectEqual(r.exitCode, 0, "shebang script ran: " + r.stderr)
    testing.expect(r.stdout.contains("#{"), "output is a set: " + r.stdout)

    // Mid-file `#!` should NOT be treated as a shebang and should
    // produce a lex error (the friendly "did you mean '#{'" hint).
    fs.write(f, "let x = 1\n#! not a shebang\n")
    let r2 = sys.exec([praiaBin, f])
    testing.expectNotEqual(r2.exitCode, 0, "mid-file #! rejected")
    testing.expect(r2.stderr.contains("Unexpected character '#'"),
                    "lexer error: " + r2.stderr)

    sys.exec(["rm", "-f", f])
})

testing.done()
