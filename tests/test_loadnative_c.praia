use "testing"

// Exercises the praia_plugin_c.h facade through the pure-C example
// plugin at examples/plugins/cmod.c. Each test covers one shape:
// string round-trip, integer ops + arg-count validation, error
// throwing, external handles with a deleter, and map construction.

let ext = ".dylib"
if (sys.platform != "darwin") {
    ext = ".so"
}

let pluginPath = "examples/plugins/cmod" + ext

if (!fs.exists(pluginPath)) {
    // Mirror the skip pattern in test_loadnative.praia so CI / a
    // fresh checkout doesn't fail just because the plugin hasn't
    // been compiled yet. `-undefined dynamic_lookup` is macOS-only;
    // GNU ld on Linux doesn't understand it and a copy-paste of the
    // hint would fail. Emit the flag only where it's needed.
    print("Skipping C-facade tests — plugin not built")
    if (sys.platform == "darwin") {
        print("Build with: gcc -std=c11 -shared -fPIC -I$(praia --include-path) \\")
        print("            -undefined dynamic_lookup -o examples/plugins/cmod" + ext + " examples/plugins/cmod.c")
    } else {
        print("Build with: gcc -std=c11 -shared -fPIC -I$(praia --include-path) \\")
        print("            -o examples/plugins/cmod" + ext + " examples/plugins/cmod.c")
    }
    testing.done()
}

let cmod = loadNative(pluginPath)

testing.test("C facade: _meta is populated from PRAIA_C_PLUGIN_METADATA", lam{ in
    testing.assertEqual(cmod._meta.name, "cmod", nil)
    testing.assertEqual(cmod._meta.version, "0.1.0", nil)
    testing.assert(cmod._meta.description.contains("Pure-C"),
                   "description survives the macro round-trip")
})

testing.test("C facade: string round-trip via praia_value_string/as_string", lam{ in
    testing.assertEqual(cmod.greet("world"), "hello, world", nil)
    testing.assertEqual(cmod.greet("Viggo"), "hello, Viggo", nil)
})

testing.test("C facade: integer ops + arg-count validation", lam{ in
    testing.assertEqual(cmod.add(2, 3), 5, nil)
    testing.assertEqual(cmod.add(-100, 50), -50, nil)
})

testing.test("C facade: praia_throw surfaces as a RuntimeError on the engine side", lam{ in
    let caught = nil
    try { cmod.boom() } catch (e) { caught = str(e) }
    testing.assert(caught != nil, "boom should throw")
    testing.assert(caught.contains("deliberate"),
                   "thrown message round-trips: %{caught}")
})

testing.test("C facade: native that returns NULL without praia_throw still throws", lam{ in
    // cmod.add with the wrong arg type calls praia_throw + returns
    // NULL — verifies the message-set path. The "NULL without
    // praia_throw" fallback path is exercised by an internal unit
    // in the facade.
    let caught = nil
    try { cmod.add("not", "ints") } catch (e) { caught = str(e) }
    testing.assert(caught.contains("must be ints"),
                   "type-error message round-trips: %{caught}")
})

testing.test("C facade: external handle deleter fires deterministically on drop", lam{ in
    let before = cmod.box_freed_count()
    let h = cmod.box()
    // While the handle is live, unwrap reads the underlying int.
    testing.assertEqual(cmod.box_unwrap(h), 42, "external pointer dereferences")
    testing.assertEqual(cmod.box_freed_count(), before,
                       "deleter doesn't fire while a reference exists")
    h = nil
    testing.assertEqual(cmod.box_freed_count() - before, 1,
                       "deleter fires exactly once when the last reference drops")
})

testing.test("C facade: external handle type guard catches type confusion", lam{ in
    // Passing a non-external to box_unwrap should throw, not segfault.
    let caught = nil
    try { cmod.box_unwrap("not a handle") } catch (e) { caught = str(e) }
    testing.assert(caught != nil, "type guard fires")
    testing.assert(caught.contains("external") || caught.contains("type"),
                   "diagnostic mentions the type-confusion: %{caught}")
})

testing.test("C facade: map construction via praia_value_new_map + map_set", lam{ in
    let m = cmod.dict("answer", 42)
    testing.assertEqual(m.answer, 42, nil)
    let m2 = cmod.dict("greeting", "hello")
    testing.assertEqual(m2.greeting, "hello", "string values round-trip too")
})

testing.test("C facade: arity mismatch caught by the engine before the callback runs", lam{ in
    let caught = nil
    try { cmod.add(1) } catch (e) { caught = str(e) }
    testing.assert(caught != nil, "engine throws on arity mismatch")
})

testing.test("C facade: add overflow guard fires instead of UB-ing", lam{ in
    // INT64_MAX = 9223372036854775807. Adding 1 would overflow,
    // which used to be silent UB in cmod.add. The guard added in
    // cmod_add catches it and throws a Praia error.
    let caught = nil
    try { cmod.add(9223372036854775807, 1) } catch (e) { caught = str(e) }
    testing.assert(caught != nil, "overflow throws")
    testing.assert(caught.contains("overflow"),
                   "error message identifies the overflow: %{caught}")
})

testing.test("C facade: praia_last_error + praia_take_error round-trip", lam{ in
    // The native stages an error with praia_throw, drains it via
    // praia_take_error, and returns the drained string. A
    // returned string (not a thrown exception) proves both:
    //   1. praia_take_error successfully read the staged message;
    //   2. after the drain, the staged slot is empty — so the
    //      native returning non-NULL doesn't leak a stale error.
    let s = cmod.error_intercept("hello")
    testing.assertEqual(s, "intercepted: hello", nil)
})

testing.test("C facade: error slot is reset between native calls", lam{ in
    // A native that throws followed immediately by one that
    // succeeds — the staged error from the first call shouldn't
    // carry over and corrupt the second call's return.
    let caught = nil
    try { cmod.boom() } catch (e) { caught = str(e) }
    testing.assert(caught.contains("deliberate"), "first call's error surfaced")
    testing.assertEqual(cmod.add(2, 3), 5,
                       "second call returns cleanly with no leaked error")
})

testing.test("C facade: set ops via praia_value_new_set + set_add + set_values", lam{ in
    // cmod.makeset(a, b, c, …) builds a set with each arg as a
    // member. Duplicate insertions are no-ops (set semantics).
    let s = cmod.makeset(1, 2, 3, 2, 1)
    testing.assertEqual(type(s), "set", "returned value is a set")
    testing.assertEqual(len(s), 3, "duplicates collapsed: 3 unique members")
    testing.assert(s.has(1), "set contains 1")
    testing.assert(s.has(2), "set contains 2")
    testing.assert(s.has(3), "set contains 3")
    testing.assert(!s.has(4), "set doesn't contain 4")
})

testing.test("C facade: non-hashable set element gets a precise diagnostic", lam{ in
    // Mirrors the map_set hashability check — sets use the same
    // ValueHash and refuse non-hashable members up front.
    let caught = nil
    try { cmod.makeset([1, 2]) } catch (e) { caught = str(e) }
    testing.assert(caught != nil, "non-hashable set element throws")
    testing.assert(caught.contains("hashable") || caught.contains("hash"),
                   "diagnostic names the constraint: %{caught}")
})

testing.test("C facade: non-hashable map key gets a precise diagnostic", lam{ in
    // cmod.dict's first arg becomes the map key. Praia maps reject
    // non-hashable keys (maps/arrays); the facade catches that up
    // front with a specific message rather than letting the
    // variant-side hash blow up with a generic error.
    let caught = nil
    try { cmod.dict([1, 2], "value") } catch (e) { caught = str(e) }
    testing.assert(caught != nil, "non-hashable key throws")
    testing.assert(caught.contains("hashable") || caught.contains("hash"),
                   "diagnostic names the constraint: %{caught}")
})

testing.done()
