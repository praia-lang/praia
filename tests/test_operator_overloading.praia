use "testing"

class Vec {
    func init(x, y) { this.x = x; this.y = y }
    func __add(other) { return Vec(this.x + other.x, this.y + other.y) }
    func __sub(other) { return Vec(this.x - other.x, this.y - other.y) }
    func __mul(other) { return Vec(this.x * other, this.y * other) }
    func __eq(other)  { return this.x == other.x && this.y == other.y }
    func __lt(other)  { return this.x + this.y < other.x + other.y }
    func __gt(other)  { return this.x + this.y > other.x + other.y }
    func __neg()      { return Vec(-this.x, -this.y) }
    func __str()      { return "(%{this.x}, %{this.y})" }
    func __len()      { return 2 }
    func __index(key) { if (key == 0) { return this.x } return this.y }
    func __indexSet(key, val) {
        if (key == 0) { this.x = val } else { this.y = val }
    }
}

testing.test("__add", lam{ in
    let r = Vec(1, 2) + Vec(3, 4)
    testing.expectEqual(r.x, 4, nil)
    testing.expectEqual(r.y, 6, nil)
})

testing.test("__sub", lam{ in
    let r = Vec(5, 7) - Vec(2, 3)
    testing.expectEqual(r.x, 3, nil)
    testing.expectEqual(r.y, 4, nil)
})

testing.test("__mul", lam{ in
    let r = Vec(2, 3) * 4
    testing.expectEqual(r.x, 8, nil)
    testing.expectEqual(r.y, 12, nil)
})

testing.test("__eq and __neq", lam{ in
    testing.expect(Vec(1, 2) == Vec(1, 2), "eq")
    testing.expect(Vec(1, 2) != Vec(3, 4), "neq")
})

testing.test("__lt __gt __lte __gte", lam{ in
    testing.expect(Vec(1, 1) < Vec(3, 3), "lt")
    testing.expect(Vec(3, 3) > Vec(1, 1), "gt")
    testing.expect(!(Vec(3, 3) <= Vec(1, 1)), "not lte")
    testing.expect(!(Vec(1, 1) >= Vec(3, 3)), "not gte")
})

testing.test("__neg", lam{ in
    let r = -Vec(1, 2)
    testing.expectEqual(r.x, -1, nil)
    testing.expectEqual(r.y, -2, nil)
})

testing.test("__str with str() and print", lam{ in
    testing.expectEqual(str(Vec(3, 4)), "(3, 4)", nil)
})

testing.test("__len", lam{ in
    testing.expectEqual(len(Vec(0, 0)), 2, nil)
})

testing.test("__index", lam{ in
    let v = Vec(10, 20)
    testing.expectEqual(v[0], 10, nil)
    testing.expectEqual(v[1], 20, nil)
})

testing.test("__indexSet", lam{ in
    let v = Vec(0, 0)
    v[0] = 42
    v[1] = 99
    testing.expectEqual(v.x, 42, nil)
    testing.expectEqual(v.y, 99, nil)
})

testing.test("__str backwards compat with toString", lam{ in
    class Old {
        func init(v) { this.v = v }
        func toString() { return "old:" + str(this.v) }
    }
    testing.expectEqual(str(Old(1)), "old:1", nil)
})

testing.test("operators on non-overloaded classes fall through", lam{ in
    class Plain { func init() {} }
    let a = Plain()
    let b = Plain()
    // == falls back to reference equality
    testing.expect(a != b, "different instances")
    testing.expect(a == a, "same reference")
})

testing.done()
