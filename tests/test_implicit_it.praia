use "testing"

testing.test("implicit it in map", lam{ in
    testing.assertEqual([1, 2, 3] |> map(lam{ it * 2 }), [2, 4, 6], nil)
})

testing.test("implicit it in filter", lam{ in
    testing.assertEqual([1, 2, 3, 4] |> filter(lam{ it > 2 }), [3, 4], nil)
})

testing.test("implicit it in any/all", lam{ in
    testing.assert([1, 2, 3] |> any(lam{ it > 2 }), nil)
    testing.assert([1, 2, 3] |> all(lam{ it > 0 }), nil)
})

testing.test("implicit it standalone", lam{ in
    let double = lam{ it * 2 }
    testing.assertEqual(double(5), 10, nil)
})

testing.test("implicit it with method call", lam{ in
    testing.assertEqual(["a", "b"] |> map(lam{ it.upper() }), ["A", "B"], nil)
})

testing.test("explicit params still work", lam{ in
    testing.assertEqual([1, 2, 3] |> map(lam{ x in x + 10 }), [11, 12, 13], nil)
})

testing.test("zero-param lambda still works", lam{ in
    let f = lam{ in 42 }
    testing.assertEqual(f(), 42, nil)
})

testing.test("pipe try catches error", lam{ in
    let r = "bad" |> json.parse |?> lam{ nil }
    testing.assertEqual(r, nil, nil)
})

testing.test("pipe try passes through on success", lam{ in
    let r = "[1]" |> json.parse |?> lam{ nil }
    testing.assertEqual(r, [1], nil)
})

testing.test("pipe try with implicit it", lam{ in
    let r = "bad" |> json.parse |?> lam{ "error: " + it }
    testing.assert(r.startsWith("error:"), nil)
})

testing.test("pipe try in chain", lam{ in
    func fail(x) { throw "nope" }
    let r = 1 |> fail |?> lam{ "recovered" }
    testing.assertEqual(r, "recovered", nil)
})

// Regression: the implicit-it detection scanned ahead for an `in`
// token but only tracked brace depth — so a nested `for (x in arr)`
// at the body level made the parser think the lambda had explicit
// params named "x", then failed when no `}` followed. Now the
// lookahead also tracks paren + bracket depth.
testing.test("implicit-it lambda with for-in body", lam{ in
    let out = []
    let f = lam{ for (x in [1, 2, 3]) { push(out, x) } }
    f(nil)
    testing.assertEqual(out, [1, 2, 3], "for-in body parsed correctly")
})

testing.test("implicit-it lambda with nested array literal", lam{ in
    // [1, 2] inside the body — the `]` is at bracketDepth 0, but the
    // lookahead must not confuse the array literal's contents with
    // params.
    let f = lam{ return [10, 20, 30] }
    testing.assertEqual(f(nil), [10, 20, 30], nil)
})

// Regression: BIT_NOT was missing from the "can start expression"
// allowlist in returnStatement and yield, so `return ~x` / `yield ~x`
// silently produced nil instead of the bitwise complement.
testing.test("return ~int gives bitwise complement", lam{ in
    func r() { return ~1 }
    testing.assertEqual(r(), -2, nil)
    func r2() { return ~0xFF }
    testing.assertEqual(r2(), -256, nil)
})

testing.test("yield ~int gives bitwise complement", lam{ in
    func g() {
        yield ~1
        yield ~0
    }
    let it = g()
    testing.assertEqual(it.next().value, -2, nil)
    testing.assertEqual(it.next().value, -1, nil)
})

testing.done()
