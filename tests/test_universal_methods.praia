use "testing"

testing.test(".toString() on int", lam{ in
    testing.expectEqual(42.toString(), "42", nil)
    testing.expectEqual(0.toString(), "0", nil)
})

testing.test(".toString() on float", lam{ in
    let s = 3.14.toString()
    testing.expect(s.startsWith("3.14"), "should start with 3.14")
})

testing.test(".toString() on bool", lam{ in
    testing.expectEqual(true.toString(), "true", nil)
    testing.expectEqual(false.toString(), "false", nil)
})

testing.test(".toString() on nil", lam{ in
    testing.expectEqual(nil.toString(), "nil", nil)
})

testing.test(".toString() on array", lam{ in
    testing.expectEqual([1, 2].toString(), "[1, 2]", nil)
})

testing.test(".toNum() on string", lam{ in
    testing.expectEqual("42".toNum(), 42, nil)
    testing.expectEqual("3.14".toNum(), 3.14, nil)
})

testing.test(".toNum() on bool", lam{ in
    testing.expectEqual(true.toNum(), 1, nil)
    testing.expectEqual(false.toNum(), 0, nil)
})

testing.test(".toNum() on bool strings", lam{ in
    testing.expectEqual("true".toNum(), 1, nil)
    testing.expectEqual("FALSE".toNum(), 0, nil)
})

testing.test(".toNum() on number is identity", lam{ in
    testing.expectEqual(42.toNum(), 42, nil)
    testing.expectEqual(3.14.toNum(), 3.14, nil)
})

testing.test(".toNum() throws on invalid string", lam{ in
    testing.expectThrows(lam{ in "abc".toNum() }, nil)
})

testing.test("instance .toString() calls user method", lam{ in
    class A {
        func toString() { return "custom" }
    }
    testing.expectEqual(A().toString(), "custom", nil)
    // str() should also use it (via __str/toString fallback)
    testing.expectEqual(str(A()), "custom", nil)
})

testing.test("instance .toNum() calls user method", lam{ in
    class B {
        func init(v) { this.v = v }
        func toNum() { return this.v }
    }
    testing.expectEqual(B(42).toNum(), 42, nil)
})

testing.test("instance without override gets universal .toString()", lam{ in
    class Plain {}
    testing.expectEqual(Plain().toString(), "<instance>", nil)
})

testing.test("map key 'toString' is not shadowed by universal", lam{ in
    let m = {toString: "field", toNum: 42}
    testing.expectEqual(m.toString, "field", nil)
    testing.expectEqual(m.toNum, 42, nil)
})

testing.test("map without 'toString' key gets universal", lam{ in
    let m = {a: 1}
    testing.expectEqual(m.toString(), "{a: 1}", nil)
})

testing.done()
