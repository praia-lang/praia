use "testing"

// `secrets` is the user-friendly namespace for generating tokens
// and comparing them safely. Everything in here is CSPRNG-backed
// (RAND_bytes → /dev/urandom on Linux/macOS), not Mersenne Twister.

// ── token / tokenHex / tokenUrlSafe ───────────────────────────

testing.test("secrets.token returns the requested byte count", lam{ in
    testing.assertEqual(len(secrets.token(0).bytes()), 0, nil)
    testing.assertEqual(len(secrets.token(16).bytes()), 16, nil)
    testing.assertEqual(len(secrets.token(32).bytes()), 32, nil)
})

testing.test("secrets.tokenHex produces 2n lowercase hex characters", lam{ in
    let h = secrets.tokenHex(16)
    testing.assertEqual(len(h), 32, "16 bytes = 32 hex chars")
    for (i in 0..len(h)) {
        let c = h[i]
        testing.assert("0123456789abcdef".contains(c),
                       "non-hex char at " + i + ": " + c)
    }
})

testing.test("secrets.tokenUrlSafe contains only URL-safe characters", lam{ in
    let t = secrets.tokenUrlSafe(48)
    // RFC 4648 §5 alphabet — no '+', '/', or '=' padding.
    for (i in 0..len(t)) {
        let c = t[i]
        testing.assert(
            "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_".contains(c),
            "non-urlsafe char at " + i + ": " + c)
    }
})

testing.test("two consecutive tokens differ (high entropy)", lam{ in
    // Birthday-paradox collision in a 256-bit space is astronomically
    // unlikely; for 32-byte tokens two draws should always differ.
    let a = secrets.token(32)
    let b = secrets.token(32)
    testing.assert(a != b, "two 32-byte tokens must differ")
})

testing.test("byte counts out of range throw", lam{ in
    testing.assertThrows(lam{ in secrets.token(-1) }, "0..65536")
    testing.assertThrows(lam{ in secrets.tokenHex(-1) }, "0..65536")
    testing.assertThrows(lam{ in secrets.tokenUrlSafe(99999) }, "0..65536")
})

testing.test("non-numeric byte count throws", lam{ in
    testing.assertThrows(lam{ in secrets.tokenHex("eight") },
                         "must be a number")
})

// ── compare ──────────────────────────────────────────────────

testing.test("compare: equal strings return true", lam{ in
    testing.assertEqual(secrets.compare("hello", "hello"), true, nil)
    testing.assertEqual(secrets.compare("", ""), true, "empty == empty")
})

testing.test("compare: differing strings return false", lam{ in
    testing.assertEqual(secrets.compare("hello", "hellp"), false, nil)
    testing.assertEqual(secrets.compare("a", "b"), false, nil)
})

testing.test("compare: length mismatch returns false (no panic, no leak)", lam{ in
    testing.assertEqual(secrets.compare("short", "longerstring"), false, nil)
    testing.assertEqual(secrets.compare("abc", ""), false, nil)
})

testing.test("compare: requires two strings", lam{ in
    testing.assertThrows(lam{ in secrets.compare("a", 1) }, "two strings")
    testing.assertThrows(lam{ in secrets.compare(42, "b") }, "two strings")
})

testing.test("compare composes with crypto.hmac for tag verification", lam{ in
    // Realistic flow: server computes an expected HMAC, attacker
    // sends one. constant-time compare prevents an early-mismatch
    // timing side-channel from leaking the right tag byte-by-byte.
    let key = "k1"
    let msg = "trusted message"
    let expected = crypto.hmac(key, msg, "sha256")
    testing.assert(secrets.compare(expected, crypto.hmac(key, msg, "sha256")), nil)
    testing.assert(!secrets.compare(expected, crypto.hmac("kX", msg, "sha256")), nil)
})

// ── choice ───────────────────────────────────────────────────

testing.test("choice from an array returns one of its elements", lam{ in
    let arr = ["a", "b", "c", "d"]
    let seen = {}
    for (i in 0..200) { seen[secrets.choice(arr)] = true }
    // 200 draws over 4 elements: by birthday, all 4 are extremely
    // likely to appear. Failure here means the distribution is
    // catastrophically uneven OR rejection sampling is broken.
    testing.assertEqual(len(keys(seen)), 4, "all elements drawn within 200 picks")
})

testing.test("choice from a string returns a grapheme", lam{ in
    // The string "abc" has 3 graphemes; the chosen value is one of
    // them.
    let chosen = secrets.choice("abc")
    testing.assert(chosen == "a" || chosen == "b" || chosen == "c", nil)
})

testing.test("choice from emoji string keeps clusters intact", lam{ in
    // Three flag emoji, each a regional-indicator pair grapheme.
    // The chosen value must be a single whole flag, never a half.
    let flags = "\u{1F1F8}\u{1F1EA}\u{1F1FA}\u{1F1F8}\u{1F1EB}\u{1F1F7}"
    let chosen = secrets.choice(flags)
    testing.assertEqual(len(chosen), 1, "result is one grapheme")
})

testing.test("choice rejects empty inputs", lam{ in
    testing.assertThrows(lam{ in secrets.choice([]) }, "array is empty")
    testing.assertThrows(lam{ in secrets.choice("") }, "string is empty")
})

testing.test("choice rejects non-sequence inputs", lam{ in
    testing.assertThrows(lam{ in secrets.choice(42) }, "array or string")
    testing.assertThrows(lam{ in secrets.choice({a: 1}) }, "array or string")
})

testing.done()
