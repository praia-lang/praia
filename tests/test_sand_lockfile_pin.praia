use "testing"

// Regression: sand-lock.yaml used to only record `source`, `version`,
// `url`, and `installed`. A grain pinned with `version: main` or any
// moving tag would silently move forward on the next `sand install`,
// because there was nothing in the lockfile that named a specific
// revision. The fix introduces:
//   • `commit:` — full SHA captured at install time
//   • `integrity:` — content hash of the installed tree
// Restore checks out the pinned SHA and verifies the integrity match
// before reporting success.

let _gitProbe = sys.exec(["which", "git"])
if (_gitProbe.exitCode != 0) {
    print("(skipping: git not available)")
    testing.done()
    sys.exit(0)
}

let praiaBin = path.join(sys.cwd(), "praia")
let sandMain = path.join(sys.cwd(), "sand", "main.praia")
let _mk = lam{ in
    return sys.exec(["mktemp", "-d"]).stdout.strip()
}
let sandHome = _mk()
let fixtureRoot = _mk()

func runSand(args) {
    let cmd = ["env", "HOME=" + sandHome, praiaBin, sandMain]
    for (a in args) { cmd.push(a) }
    return sys.exec(cmd)
}

// Build a git-tracked grain with the given file contents. Returns
// (grainDir, headSha).
func makeGrain(name, mainBody) {
    let grain = path.join(fixtureRoot, name)
    if (fs.exists(grain)) { fs.remove(grain) }
    fs.mkdir(grain)
    fs.write(path.join(grain, "main.praia"), mainBody)
    fs.write(path.join(grain, "grain.yaml"),
        "name: %{name}\nversion: 0.1.0\nmain: main.praia\n")
    sys.exec(["git", "init", "-q", grain])
    sys.exec(["git", "-C", grain, "add", "-A"])
    sys.exec(["git", "-C", grain,
              "-c", "user.email=t@t", "-c", "user.name=t",
              "commit", "-q", "-m", "init"])
    let sha = sys.exec(["git", "-C", grain, "rev-parse", "HEAD"]).stdout.strip()
    return [grain, sha]
}

// Append a new commit to an existing grain so the branch tip moves.
func bumpGrain(grain, newBody) {
    fs.write(path.join(grain, "main.praia"), newBody)
    sys.exec(["git", "-C", grain, "add", "-A"])
    sys.exec(["git", "-C", grain,
              "-c", "user.email=t@t", "-c", "user.name=t",
              "commit", "-q", "-m", "bump"])
    return sys.exec(["git", "-C", grain, "rev-parse", "HEAD"]).stdout.strip()
}

testing.test("install records commit SHA and integrity in the lockfile", lam{ in
    let [grain, sha] = makeGrain("pinme", "let v = 1\nexport { v }\n")

    let r = runSand(["install", "-g", "file://" + grain])
    testing.expectEqual(r.exitCode, 0, "install: " + r.stderr)

    let lock = fs.read(path.join(sandHome, ".praia", "ext_grains", ".sand-lock.yaml"))
    testing.expect(lock.contains("commit: %{sha}"),
        "lockfile records the full HEAD SHA: " + lock)
    testing.expect(lock.contains("integrity: sha256-"),
        "lockfile records an sha256 integrity hash: " + lock)

    let cleanup = runSand(["remove", "-g", "-y", "pinme"])
    testing.expectEqual(cleanup.exitCode, 0, cleanup.stderr)
})

testing.test("restore from lockfile re-installs the pinned commit, not the branch tip", lam{ in
    // Install at v1, capture lock contents.
    let [grain, sha1] = makeGrain("driftless", "let v = 1\nexport { v }\n")
    let r1 = runSand(["install", "-g", "file://" + grain])
    testing.expectEqual(r1.exitCode, 0, "install: " + r1.stderr)

    let lockPath = path.join(sandHome, ".praia", "ext_grains", ".sand-lock.yaml")
    let lockBefore = fs.read(lockPath)
    testing.expect(lockBefore.contains("commit: %{sha1}"),
        "lockfile pins v1's SHA")

    // Source repo moves forward. Without a SHA pin, a restore would
    // silently install the new revision.
    let sha2 = bumpGrain(grain, "let v = 2\nexport { v }\n")
    testing.expect(sha1 != sha2, "bump produced a new commit")

    // Tear down the local install — but keep the lockfile, which is
    // what `sand install` (no args) restores from.
    let grainDir = path.join(sandHome, ".praia", "ext_grains", "driftless")
    fs.remove(grainDir)

    let r2 = runSand(["install", "-g"])
    testing.expectEqual(r2.exitCode, 0, "restore: " + r2.stderr)

    // Content must be v1 (pinned), not v2 (current branch tip).
    let restoredMain = fs.read(path.join(grainDir, "main.praia"))
    testing.expectEqual(restoredMain, "let v = 1\nexport { v }\n",
        "restore brought back the pinned content")

    // And the lockfile entry — including commit and integrity — must
    // be unchanged across the restore. The pin is what made the
    // restore deterministic; a successful restore that mutated the
    // lock would defeat the whole point.
    let lockAfter = fs.read(lockPath)
    testing.expectEqual(lockAfter, lockBefore,
        "lockfile is byte-identical after a clean restore")

    let cleanup = runSand(["remove", "-g", "-y", "driftless"])
    testing.expectEqual(cleanup.exitCode, 0, cleanup.stderr)
})

testing.test("restore aborts when integrity does not match", lam{ in
    let [grain, sha] = makeGrain("verifyme", "let v = 1\nexport { v }\n")
    let r = runSand(["install", "-g", "file://" + grain])
    testing.expectEqual(r.exitCode, 0, "install: " + r.stderr)

    // Corrupt the recorded integrity hash. The pinned SHA still
    // points to valid content, so the only thing protecting us from
    // accepting whatever the repo serves up is the post-install
    // integrity verify.
    let lockPath = path.join(sandHome, ".praia", "ext_grains", ".sand-lock.yaml")
    let lock = fs.read(lockPath)
    let mangled = lock.replace("integrity: sha256-",
                                "integrity: sha256-deadbeef")
    testing.expect(mangled != lock, "managed to corrupt integrity line")
    fs.write(lockPath, mangled)

    let grainDir = path.join(sandHome, ".praia", "ext_grains", "verifyme")
    fs.remove(grainDir)

    let r2 = runSand(["install", "-g"])
    testing.expect(r2.exitCode != 0,
        "restore must fail when integrity check fails (exit=" + str(r2.exitCode) + ")")
    testing.expect((r2.stdout + r2.stderr).contains("integrity"),
        "error mentions integrity: " + r2.stdout + r2.stderr)

    // Roll the lockfile back so subsequent tests have a clean state.
    fs.write(lockPath, lock)
    // Clean up the (potentially partially-installed) directory.
    if (fs.exists(grainDir)) { fs.remove(grainDir) }
    let cleanup = runSand(["remove", "-g", "-y", "verifyme"])
    // Don't assert here — depending on where the integrity check
    // fired, the lockfile entry may or may not still exist. We just
    // want sandHome clean for the next test.
})

testing.test("install with @version stores bare source (no double-pin on restore)", lam{ in
    // Regression: when the user installed `<url>@v1`, the lockfile
    // saved `source: <url>@v1` verbatim, then restore appended
    // `@v1` again, producing `<url>@v1@v1`. parseSpec then derived
    // a name like `repo@v1` from the last segment, which failed
    // isValidName, and the whole restore aborted.
    let g = makeGrain("pinned", "let v = 1\nexport { v }\n")
    let grain = g[0]
    sys.exec(["git", "-C", grain, "tag", "v1"])

    let r1 = runSand(["install", "-g", "file://" + grain + "@v1"])
    testing.expectEqual(r1.exitCode, 0, "v1 install: " + r1.stderr)

    let lockPath = path.join(sandHome, ".praia", "ext_grains", ".sand-lock.yaml")
    let lock = fs.read(lockPath)
    testing.expect(lock.contains("source: " + "file://" + grain + "\n"),
        "source stored without @version suffix: " + lock)
    testing.expect(lock.contains("version: v1"),
        "version recorded separately: " + lock)

    // Tear down the local install and restore from the lockfile.
    let grainDir = path.join(sandHome, ".praia", "ext_grains", "pinned")
    fs.remove(grainDir)

    let r2 = runSand(["install", "-g"])
    testing.expectEqual(r2.exitCode, 0,
        "restore (no double-pin) succeeds: " + r2.stderr)
    testing.expect(fs.exists(grainDir),
        "grain reinstalled at the pinned version")

    let cleanup = runSand(["remove", "-g", "-y", "pinned"])
    testing.expectEqual(cleanup.exitCode, 0, cleanup.stderr)
})

testing.test("restore tolerates an old-format lockfile with @version embedded in source", lam{ in
    // Defensive: lockfiles written by older sand versions stored the
    // version pin inside `source`. After the fix, restore guards
    // against appending the version a second time, so old lockfiles
    // keep working without manual editing.
    let g = makeGrain("migrate", "let v = 1\nexport { v }\n")
    let grain = g[0]
    sys.exec(["git", "-C", grain, "tag", "v1"])

    // Hand-write an old-format lockfile.
    let extGrains = path.join(sandHome, ".praia", "ext_grains")
    fs.mkdir(extGrains)
    let lockPath = path.join(extGrains, ".sand-lock.yaml")
    fs.write(lockPath,
        "grains:\n" +
        "  migrate:\n" +
        "    source: file://" + grain + "@v1\n" +
        "    version: v1\n" +
        "    url: file://" + grain + "\n" +
        "    installed: 2026-05-20\n")

    let r = runSand(["install", "-g"])
    testing.expectEqual(r.exitCode, 0,
        "restore from old-format lockfile succeeds: " + r.stderr)
    let grainDir = path.join(extGrains, "migrate")
    testing.expect(fs.exists(grainDir),
        "old-format lockfile restored without double-pin")

    let cleanup = runSand(["remove", "-g", "-y", "migrate"])
    testing.expectEqual(cleanup.exitCode, 0, cleanup.stderr)
})

testing.test("update short-circuits when the remote SHA matches the lockfile", lam{ in
    // Regression: `sand update` used to re-clone and re-install every
    // grain pinned to "latest" even when the remote hadn't moved.
    // After the fix, an ls-remote probe compares the remote HEAD
    // against `info.commit` and skips the install when they match.
    let g = makeGrain("nochange", "let v = 1\nexport { v }\n")
    let grain = g[0]
    let r1 = runSand(["install", "-g", "file://" + grain])
    testing.expectEqual(r1.exitCode, 0, "install: " + r1.stderr)

    let grainDir = path.join(sandHome, ".praia", "ext_grains", "nochange")
    let lockPath = path.join(sandHome, ".praia", "ext_grains", ".sand-lock.yaml")
    let mainBefore = fs.read(path.join(grainDir, "main.praia"))
    let lockBefore = fs.read(lockPath)

    // No remote change between install and update.
    let r2 = runSand(["update", "-g", "nochange"])
    testing.expectEqual(r2.exitCode, 0, "update no-op: " + r2.stderr)
    testing.expect(r2.stdout.contains("up to date"),
        "update reports no-op: " + r2.stdout)
    // Nothing on disk should change.
    testing.expectEqual(fs.read(path.join(grainDir, "main.praia")), mainBefore,
        "grain content untouched on no-op update")
    testing.expectEqual(fs.read(lockPath), lockBefore,
        "lockfile untouched on no-op update")

    let cleanup = runSand(["remove", "-g", "-y", "nochange"])
    testing.expectEqual(cleanup.exitCode, 0, cleanup.stderr)
})

testing.test("update still re-installs when the remote has moved", lam{ in
    // Counter-test: when the remote DOES have a new commit, update
    // must actually run (and record the new SHA in the lockfile).
    let g = makeGrain("moved", "let v = 1\nexport { v }\n")
    let grain = g[0]
    let r1 = runSand(["install", "-g", "file://" + grain])
    testing.expectEqual(r1.exitCode, 0, "install: " + r1.stderr)

    let lockPath = path.join(sandHome, ".praia", "ext_grains", ".sand-lock.yaml")
    let lockBefore = fs.read(lockPath)
    let newSha = bumpGrain(grain, "let v = 2\nexport { v }\n")

    let r2 = runSand(["update", "-g", "moved"])
    testing.expectEqual(r2.exitCode, 0, "update: " + r2.stderr)
    testing.expect(!r2.stdout.contains("up to date"),
        "remote-moved update is not skipped: " + r2.stdout)
    let lockAfter = fs.read(lockPath)
    testing.expect(lockAfter != lockBefore,
        "lockfile updated when remote moves")
    testing.expect(lockAfter.contains("commit: " + newSha),
        "new commit SHA recorded: " + lockAfter)

    let cleanup = runSand(["remove", "-g", "-y", "moved"])
    testing.expectEqual(cleanup.exitCode, 0, cleanup.stderr)
})

sys.exec(["rm", "-rf", sandHome, fixtureRoot])
testing.done()
