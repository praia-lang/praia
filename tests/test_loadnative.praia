use "testing"

let ext = ".dylib"
if (sys.platform != "darwin") {
    ext = ".so"
}

let pluginPath = "examples/plugins/mathext" + ext

if (!fs.exists(pluginPath)) {
    print("Skipping loadNative tests — plugin not built")
    print("Build with: make plugin SRC=examples/plugins/mathext.cpp OUT=examples/plugins/mathext" + ext)
    testing.done()
}

let mathext = loadNative(pluginPath)

testing.test("gcd", lam{ in
    testing.assertEqual(mathext.gcd(48, 18), 6, nil)
    testing.assertEqual(mathext.gcd(100, 75), 25, nil)
    testing.assertEqual(mathext.gcd(7, 13), 1, nil)
})

testing.test("lcm", lam{ in
    testing.assertEqual(mathext.lcm(12, 8), 24, nil)
    testing.assertEqual(mathext.lcm(0, 5), 0, nil)
})

testing.test("fibonacci", lam{ in
    testing.assertEqual(mathext.fibonacci(0), 0, nil)
    testing.assertEqual(mathext.fibonacci(1), 1, nil)
    testing.assertEqual(mathext.fibonacci(10), 55, nil)
})

testing.test("hypot", lam{ in
    testing.assertEqual(mathext.hypot(3, 4), 5, nil)
})

testing.test("sum", lam{ in
    testing.assertEqual(mathext.sum([1, 2, 3, 4, 5]), 15, nil)
    testing.assertEqual(mathext.sum([]), 0, nil)
})

testing.test("filter — plugin invokes a Praia callback via praia::call", lam{ in
    // Exercises the praia::call helper: the native function takes
    // a Callable, calls it once per element, and keeps the ones
    // where the predicate returns truthy. If the helper or its
    // engine-dispatch shim breaks, this fails.
    let kept = mathext.filter([1, 2, 3, 4, 5, 6], lam{ x in x > 3 })
    testing.assertEqual(kept, [4, 5, 6], nil)
    // Empty input — predicate is never called.
    testing.assertEqual(mathext.filter([], lam{ x in true }), [], nil)
    // Named function (not just inline lambda).
    func isEven(n) { return n % 2 == 0 }
    testing.assertEqual(mathext.filter([1, 2, 3, 4, 5], isEven), [2, 4], nil)
})

testing.test("filter — non-callable predicate throws cleanly", lam{ in
    testing.assertThrows(lam{ in mathext.filter([1, 2, 3], 42) }, nil)
})

testing.test("plugin metadata surfaces on _meta", lam{ in
    // PRAIA_PLUGIN_METADATA() in mathext.cpp populates these.
    // Plugins that don't declare metadata get no `_meta` key —
    // tested implicitly by every other test that ignores it.
    testing.assertEqual(mathext._meta.name, "mathext", nil)
    testing.assertEqual(mathext._meta.version, "0.1.0", nil)
    testing.assert(mathext._meta.description.contains("math"),
        "description present: " + str(mathext._meta.description))
})

testing.test("native function accepts named arguments", lam{ in
    // gcd declares paramNames {a, b} via the trailing arg of
    // makeNative — without that, this call would fail with
    // "Named arguments not supported for 'mathext.gcd'".
    testing.assertEqual(mathext.gcd(a: 48, b: 18), 6, nil)
    testing.assertEqual(mathext.gcd(b: 18, a: 48), 6,
        "order-independent named call")
    // Positional dispatch still works (back-compat).
    testing.assertEqual(mathext.gcd(48, 18), 6, nil)
})

testing.test("require helpers produce canonical error wording", lam{ in
    // praia::requireNumber throws "<fn>() argument N must be a
    // number" — matches the wording the engine's own builtins use.
    let err = nil
    try { mathext.gcd("not a number", 5) } catch (e) { err = str(e) }
    testing.assert(err != nil, "type mismatch must throw")
    testing.assert(err.contains("mathext.gcd() argument 1 must be a number"),
        "canonical wording: " + str(err))
})

testing.test("gcd rejects floats that don't safely cast to int64", lam{ in
    // Plain static_cast<int64_t> on a double is UB for NaN, ±Inf,
    // non-integer values, and values outside int64 range. gcd's
    // toInt64 helper guards each case and throws a clean error.
    testing.assertThrows(lam{ in mathext.gcd(3.5, 2) }, nil)
    testing.assertThrows(lam{ in mathext.gcd(1e308, 2) }, nil)
    // 9.22e18 ≈ 2^63 — exactly representable as a double, but one
    // past INT64_MAX (which itself can't be represented). Must reject.
    testing.assertThrows(lam{ in mathext.gcd(9223372036854775807, 2) }, nil)
    // Integer-valued floats still cast cleanly.
    testing.assertEqual(mathext.gcd(48.0, 18), 6, nil)
})

testing.test("A1 regression — isNumber-guarded plugin accepts floats", lam{ in
    // Pre-fix, the plugin example demoed `asInt()` after only
    // `isNumber()`, which threw `std::bad_variant_access` on a
    // float argument. mathext.gcd is similarly isNumber-guarded
    // and now does `static_cast<int64_t>(asNumber())` — so a
    // float-valued integer flows through without surprises.
    testing.assertEqual(mathext.gcd(48.0, 18), 6, nil)
    testing.assertEqual(mathext.hypot(3.0, 4.0), 5, nil)
})

testing.test("cached load returns same module", lam{ in
    let mathext2 = loadNative(pluginPath)
    testing.assertEqual(mathext2.gcd(100, 75), 25, nil)
})

testing.test("bad path throws", lam{ in
    testing.assertThrows(lam{ in loadNative("nonexistent.so") }, nil)
})

testing.test("non-string throws", lam{ in
    testing.assertThrows(lam{ in loadNative(42) }, nil)
})

testing.test("ABI version: missing declaration is rejected", lam{ in
    // Build a tiny plugin without PRAIA_DECLARE_ABI() and verify
    // loadNative refuses it with a clear "rebuild" diagnostic.
    // Two skip conditions: --include-path not pointing at shipped
    // headers (no praia install on this machine), or no `c++`
    // compiler available. Anything past those two should COMPILE
    // — a compile failure is a real regression we want to see,
    // not silently skip past.
    let praiaBin = path.join(sys.cwd(), "praia")
    let inc = sys.exec([praiaBin, "--include-path"]).stdout.strip()
    if (!fs.exists(path.join(inc, "praia_plugin.h"))) {
        print("(skipping: --include-path not pointing at shipped headers)")
        return
    }
    if (sys.exec(["c++", "--version"]).exitCode != 0) {
        print("(skipping: c++ compiler not on PATH)")
        return
    }
    let dir = testing.tempDir(nil)
    let src = path.join(dir, "noabi.cpp")
    let out = path.join(dir, "noabi" + ext)
    fs.write(src,
        "#include \"praia_plugin.h\"\n" +
        "extern \"C\" void praia_register(PraiaMap* m) {\n" +
        "    m->entries[\"x\"] = Value(int64_t(1));\n" +
        "}\n")
    // Arg array (not `sh -c <string>`) so quoting / spaces in
    // paths can't bite us, and the compiler invocation is visible
    // in process listings without shell layering.
    let cmd = ["c++",
               "-std=c++20", "-Wno-deprecated-declarations",
               "-D_XOPEN_SOURCE=600", "-D_DARWIN_C_SOURCE",
               "-shared", "-fPIC", "-I" + inc]
    if (sys.platform == "darwin") {
        cmd.push("-undefined")
        cmd.push("dynamic_lookup")
    }
    cmd.push("-o")
    cmd.push(out)
    cmd.push(src)
    let r = sys.exec(cmd)
    // A compile failure here means a header/flag regression — surface
    // both stdout and stderr instead of silently skipping past it.
    testing.assertEqual(r.exitCode, 0,
        "c++ compile of the no-ABI fixture failed:\n" +
        "stderr: " + r.stderr + "\nstdout: " + r.stdout)

    let err = nil
    try { loadNative(out) } catch (e) { err = str(e) }
    testing.assert(err != nil, "loadNative must reject the no-ABI plugin")
    testing.assert(err.contains("ABI"),
        "error message mentions ABI: " + str(err))
})

// ── Opaque-handle tests (counter plugin) ─────────────────────

let counterPath = "examples/plugins/counter" + ext

if (!fs.exists(counterPath)) {
    print("(skipping opaque-handle tests — counter plugin not built)")
    testing.done()
}

let counter = loadNative(counterPath)

testing.test("opaque handle: round-trip via inc/value/reset", lam{ in
    let h = counter.new()
    testing.assertEqual(counter.value(h), 0, "fresh handle starts at 0")
    counter.inc(h); counter.inc(h); counter.inc(h)
    testing.assertEqual(counter.value(h), 3, "three inc steps land at 3")
    counter.reset(h)
    testing.assertEqual(counter.value(h), 0, "reset returns to 0")
})

testing.test("opaque handle: toString shows the type tag", lam{ in
    let h = counter.new()
    testing.assertEqual(str(h), "<external:counter.handle>",
        "tag format includes type name")
})

testing.test("opaque handle: getExternal rejects non-external values", lam{ in
    // Pass a string where a handle is expected. praia::getExternal
    // throws with a clear "expected an external handle of type X".
    let err = nil
    try { counter.value("not a handle") } catch (e) { err = str(e) }
    testing.assert(err != nil, "must throw on non-external")
    testing.assert(err.contains("external handle") && err.contains("counter.handle"),
        "error names the expected type: " + str(err))
})

testing.test("opaque handle: getExternal rejects int Values", lam{ in
    let err = nil
    try { counter.value(42) } catch (e) { err = str(e) }
    testing.assert(err != nil, nil)
    testing.assert(err.contains("external handle"), str(err))
})

testing.test("opaque handle: destructor fires when reference drops", lam{ in
    // shared_ptr refcount hits zero on reassign-to-nil, which
    // destroys the PraiaExternal, which runs the deleter (the
    // counter plugin increments a process-global counter from
    // there). No GC sweep needed for refcount-driven drops.
    let before = counter._destructorCount()
    let h = counter.new()
    counter.inc(h)
    h = nil
    let after = counter._destructorCount()
    testing.assertEqual(after - before, 1,
        "exactly one destructor fired between create and drop")
})

testing.test("opaque handle: destructor fires under GC pressure", lam{ in
    // Create handles in a tight loop without retaining references
    // (each iteration overwrites the previous binding). The GC
    // threshold should fire mid-loop; the cumulative destructor
    // count after the loop should equal the number of handles
    // we created.
    let before = counter._destructorCount()
    let h = nil
    for (i in 0..600) {
        h = counter.new()
    }
    h = nil   // drop the final retained handle too
    let after = counter._destructorCount()
    testing.assertEqual(after - before, 600,
        "600 handles created, 600 destructors fired")
})

// ── GC root pinning (praia::pinValue / unpinValue) ────────────

// Build a callback whose captured environment is *only* reachable
// through the returned Callable. Critical: defining the lambda inside
// a helper that then returns means the helper's frame env is no
// longer on the call stack — so the only path the GC has to reach
// the captured `secret` upvalue is via the plugin's pinned Value.
// Putting the lambda inline in the test would leave the test's own
// frame env on the stack, marking the captured env "for free" and
// silently masking a missing pin.
func _makePinTestCallback(payload) {
    return lam{ in return payload }
}

testing.test("plugin-pinned callback survives GC pressure", lam{ in
    counter.setStored(_makePinTestCallback("alive"))
    // _makePinTestCallback has returned — its frame env is no longer
    // a root. The only thing keeping the closure (and its `payload`
    // upvalue) alive is the plugin's C++ pin.
    let h = nil
    for (i in 0..600) {
        h = counter.new()   // pure allocation churn — trips the GC
    }
    h = nil
    let result = counter.callStored()
    testing.assertEqual(result, "alive",
        "pinned callback retained its environment across the sweep")
    counter.clearStored()
})

testing.test("pinned callback's captured upvalues remain bound", lam{ in
    // Same shape as above but proves the *bound value* on the
    // upvalue survives — not just the slot. Without pinning, the
    // sweep would `env->variables.clear()` and the lookup would
    // either throw or return nil.
    counter.setStored(_makePinTestCallback("praia-pinning-works"))
    let h = nil
    for (i in 0..600) {
        h = counter.new()
    }
    h = nil
    testing.assertEqual(counter.callStored(), "praia-pinning-works",
        "upvalue value survived the sweep alongside the closure")
    counter.clearStored()
})

testing.test("clearStored unpins so the closure becomes collectable", lam{ in
    // After clearStored() releases the pin AND drops the C++ stash,
    // there are no remaining references to the closure — the next
    // GC sweep is free to collect it. We can't directly observe
    // closure collection (no destructor count for Callables), but
    // we can verify the slot was cleared by re-calling callStored
    // and asserting it now throws the "no callback stored" error
    // rather than reusing a stale binding.
    counter.setStored(lam{ in return 42 })
    counter.clearStored()
    let err = nil
    try { counter.callStored() } catch (e) { err = str(e) }
    testing.assert(err != nil, "must throw after clearStored")
    testing.assert(err.contains("no callback stored"), str(err))
})

testing.done()
