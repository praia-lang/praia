use "testing"

testing.test("spawn basic write/read", lam{ in
    let proc = sys.spawn("cat")
    proc.write("hello\n")
    proc.closeStdin()
    let out = proc.read()
    testing.expectEqual(out, "hello\n", nil)
    testing.expectEqual(proc.wait(), 0, nil)
})

testing.test("spawn readLine", lam{ in
    let proc = sys.spawn("cat -n")
    proc.write("a\n")
    proc.write("b\n")
    proc.closeStdin()
    let line1 = proc.readLine()
    let line2 = proc.readLine()
    let line3 = proc.readLine()
    testing.expect(line1.contains("a"), "first line")
    testing.expect(line2.contains("b"), "second line")
    testing.expectEqual(line3, nil, "EOF returns nil")
    proc.wait()
})

testing.test("spawn stderr", lam{ in
    let proc = sys.spawn("sh -c 'echo err >&2'")
    let err = proc.readErr()
    testing.expectEqual(err, "err\n", nil)
    proc.wait()
})

testing.test("spawn exit code", lam{ in
    let proc = sys.spawn("sh -c 'exit 42'")
    testing.expectEqual(proc.wait(), 42, nil)
})

testing.test("spawn kill", lam{ in
    let proc = sys.spawn("sleep 60")
    proc.kill()
    let code = proc.wait()
    testing.expectNotEqual(code, 0, "killed process should not exit 0")
})

testing.test("spawn write after close throws", lam{ in
    let proc = sys.spawn("cat")
    proc.closeStdin()
    proc.wait()
    testing.expectThrows(lam{ in proc.write("x") }, "write after close")
})

testing.test("spawn pid", lam{ in
    let proc = sys.spawn("echo hi")
    testing.expectEqual(type(proc.pid), "int", nil)
    testing.expect(proc.pid > 0, "pid should be positive")
    proc.read()
    proc.wait()
})

testing.test("dropped spawn handles release fds + reap child (RAII cleanup)", lam{ in
    // Regression: SpawnState had no destructor, so a caller who
    // dropped the handle without calling .wait() leaked 3 pipe fds
    // and left a zombie child for the rest of the process lifetime.
    // 300 spawns is well above the default macOS soft FD limit (256)
    // and any reasonable user/proc ulimit — without the dtor this
    // would EMFILE or hit the per-user process cap long before
    // completing.
    for (i in 0..300) {
        let proc = sys.spawn(["true"])
        // intentionally NO proc.wait() — relies on RAII
    }
    testing.expect(true, "completed 300 implicit-cleanup spawns without exhausting fds/procs")
})

testing.done()
