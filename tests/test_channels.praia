use "testing"

testing.test("channel send and recv", lam{ in
    let ch = Channel()
    func producer(ch) {
        ch.send(1)
        ch.send(2)
        ch.send(3)
        ch.close()
    }
    async producer(ch)
    let results = []
    while (true) {
        let val = ch.recv()
        if (val == nil) { break }
        push(results, val)
    }
    testing.assertEqual(results, [1, 2, 3], nil)
})

testing.test("buffered channel", lam{ in
    let ch = Channel(3)
    ch.send("a")
    ch.send("b")
    ch.send("c")
    testing.assertEqual(ch.recv(), "a", nil)
    testing.assertEqual(ch.recv(), "b", nil)
    testing.assertEqual(ch.recv(), "c", nil)
})

testing.test("tryRecv non-blocking", lam{ in
    let ch = Channel()
    testing.assertEqual(ch.tryRecv(), nil, "tryRecv on empty should be nil")
    ch.send(42)
    testing.assertEqual(ch.tryRecv(), 42, nil)
    testing.assertEqual(ch.tryRecv(), nil, "tryRecv after drain should be nil")
})

testing.test("channel closed", lam{ in
    let ch = Channel()
    ch.send(1)
    ch.close()
    testing.assertEqual(ch.recv(), 1, "should get value before close")
    testing.assertEqual(ch.recv(), nil, "should get nil after close + empty")
    testing.assert(ch.closed(), "should report closed")
})

// closed() is "closed AND drained". A producer that just wants to know
// whether send() will throw needs isClosed() — which flips the instant
// close() is called, even while the buffer still has values.
testing.test("channel isClosed / isEmpty / closed semantics", lam{ in
    let ch = Channel(3)
    ch.send(1)
    ch.send(2)
    testing.assertEqual(ch.isClosed(), false, "open channel")
    testing.assertEqual(ch.isEmpty(),  false, "buffer has values")
    testing.assertEqual(ch.closed(),   false, "neither closed nor drained")

    ch.close()
    testing.assertEqual(ch.isClosed(), true,  "close() flipped isClosed")
    testing.assertEqual(ch.isEmpty(),  false, "values still buffered")
    testing.assertEqual(ch.closed(),   false, "closed but not yet drained")

    testing.assertEqual(ch.recv(), 1, nil)
    testing.assertEqual(ch.recv(), 2, nil)
    testing.assertEqual(ch.isClosed(), true,  nil)
    testing.assertEqual(ch.isEmpty(),  true,  "fully drained")
    testing.assertEqual(ch.closed(),   true,  "closed AND drained")
})

testing.test("send on closed channel throws", lam{ in
    let ch = Channel()
    ch.close()
    testing.assertThrows(lam{ in ch.send(1) }, nil)
})

testing.test("multiple producers", lam{ in
    let ch = Channel()
    func worker(id, ch) {
        ch.send(id)
    }
    async worker(1, ch)
    async worker(2, ch)
    async worker(3, ch)
    let results = []
    for (i in 0..3) {
        push(results, ch.recv())
    }
    testing.assertEqual(len(results), 3, nil)
    testing.assert(results.contains(1), "should have worker 1")
    testing.assert(results.contains(2), "should have worker 2")
    testing.assert(results.contains(3), "should have worker 3")
})

testing.done()
