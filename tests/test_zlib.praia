use "testing"

// zlib namespace: one-shot gzip and raw-deflate. Two pairs of
// inverses — gzip/gunzip wrap deflate output with a 10-byte header
// + crc32 + isize (RFC 1952); deflate/inflate are the raw RFC 1951
// codec with no framing.

// ── gzip ───────────────────────────────────────────────────────

testing.test("gzip roundtrip on text", lam{ in
    let s = "The quick brown fox jumps over the lazy dog. ".repeat(20)
    let gz = zlib.gzip(s)
    testing.expect(len(gz.bytes()) < len(s.bytes()),
                   "compressed output is smaller than input")
    testing.expectEqual(zlib.gunzip(gz), s, nil)
})

testing.test("gzip output has the RFC 1952 magic header", lam{ in
    // Per RFC 1952 §2.3: ID1=0x1F, ID2=0x8B, CM=0x08 (deflate).
    let header = bytes.hex(bytes.slice(zlib.gzip("hello"), 0, 3))
    testing.expectEqual(header, "1f8b08", "gzip starts with magic 1f 8b 08")
})

testing.test("gzip respects the optional compression level", lam{ in
    let s = "x".repeat(1000)
    // Level 0 = stored (no compression); level 9 = best.
    // The output should be markedly smaller at 9 than at 0.
    testing.expect(len(zlib.gzip(s, 9).bytes()) < len(zlib.gzip(s, 0).bytes()),
                   "level 9 compresses better than level 0")
})

testing.test("gzip rejects level out of range", lam{ in
    testing.expectThrows(lam{ in zlib.gzip("x", -1) }, "0..9")
    testing.expectThrows(lam{ in zlib.gzip("x", 10) }, "0..9")
})

testing.test("gzip handles empty input", lam{ in
    let gz = zlib.gzip("")
    testing.expect(len(gz.bytes()) > 0, "empty input still produces gzip frame")
    testing.expectEqual(zlib.gunzip(gz), "", nil)
})

testing.test("gunzip on garbage throws", lam{ in
    testing.expectThrows(lam{ in zlib.gunzip("not a gzip stream") },
                         "zlib: inflate failed")
})

// ── raw deflate ────────────────────────────────────────────────

testing.test("deflate roundtrip on text", lam{ in
    let s = "abracadabra ".repeat(50)
    let d = zlib.deflate(s)
    testing.expect(len(d.bytes()) < len(s.bytes()), nil)
    testing.expectEqual(zlib.inflate(d), s, nil)
})

testing.test("deflate output is shorter than gzip (no header overhead)", lam{ in
    let s = "hi"
    // The gzip frame adds 10 header bytes + 8 trailer bytes (crc32 + isize),
    // so for a tiny payload the raw deflate is meaningfully smaller.
    testing.expect(len(zlib.deflate(s).bytes()) < len(zlib.gzip(s).bytes()),
                   "raw deflate has no framing overhead")
})

testing.test("deflate handles empty input", lam{ in
    testing.expectEqual(zlib.inflate(zlib.deflate("")), "", nil)
})

testing.test("inflate on garbage throws", lam{ in
    testing.expectThrows(lam{ in zlib.inflate("not deflate-formatted bytes") },
                         "zlib: inflate failed")
})

// ── Cross-format errors ────────────────────────────────────────

testing.test("gunzip on raw deflate throws (different framing)", lam{ in
    let d = zlib.deflate("hello world")
    testing.expectThrows(lam{ in zlib.gunzip(d) }, "zlib: inflate failed")
})

testing.test("inflate on gzip-framed bytes throws", lam{ in
    let gz = zlib.gzip("hello world")
    testing.expectThrows(lam{ in zlib.inflate(gz) }, "zlib: inflate failed")
})

// ── Binary roundtrip ───────────────────────────────────────────

testing.test("gzip roundtrip on arbitrary binary input", lam{ in
    // 256 distinct bytes — exercises the full byte range, not just text.
    let arr = []
    for (i in 0..256) { push(arr, i) }
    let b = bytes.from(arr)
    testing.expectEqual(zlib.gunzip(zlib.gzip(b)), b,
                        "every byte value roundtrips")
})

// ── Output cap (zip-bomb protection) ─────────────────────────────

testing.test("gunzip blocks decompressed output beyond maxOutput", lam{ in
    // 100 KiB of zeroes compresses to a few hundred bytes; perfect
    // miniature zip-bomb. With a 1 KiB cap, gunzip must throw before
    // returning the 100 KiB payload.
    let payload = "\x00".repeat(100 * 1024)
    let gz = zlib.gzip(payload)
    testing.expect(len(gz.bytes()) < 1024, "gz fits well under the cap")
    testing.expectThrows(lam{ in zlib.gunzip(gz, 1024) }, "maxOutput")
})

testing.test("gunzip honors a maxOutput high enough for the payload", lam{ in
    let payload = "a".repeat(50 * 1024)
    let gz = zlib.gzip(payload)
    testing.expectEqual(zlib.gunzip(gz, 100 * 1024), payload, nil)
})

testing.test("inflate respects maxOutput on raw deflate", lam{ in
    let payload = "x".repeat(100 * 1024)
    let raw = zlib.deflate(payload)
    testing.expectThrows(lam{ in zlib.inflate(raw, 1024) }, "maxOutput")
    testing.expectEqual(zlib.inflate(raw, 200 * 1024), payload, nil)
})

testing.test("gunzip rejects negative or zero maxOutput", lam{ in
    let gz = zlib.gzip("hi")
    testing.expectThrows(lam{ in zlib.gunzip(gz, 0) },  "positive")
    testing.expectThrows(lam{ in zlib.gunzip(gz, -1) }, "positive")
})

testing.test("gunzip rejects NaN / Inf maxOutput", lam{ in
    let gz = zlib.gzip("hi")
    // NaN slips past `d <= 0` and `d >= SIZE_MAX` because every NaN
    // comparison is false; static_cast<size_t>(NaN) is UB. Make sure
    // the gate rejects both NaN and Inf explicitly.
    testing.expectThrows(lam{ in zlib.gunzip(gz, 0.0 / 0.0) }, "finite")
    testing.expectThrows(lam{ in zlib.gunzip(gz, 1.0 / 0.0) }, "finite")
})

testing.test("gunzip with maxOutput=nil uses the default cap", lam{ in
    let gz = zlib.gzip("hi")
    testing.expectEqual(zlib.gunzip(gz, nil), "hi", nil)
})

testing.done()
