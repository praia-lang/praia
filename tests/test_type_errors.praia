use "testing"

testing.test("comparison type errors", lam{ in
    testing.expectThrows(lam{ in "a" < 1 }, nil)
    testing.expectThrows(lam{ in "a" > 1 }, nil)
    testing.expectThrows(lam{ in "a" <= 1 }, nil)
    testing.expectThrows(lam{ in "a" >= 1 }, nil)
})

testing.test("arithmetic type errors", lam{ in
    testing.expectThrows(lam{ in "a" - 1 }, nil)
    testing.expectThrows(lam{ in "a" * "b" }, nil)
    testing.expectThrows(lam{ in "a" / 1 }, nil)
    testing.expectThrows(lam{ in "a" % 1 }, nil)
})

testing.test("bitwise type errors", lam{ in
    testing.expectThrows(lam{ in "a" & 1 }, nil)
    testing.expectThrows(lam{ in "a" | 1 }, nil)
    testing.expectThrows(lam{ in "a" ^ 1 }, nil)
    testing.expectThrows(lam{ in ~"a" }, nil)
    testing.expectThrows(lam{ in "a" << 1 }, nil)
    testing.expectThrows(lam{ in "a" >> 1 }, nil)
})

testing.test("negate type error", lam{ in
    testing.expectThrows(lam{ in -"hello" }, nil)
})

testing.test("index type errors", lam{ in
    testing.expectThrows(lam{ in let a = [1,2,3]; a["x"] }, nil)
    testing.expectThrows(lam{ in let a = [1,2,3]; a[99] }, nil)
})

testing.test("caught errors don't leak stack frames", lam{ in
    func f() { throw "inner" }
    func g() {
        try { f() } catch (e) {}
        throw "outer"
    }
    let caught = ""
    try { g() } catch (e) { caught = e }
    testing.expectEqual(caught, "outer", nil)
})

testing.test("runtime error caught in try/catch", lam{ in
    let caught = false
    try {
        1 + true
    } catch (e) {
        caught = true
    }
    testing.expect(caught, "should catch type error")
})

testing.test("division by zero caught", lam{ in
    let caught = false
    try {
        1 / 0
    } catch (e) {
        caught = true
    }
    testing.expect(caught, "should catch division by zero")
})

testing.done()
