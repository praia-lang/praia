use "testing"
use "../sand/grains/manifest"
use "../sand/grains/bin"

// ── bin: field round-trip ─────────────────────────────────────

testing.test("manifest round-trips bin: entries", lam{ in
    let dir = testing.tempDir(nil)
    let m = manifest.create("prscan")
    m.bin = {prscan: "bin/prscan.praia", helper: "bin/helper.praia"}
    manifest.write(dir, m)
    let r = manifest.read(dir)
    testing.expectEqual(r.bin.prscan, "bin/prscan.praia", nil)
    testing.expectEqual(r.bin.helper, "bin/helper.praia", nil)
})

testing.test("manifest write skips empty bin: map", lam{ in
    let dir = testing.tempDir(nil)
    let m = manifest.create("nobin")
    // no m.bin field — write shouldn't emit a bin: section
    manifest.write(dir, m)
    let written = fs.read(path.join(dir, "grain.yaml"))
    testing.expect(!written.contains("bin:"), "no bin: section without entries")
})

// ── validators ────────────────────────────────────────────────

testing.test("bin name validator: alphanumeric, _, -", lam{ in
    testing.expectEqual(manifest.isValidBinName("prscan"), true, nil)
    testing.expectEqual(manifest.isValidBinName("prscan-cli"), true, nil)
    testing.expectEqual(manifest.isValidBinName("pr_scan"), true, nil)
})

testing.test("bin name validator rejects unsafe forms", lam{ in
    testing.expectEqual(manifest.isValidBinName(""), false, nil)
    testing.expectEqual(manifest.isValidBinName("../escape"), false, nil)
    testing.expectEqual(manifest.isValidBinName("foo/bar"), false, nil)
    testing.expectEqual(manifest.isValidBinName(".hidden"), false, "leading dot")
    testing.expectEqual(manifest.isValidBinName("-flag"), false, "leading dash")
})

testing.test("bin path validator: relative .praia files only", lam{ in
    testing.expectEqual(manifest.isValidBinPath("bin/foo.praia"), true, nil)
    testing.expectEqual(manifest.isValidBinPath("main.praia"), true, nil)
})

testing.test("bin path validator rejects unsafe forms", lam{ in
    testing.expectEqual(manifest.isValidBinPath("/abs/path.praia"), false, nil)
    testing.expectEqual(manifest.isValidBinPath("a/../b.praia"), false, nil)
    testing.expectEqual(manifest.isValidBinPath("x.txt"), false, "wrong extension")
    testing.expectEqual(manifest.isValidBinPath(""), false, nil)
})

testing.test("manifest.read throws on invalid bin name", lam{ in
    let dir = testing.tempDir(nil)
    // Write a manifest with a malicious bin name directly; can't go
    // through manifest.write because the validator there would reject.
    fs.write(path.join(dir, "grain.yaml"),
        "name: bad\nversion: 0.1.0\nbin:\n  ../escape: bin/x.praia\n")
    testing.expectThrows(
        lam{ in manifest.read(dir) },
        "rejected: bad bin name")
})

testing.test("manifest.read throws on invalid bin path", lam{ in
    let dir = testing.tempDir(nil)
    fs.write(path.join(dir, "grain.yaml"),
        "name: bad\nversion: 0.1.0\nbin:\n  x: /etc/passwd\n")
    testing.expectThrows(
        lam{ in manifest.read(dir) },
        "rejected: absolute path")
})

// ── wrapper byte-format invariant ─────────────────────────────
//
// The Makefile bootstraps the sand wrapper inline via printf. That
// format MUST match what bin.wrapperContent() produces so a future
// `sand install -g sand@<ver>` regenerates a byte-identical wrapper.

testing.test("bin.wrapperContent format matches the Makefile bootstrap", lam{ in
    let w = bin.wrapperContent("sand",
                                "/usr/local/bin/praia",
                                "/usr/local/lib/praia/ext_grains/sand/main.praia")
    // Hand-build the same string the Makefile's printf produces.
    // Paths are POSIX single-quoted so shell metachars in a grain's
    // bin: path can't break out of the exec line; "$@" stays
    // double-quoted (that's the correct POSIX way to forward argv).
    let expected = "#!/bin/sh\n" +
                   "# sand-managed wrapper for sand\n" +
                   "exec '/usr/local/bin/praia' " +
                   "'/usr/local/lib/praia/ext_grains/sand/main.praia' \"$@\"\n"
    testing.expectEqual(w, expected, "wrapper byte-identical to bootstrap form")
})

testing.test("bin.wrapperContent escapes single quotes in paths", lam{ in
    // POSIX escape: `'O'\''Brien'` for a path with a single quote.
    let w = bin.wrapperContent("foo", "/usr/local/bin/praia",
                                "/Users/O'Brien/foo.praia")
    testing.expect(w.contains("'/Users/O'\\''Brien/foo.praia'"),
                    "single quote inside path is POSIX-escaped: " + w)
})

testing.test("bin.wrapperContent neutralizes shell metachars in paths", lam{ in
    // Regression: an attacker-controllable bin path containing `"; rm
    // -rf ~; "` used to break out of double-quoted exec args. Single
    // quotes don't process any escape sequences inside, so the only
    // dangerous byte is the quote itself — which shellQuote handles.
    // The bytes `rm -rf` still appear literally inside the
    // single-quoted region, but sh treats them as data, not a command.
    let evil = "/tmp/grain/evil\"; rm -rf ~; \".praia"
    let w = bin.wrapperContent("evil", "/usr/local/bin/praia", evil)
    // The evil path is preserved verbatim inside the single-quoted arg.
    testing.expect(w.contains("'" + evil + "'"),
                    "evil path wrapped in single quotes verbatim: " + w)
    // And the wrapper contains exactly two single-quoted args before
    // "$@" — no extra `;` or unbalanced quote sneaks in.
    let execLine = "exec '/usr/local/bin/praia' '" + evil + "' \"$@\"\n"
    testing.expect(w.endsWith(execLine),
                    "exec line uses single-quoted form, ends correctly: " + w)
})

testing.test("bin.isReserved blocks praia and sand only", lam{ in
    testing.expectEqual(bin.isReserved("praia"), true, nil)
    testing.expectEqual(bin.isReserved("sand"), true, nil)
    testing.expectEqual(bin.isReserved("prscan"), false, nil)
    testing.expectEqual(bin.isReserved(""), false, nil)
})

// ── install / remove cycle, in-memory only (no PATH side effects) ──

testing.test("bin.install writes wrappers, bin.remove cleans up", lam{ in
    let grainDir = testing.tempDir(nil)
    let binDir = testing.tempDir(nil)
    fs.mkdir(path.join(grainDir, "bin"))
    fs.write(path.join(grainDir, "bin", "ok.praia"), "print(\"ok\")\n")

    let m = {name: "demo", version: "0.1.0", bin: {ok: "bin/ok.praia"}}
    let result = bin.install(grainDir, m, binDir)
    testing.expectEqual(len(result.written), 1, "one wrapper written")
    testing.expect(fs.exists(result.written[0]), "wrapper exists on disk")
    testing.expect(bin.isSandManaged(result.written[0]), "wrapper carries sentinel")
    testing.expectEqual(len(result.restorable), 0,
        "fresh install has nothing to restore (no prior wrappers overwritten)")

    bin.remove(m, binDir)
    testing.expect(!fs.exists(result.written[0]), "wrapper removed")
})

testing.test("bin.install rejects reserved names without allowReserved", lam{ in
    let grainDir = testing.tempDir(nil)
    let binDir = testing.tempDir(nil)
    fs.mkdir(path.join(grainDir, "bin"))
    fs.write(path.join(grainDir, "bin", "x.praia"), "print(\"x\")\n")
    let m = {name: "evil", version: "0.1.0", bin: {sand: "bin/x.praia"}}
    testing.expectThrows(
        lam{ in bin.install(grainDir, m, binDir) },
        "reserved name rejected")
})

testing.test("bin.install rolls back partial writes on failure", lam{ in
    // First entry valid, second entry references a missing file —
    // the partially-written first wrapper must be removed.
    let grainDir = testing.tempDir(nil)
    let binDir = testing.tempDir(nil)
    fs.mkdir(path.join(grainDir, "bin"))
    fs.write(path.join(grainDir, "bin", "a.praia"), "print(\"a\")\n")
    let m = {
        name: "demo", version: "0.1.0",
        bin: {a: "bin/a.praia", b: "bin/missing.praia"}
    }
    testing.expectThrows(
        lam{ in bin.install(grainDir, m, binDir) },
        "throws on missing script")
    testing.expect(!fs.exists(path.join(binDir, "a")),
                    "first wrapper was rolled back")
})

testing.test("bin.install restores prior sand-managed wrapper on rollback", lam{ in
    // Regression: the rollback used to blindly fs.remove() everything
    // it wrote. If a sand-managed wrapper existed from a prior install
    // of the same grain, that would leave the user with NO wrapper at
    // all. The per-target backup now restores the original bytes +
    // mode when the install fails.
    let grainDir = testing.tempDir(nil)
    let binDir = testing.tempDir(nil)
    fs.mkdir(path.join(grainDir, "bin"))
    fs.write(path.join(grainDir, "bin", "a.praia"), "print(\"new a\")\n")
    let m = {name: "demo", version: "0.1.0",
             bin: {a: "bin/a.praia", b: "bin/missing.praia"}}

    // Pre-install a sand-managed wrapper for `a` so the rollback has
    // something to restore (rather than just unlink).
    let prior = "#!/bin/sh\n# sand-managed wrapper for a\nexec '/old/praia' '/old/a' \"$@\"\n"
    let target = path.join(binDir, "a")
    fs.write(target, prior)
    fs.chmod(target, 0o755)

    testing.expectThrows(
        lam{ in bin.install(grainDir, m, binDir) },
        "throws on missing second script")
    testing.expect(fs.exists(target),
                    "prior wrapper restored (not unlinked)")
    testing.expectEqual(fs.read(target), prior,
                         "prior wrapper bytes restored exactly")
    // Catch chmod regressions in the rollback path — bytes alone
    // don't tell us if the file became unexecutable. Mask to 0o777
    // because fs.stat may report setuid/setgid/sticky bits we don't
    // care about here.
    testing.expectEqual(fs.stat(target).mode & 0o777, 0o755,
                         "prior wrapper mode (0o755) restored exactly")
})

testing.test("bin.install refuses to overwrite foreign files", lam{ in
    let grainDir = testing.tempDir(nil)
    let binDir = testing.tempDir(nil)
    fs.mkdir(path.join(grainDir, "bin"))
    fs.write(path.join(grainDir, "bin", "ok.praia"), "print(\"ok\")\n")
    // Plant a hand-written script with the same name as our bin entry.
    fs.write(path.join(binDir, "ok"), "#!/bin/sh\necho not ours\n")
    let m = {name: "demo", version: "0.1.0", bin: {ok: "bin/ok.praia"}}
    testing.expectThrows(
        lam{ in bin.install(grainDir, m, binDir) },
        "foreign file protected")
    // Foreign file untouched.
    testing.expectEqual(fs.read(path.join(binDir, "ok")),
                         "#!/bin/sh\necho not ours\n", nil)
})

testing.done()
