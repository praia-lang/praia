use "testing"

testing.test("parse primitives", lam{ in
    testing.expectEqual(json.parse("42"), 42, nil)
    testing.expectEqual(json.parse("\"hi\""), "hi", nil)
    testing.expectEqual(json.parse("true"), true, nil)
    testing.expectEqual(json.parse("false"), false, nil)
    testing.expectEqual(json.parse("null"), nil, nil)
})

testing.test("parse array", lam{ in
    let a = json.parse("[1, 2, 3]")
    testing.expectEqual(len(a), 3, nil)
    testing.expectEqual(a[0], 1, nil)
    testing.expectEqual(a[2], 3, nil)
})

testing.test("parse object", lam{ in
    let m = json.parse("{\"name\": \"Ada\", \"age\": 36}")
    testing.expectEqual(m.name, "Ada", nil)
    testing.expectEqual(m.age, 36, nil)
})

testing.test("parse nested", lam{ in
    let data = json.parse("{\"users\": [{\"id\": 1}, {\"id\": 2}]}")
    testing.expectEqual(len(data.users), 2, nil)
    testing.expectEqual(data.users[0].id, 1, nil)
    testing.expectEqual(data.users[1].id, 2, nil)
})

testing.test("stringify roundtrip", lam{ in
    let original = {name: "Ada", age: 36, active: true}
    let s = json.stringify(original)
    let parsed = json.parse(s)
    testing.expectEqual(parsed.name, "Ada", nil)
    testing.expectEqual(parsed.age, 36, nil)
    testing.expectEqual(parsed.active, true, nil)
})

testing.test("parse errors include context", lam{ in
    let msg = nil
    try {
        json.parse("{\"foo\": 12x}")
    } catch (err) {
        msg = err
    }
    // Should include both the position and the surrounding text
    testing.expect(msg.contains("position"), nil)
    testing.expect(msg.contains("12"), nil)
})

// Regression: json.stringify used to emit `inf` / `-inf` / `nan` for
// non-finite doubles, which aren't valid JSON. Now rejected with a
// clear error (same pattern as cyclic-reference rejection).
testing.test("json.stringify rejects Infinity", lam{ in
    testing.expectThrows(lam{ in json.stringify(math.INF) }, "Infinity")
    testing.expectThrows(lam{ in json.stringify(0 - math.INF) }, "Infinity")
})

testing.test("json.stringify rejects NaN", lam{ in
    testing.expectThrows(lam{ in json.stringify(math.INF - math.INF) }, "NaN")
})

testing.test("json.stringify still emits ordinary floats", lam{ in
    testing.expectEqual(json.stringify(3.5), "3.5", nil)
    testing.expectEqual(json.stringify(0.0), "0", nil)
})

// Companion: type() now reports `future` and `generator` instead of
// leaking `unknown`, and the `is` operator recognises both.
testing.test("type() reports future and generator", lam{ in
    func g() { yield 1 }
    testing.expectEqual(type(g()), "generator", nil)
    func nullary() { return 1 }
    let fut = async nullary()
    testing.expectEqual(type(fut), "future", nil)
    await fut
})

testing.test("`is` recognises future and generator", lam{ in
    func g() { yield 1 }
    testing.expect(g() is "generator", nil)
    func nullary() { return 1 }
    let fut = async nullary()
    testing.expect(fut is "future", nil)
    await fut
})

testing.done()
