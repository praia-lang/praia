use "testing"

// Regression: url.parse and http.* used to share two separate ad-hoc
// parsers that both split on the first ':' — IPv6 literals, userinfo,
// and fragments were all parsed wrong (or crashed). Both now share
// praia::url::parse() in src/url.cpp.

testing.test("url.parse — full http URL with all components", lam{ in
    let u = url.parse("https://user:pass@example.com:8443/api/v1?q=1&r=2#section")
    testing.expectEqual(u.scheme, "https", nil)
    testing.expectEqual(u.userinfo, "user:pass", nil)
    testing.expectEqual(u.host, "example.com", nil)
    testing.expectEqual(u.port, 8443, nil)
    testing.expectEqual(u.path, "/api/v1", nil)
    testing.expectEqual(u.query, "q=1&r=2", nil)
    testing.expectEqual(u.fragment, "section", nil)
})

testing.test("url.parse — scheme is lowercased", lam{ in
    testing.expectEqual(url.parse("HTTPS://x/").scheme, "https", nil)
    testing.expectEqual(url.parse("HtTp://x/").scheme, "http", nil)
})

testing.test("url.parse — absent port is nil, not 0", lam{ in
    // Important: 0 is a valid port value; `nil` is how we signal
    // "the URL didn't specify a port" without that collision.
    let u = url.parse("http://example.com/")
    testing.expectEqual(u.port, nil, "no port should produce nil")
})

testing.test("url.parse — IPv6 literal is unbracketed in .host", lam{ in
    let u = url.parse("http://[::1]:8080/path")
    testing.expectEqual(u.host, "::1", "host strips the brackets")
    testing.expectEqual(u.port, 8080, nil)
    testing.expectEqual(u.path, "/path", nil)
})

testing.test("url.parse — IPv6 literal without port", lam{ in
    let u = url.parse("http://[2001:db8::1]/")
    testing.expectEqual(u.host, "2001:db8::1", nil)
    testing.expectEqual(u.port, nil, nil)
    testing.expectEqual(u.path, "/", nil)
})

testing.test("url.parse — userinfo split on the LAST @", lam{ in
    // user:pa@ss is a valid (if odd) userinfo; the parser must not
    // get confused by the inner '@'.
    let u = url.parse("http://user:pa@ss@host/p")
    testing.expectEqual(u.userinfo, "user:pa@ss", nil)
    testing.expectEqual(u.host, "host", nil)
    testing.expectEqual(u.path, "/p", nil)
})

testing.test("url.parse — userinfo without password", lam{ in
    let u = url.parse("http://alice@host/")
    testing.expectEqual(u.userinfo, "alice", nil)
    testing.expectEqual(u.host, "host", nil)
})

testing.test("url.parse — fragment without query", lam{ in
    let u = url.parse("http://x/p#frag")
    testing.expectEqual(u.path, "/p", nil)
    testing.expectEqual(u.query, "", nil)
    testing.expectEqual(u.fragment, "frag", nil)
})

testing.test("url.parse — '?' inside fragment is part of fragment", lam{ in
    // Fragment is stripped FIRST per RFC 3986 §3.5, so a '?' after a
    // '#' is fragment text, not a query delimiter.
    let u = url.parse("http://x/#a?b")
    testing.expectEqual(u.query, "", nil)
    testing.expectEqual(u.fragment, "a?b", nil)
})

testing.test("url.parse — protocol-relative URL", lam{ in
    let u = url.parse("//host.test/relative")
    testing.expectEqual(u.scheme, "", nil)
    testing.expectEqual(u.host, "host.test", nil)
    testing.expectEqual(u.path, "/relative", nil)
})

testing.test("url.parse — path-only URL", lam{ in
    let u = url.parse("/just/a/path?q=2")
    testing.expectEqual(u.scheme, "", nil)
    testing.expectEqual(u.host, "", nil)
    testing.expectEqual(u.path, "/just/a/path", nil)
    testing.expectEqual(u.query, "q=2", nil)
})

testing.test("url.parse — opaque URI (mailto:)", lam{ in
    // No '//' after the scheme — everything after the colon is path,
    // not authority. Userinfo/host/port stay empty.
    let u = url.parse("mailto:viggo@baconx.com")
    testing.expectEqual(u.scheme, "mailto", nil)
    testing.expectEqual(u.host, "", nil)
    testing.expectEqual(u.userinfo, "", nil)
    testing.expectEqual(u.path, "viggo@baconx.com", nil)
})

testing.test("url.parse — empty path when authority has none", lam{ in
    // http://example.com is legal; the path component is empty.
    let u = url.parse("http://example.com")
    testing.expectEqual(u.host, "example.com", nil)
    testing.expectEqual(u.path, "", "no path should be empty string")
})

// ── Error cases ─────────────────────────────────────────────────

testing.test("url.parse — rejects bare IPv6 (forgotten brackets)", lam{ in
    // Two ':' in an unbracketed host is the unambiguous signal that
    // someone wrote an IPv6 address without brackets. Pre-fix this
    // silently corrupted the parse; now it throws.
    testing.expectThrows(lam{ in url.parse("http://1.2.3.4:5:6/") },
                         "ambiguous host")
})

testing.test("url.parse — rejects unterminated IPv6 literal", lam{ in
    testing.expectThrows(lam{ in url.parse("http://[::1/x") },
                         "unterminated IPv6 literal")
})

testing.test("url.parse — rejects empty port", lam{ in
    testing.expectThrows(lam{ in url.parse("http://host:/") }, "empty port")
})

testing.test("url.parse — rejects non-numeric port", lam{ in
    testing.expectThrows(lam{ in url.parse("http://host:abc/") },
                         "non-numeric port")
})

testing.test("url.parse — rejects out-of-range port", lam{ in
    testing.expectThrows(lam{ in url.parse("http://host:99999/") },
                         "port out of range")
})

testing.test("url.parse — rejects CR/LF/NUL (header injection guard)", lam{ in
    testing.expectThrows(lam{ in url.parse("http://x/\r\nInjected: 1") },
                         "control character")
    testing.expectThrows(lam{ in url.parse("http://x/\nfoo") },
                         "control character")
})

testing.done()
