use "testing"
use "colors"

testing.test("basic color wrapping", lam{ in
    let r = colors.red("hi")
    testing.expect(r.contains("hi"), "should contain text")
    testing.expect(r.contains("\x1b["), "should contain escape")
})

testing.test("colors.strip", lam{ in
    testing.expectEqual(colors.strip(colors.red("hello")), "hello", nil)
    testing.expectEqual(colors.strip(colors.bold(colors.green("x"))), "x", nil)
    testing.expectEqual(colors.strip("plain"), "plain", nil)
})

testing.test("styles compose", lam{ in
    let s = colors.bold(colors.red("err"))
    testing.expectEqual(colors.strip(s), "err", nil)
})

testing.test("256-color and RGB", lam{ in
    let s = colors.fg256("hi", 208)
    testing.expectEqual(colors.strip(s), "hi", nil)
    let r = colors.rgb("x", 255, 0, 0)
    testing.expectEqual(colors.strip(r), "x", nil)
})

testing.done()
