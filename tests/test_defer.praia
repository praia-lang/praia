use "testing"

testing.test("defer LIFO order", lam{ in
    let order = []
    func f() {
        defer push(order, "c")
        defer push(order, "b")
        defer push(order, "a")
    }
    f()
    testing.assertEqual(order, ["a", "b", "c"], nil)
})

testing.test("defer runs on return", lam{ in
    let ran = []
    func mark() { push(ran, true) }
    func f() {
        defer mark()
        return 42
    }
    let r = f()
    testing.assertEqual(r, 42, "return value preserved")
    testing.assertEqual(len(ran), 1, "defer ran")
})

testing.test("defer runs on exception", lam{ in
    let ran = []
    func mark() { push(ran, true) }
    func f() {
        defer mark()
        throw "boom"
    }
    try { f() } catch (e) {}
    testing.assertEqual(len(ran), 1, "defer ran after throw")
})

testing.test("defer in lambda", lam{ in
    let ran = []
    func mark() { push(ran, true) }
    let f = lam{ in defer mark(); return "ok" }
    testing.assertEqual(f(), "ok", nil)
    testing.assertEqual(len(ran), 1, nil)
})

testing.test("failing defer does not block others", lam{ in
    let order = []
    func failing() { throw "fail" }
    func f() {
        defer push(order, "after")
        defer failing()
        defer push(order, "before")
    }
    try { f() } catch (e) {}
    testing.assertEqual(order, ["before", "after"], nil)
})

testing.test("defer with no defers is no-op", lam{ in
    func f() { return 1 + 2 }
    testing.assertEqual(f(), 3, nil)
})

testing.done()
