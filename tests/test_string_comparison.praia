use "testing"

testing.test("less than", lam{ in
    testing.expect("apple" < "banana", nil)
    testing.expect(!("banana" < "apple"), nil)
    testing.expect(!("abc" < "abc"), "equal strings not less than")
})

testing.test("greater than", lam{ in
    testing.expect("banana" > "apple", nil)
    testing.expect(!("apple" > "banana"), nil)
    testing.expect(!("abc" > "abc"), nil)
})

testing.test("less than or equal", lam{ in
    testing.expect("abc" <= "abc", "equal")
    testing.expect("abc" <= "abd", "less")
    testing.expect(!("abd" <= "abc"), nil)
})

testing.test("greater than or equal", lam{ in
    testing.expect("abc" >= "abc", "equal")
    testing.expect("abd" >= "abc", "greater")
    testing.expect(!("abc" >= "abd"), nil)
})

testing.test("prefix ordering", lam{ in
    testing.expect("hello" > "hell", "longer string is greater")
    testing.expect("hell" < "hello", nil)
})

testing.test("case sensitivity", lam{ in
    testing.expect("A" < "a", "uppercase before lowercase in ASCII")
    testing.expect("Z" < "a", nil)
})

testing.test("empty string", lam{ in
    testing.expect("" < "a", "empty is less than anything")
    testing.expect("" <= "", nil)
    testing.expect(!("" > ""), nil)
})

testing.test("mixed type comparison still throws", lam{ in
    testing.expectThrows(lam{ in "abc" < 123 }, nil)
    testing.expectThrows(lam{ in "abc" > true }, nil)
    testing.expectThrows(lam{ in 1 < "a" }, nil)
})

testing.done()
