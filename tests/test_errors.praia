use "testing"

testing.test("throw and catch", lam{ in
    let caught = nil
    try {
        throw "boom"
    } catch (err) {
        caught = err
    }
    testing.assertEqual(caught, "boom", nil)
})

testing.test("throw with structured payload", lam{ in
    let caught = nil
    try {
        throw {code: 404, message: "not found"}
    } catch (err) {
        caught = err
    }
    testing.assertEqual(caught.code, 404, nil)
    testing.assertEqual(caught.message, "not found", nil)
})

testing.test("catch runtime error", lam{ in
    let caught = nil
    try {
        let x = 1 / 0
    } catch (err) {
        caught = err
    }
    testing.assert(caught.contains("Division"), nil)
})

testing.test("ensure early exit", lam{ in
    func check(x) {
        ensure (x > 0) else { throw "must be positive" }
        return x * 2
    }
    testing.assertEqual(check(5), 10, nil)
    testing.assertThrows(lam{ in check(-1) }, nil)
})

testing.test("ensure: return is a valid terminator", lam{ in
    func bounded(x) {
        ensure (x >= 0) else { return nil }
        return x * 2
    }
    testing.assertEqual(bounded(5), 10, nil)
    testing.assertEqual(bounded(-1), nil, "else's return is taken")
})

testing.test("ensure: break is a valid terminator (inside a loop)", lam{ in
    let last_i = -1
    for (i in 0..10) {
        ensure (i < 3) else { break }
        last_i = i
    }
    testing.assertEqual(last_i, 2, "loop broke on the first ensure failure")
})

testing.test("ensure: nested if-else both terminating counts as terminator", lam{ in
    // Exercises the recursive case of stmtTerminates — every
    // branch (then + elif + else) of the nested if terminates,
    // so the whole else block terminates.
    func classify(x) {
        ensure (x != 0) else {
            if (x > 0) { return "pos" }
            elif (x < 0) { return "neg" }
            else { throw "unreachable" }
        }
        return "nonzero"
    }
    testing.assertEqual(classify(5), "nonzero", "non-zero path skips the else")
    // classify(0): ensure fires, inner if/elif both false, the
    // else throws "unreachable" — assertThrows confirms the
    // terminator actually runs.
    testing.assertThrows(lam{ in classify(0) }, "unreachable")
})

testing.test("ensure: sys.exit(...) is a valid terminator", lam{ in
    // Sand and other CLI tools use printer.error + sys.exit
    // rather than throw because the error message would
    // otherwise round-trip through main.praia's try/catch and
    // get reformatted. sys.exit calls _exit() and never returns,
    // so it's structurally a terminator — recognise it.
    let ok = "func f(x) { ensure (x) else { sys.exit(1) } ; print(\"unreached\") }"
    let r = sys.exec(["./praia", "-c", ok])
    testing.assertEqual(r.exitCode, 0, "sys.exit-terminated ensure parses cleanly: %{r.stderr}")
})

testing.test("ensure: parser rejects non-terminating else block", lam{ in
    // A separate Praia subprocess parses the snippet. We assert
    // it dies with a non-zero exit AND that stderr names the
    // ensure-guard contract. Mirrors the parse-error checks in
    // test_lex_parse.praia and friends.
    let bad = "func f(x) { ensure (x) else { print(\"hi\") } }"
    let r = sys.exec(["./praia", "-c", bad])
    testing.assert(r.exitCode != 0, "non-terminating ensure must fail parse")
    let blob = r.stdout + r.stderr
    testing.assert(blob.contains("ensure"),
                   "error names the construct: %{blob}")
    testing.assert(blob.contains("terminate") || blob.contains("return") ||
                   blob.contains("throw"),
                   "error names the required action: %{blob}")
})

testing.test("ensure: parser rejects nested if without else (fall-through)", lam{ in
    // The inner `if (true) { return }` has no else — a non-true
    // path would fall through. stmtTerminates correctly refuses
    // to call this a terminator.
    let bad = "func f(x) { ensure (x) else { if (x) { return } } }"
    let r = sys.exec(["./praia", "-c", bad])
    testing.assert(r.exitCode != 0, "fall-through nested if must fail parse")
})

testing.test("try in try", lam{ in
    let outer = nil
    try {
        try {
            throw "inner"
        } catch (e) {
            throw "rewrapped: " + e
        }
    } catch (e) {
        outer = e
    }
    testing.assertEqual(outer, "rewrapped: inner", nil)
})

testing.test("assertThrows catches runtime errors too", lam{ in
    testing.assertThrows(lam{ in num("not a number") }, nil)
    testing.assertThrows(lam{ in pop([]) }, nil)
    testing.assertThrows(lam{ in [1, 2][10] }, nil)
})

testing.test("finally runs after try", lam{ in
    let log = []
    try {
        push(log, "try")
    } catch (e) {
        push(log, "catch")
    } finally {
        push(log, "finally")
    }
    testing.assertEqual(log, ["try", "finally"], nil)
})

testing.test("finally runs after catch", lam{ in
    let log = []
    try {
        throw "err"
    } catch (e) {
        push(log, "catch")
    } finally {
        push(log, "finally")
    }
    testing.assertEqual(log, ["catch", "finally"], nil)
})

testing.test("finally runs even when catch rethrows", lam{ in
    let log = []
    try {
        try {
            throw "err"
        } catch (e) {
            push(log, "inner-catch")
            throw e
        } finally {
            push(log, "inner-finally")
        }
    } catch (e) {
        push(log, "outer-catch")
    }
    testing.assertEqual(log, ["inner-catch", "inner-finally", "outer-catch"], nil)
})

testing.test("finally without error", lam{ in
    let cleaned = false
    try {
        let x = 42
    } catch (e) {
        // not reached
    } finally {
        cleaned = true
    }
    testing.assert(cleaned, nil)
})

testing.test("finally runs on return from try", lam{ in
    let log = []
    func test() {
        try {
            push(log, "try")
            return 42
        } catch (e) {
            push(log, "catch")
        } finally {
            push(log, "finally")
        }
    }
    testing.assertEqual(test(), 42, nil)
    testing.assertEqual(log, ["try", "finally"], nil)
})

testing.test("finally runs on return from catch", lam{ in
    let log = []
    func test() {
        try {
            throw "err"
        } catch (e) {
            push(log, "catch")
            return 99
        } finally {
            push(log, "finally")
        }
    }
    testing.assertEqual(test(), 99, nil)
    testing.assertEqual(log, ["catch", "finally"], nil)
})

testing.test("error messages include column info", lam{ in
    // Runtime error — division by zero at a known column
    let r1 = sys.exec("./praia -c \"let x = 10 / 0\"")
    testing.assert(r1.stderr.contains(":col "), "runtime error should include column")
    testing.assert(r1.stderr.contains("[line 1:col 12]"), "division by zero at col 12")

    // Parse error — unexpected token at a known column
    let r2 = sys.exec("./praia -c \"let x = (1 + )\"")
    testing.assert(r2.stderr.contains(":col "), "parse error should include column")

    // Multiline — error on second line
    let r3 = sys.exec("./praia -c \"let a = 1\nlet b = a / 0\"")
    testing.assert(r3.stderr.contains("[line 2:col"), "line 2 error should have column")
})

// Regression: semicolons used to be discarded as whitespace by the
// lexer, so adjacent expressions on one line silently parsed as two
// statements. `let x = 1 2; print(x)` printed 1 instead of failing.
// Now SEMICOLON is a real token and the parser requires either a
// semicolon or a newline between expression-tailed statements on the
// same line.
testing.test("adjacent expressions require separator", lam{ in
    let r = sys.exec("./praia -c \"let x = 1 2; print(x)\"")
    testing.assert(r.stderr.contains("between statements"),
                   "adjacent statements without separator should error")
})

testing.test("adjacent let statements require separator", lam{ in
    let r = sys.exec("./praia -c \"let a = 1 let b = 2\"")
    testing.assert(r.stderr.contains("between statements"), nil)
})

testing.test("semicolon separator accepts same-line statements", lam{ in
    let r = sys.exec("./praia -c \"let a = 1; let b = 2; print(a + b)\"")
    testing.assertEqual(r.stdout.strip(), "3", nil)
})

testing.test("} ends a statement — same-line follow-up is legal", lam{ in
    // Block-form statements (if/while/for/func) end with `}`; the
    // brace is its own separator, so a return after `}` on the same
    // line is valid Praia style.
    let r = sys.exec("./praia -c \"func f(x) { if (x > 0) { return 1 } return 0 } print(f(5))\"")
    testing.assertEqual(r.stdout.strip(), "1", nil)
})

testing.done()
