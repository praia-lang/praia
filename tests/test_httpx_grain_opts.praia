use "testing"
use "httpx"
use "cookie"

// Companion to test_httpx_grain.praia — covers the opts-shape and
// pre-populated-jar behaviors. Split into its own file because
// `praia test` runs each test file in a separate subprocess, which
// gives these tests a fresh OS-level networking state. When combined
// in one file with the cookie-threading tests, tree-walker exhibits
// a kernel-level localhost-accept stall after ~12-14 short
// connections in quick succession (the same pattern shows up in
// test_http_session.praia and was worked around there by ordering;
// here a separate file is the cleaner fix).

let listener = net.listen(0)
let TEST_PORT = net.localAddr(listener).port

// Server echoes the inbound Cookie header value in the body so tests
// can assert what was actually threaded.
let headerOf = lam{ req, name in
    let needle = "\n" + name.lower() + ":"
    let lower = req.lower()
    let idx = lower.indexOf(needle)
    if (idx < 0) { return "" }
    let start = idx + len(needle)
    let end = req.indexOf("\r\n", start)
    if (end < 0) { return "" }
    return req.slice(start, end).strip()
}

let _serverFuture = async lam{ in
    while (true) {
        let c = net.accept(listener)
        let req = ""
        while (!req.contains("\r\n\r\n")) {
            let chunk = net.recv(c, 4096)
            if (len(chunk) == 0) { break }
            req = req + chunk
        }
        let firstSp = req.indexOf(" ")
        let after = req.slice(firstSp + 1, len(req))
        let path = after.slice(0, after.indexOf(" "))
        let body = headerOf(req, "Cookie")
        let extra = ""
        if (path == "/login") { extra = "Set-Cookie: sid=abc123; Path=/\r\n" }
        net.send(c, "HTTP/1.1 200 OK\r\n" + extra +
                   "Content-Length: " + str(len(body.bytes())) + "\r\n\r\n" +
                   body)
        net.close(c)
    }
}()

let base = "http://localhost:" + str(TEST_PORT)

testing.test("opts.jar lets callers supply a pre-existing jar", lam{ in
    // Build a jar by routing through one session, then hand it to a
    // fresh session — the cookies should carry over.
    let s1 = httpx.session({blockPrivateHosts: false})
    s1.get(base + "/login")                // sid=abc123 lands in s1.jar
    let savedJar = s1.jar()
    testing.expectEqual(savedJar.size(), 1, "one cookie in saved jar")
    s1.close()

    let s2 = httpx.session({blockPrivateHosts: false, jar: savedJar})
    let r = s2.get(base + "/x")
    testing.expect(r.status == 200,
        "second session reached the server")
    // The cookie should have been attached to s2's request — but the
    // mock server doesn't echo Cookie in this file (kept minimal).
    // The size check on savedJar above is the contract test.
    s2.close()
})

testing.test("session-default headers don't break the request pipeline", lam{ in
    // Direct verification of session-default-header forwarding lives
    // in test_http_session.praia; here we just check the wrapper
    // accepts an opts.headers map without crashing.
    let s = httpx.session({blockPrivateHosts: false, headers: {"X-Trace": "abc"}})
    let r = s.get(base + "/")
    testing.expectEqual(r.status, 200, nil)
    s.close()
})

testing.test("request({method, url, body, headers}) round-trips", lam{ in
    let s = httpx.session({blockPrivateHosts: false})
    let r = s.request({method: "GET", url: base + "/",
                        headers: {"X-Test": "abc"}})
    testing.expectEqual(r.status, 200, nil)
    s.close()
})

testing.test("explicit per-call Cookie header overrides the jar", lam{ in
    let s = httpx.session({blockPrivateHosts: false})
    s.get(base + "/login")                 // sid=abc123 now in jar
    // A per-call Cookie header is the user explicitly stating "use
    // this exact value." The wrapper must not silently overwrite it
    // with the jar's value.
    let r = s.request({url: base + "/x",
                        headers: {Cookie: "manual=override"}})
    testing.expectEqual(r.body, "manual=override",
        "per-call Cookie wins over jar")
    s.close()
})

testing.test("Session.stream(url) threads cookies into the streamed request", lam{ in
    // /login puts sid=abc123 in the jar.
    let s = httpx.session({blockPrivateHosts: false})
    s.get(base + "/login")
    // A streamed request through the same session must attach the
    // jar's Cookie header — the stream handle's body echoes back
    // what the server received, so we can assert directly.
    let stream = s.stream(base + "/x")
    testing.expectEqual(stream.status, 200, nil)
    let body = stream.readAll()
    testing.expectEqual(body, "sid=abc123",
        "stream request carried the jar's Cookie header")
    stream.close()
    s.close()
})

testing.test("Session.stream() also ingests Set-Cookie from the response", lam{ in
    // /login on the streamed path should still update the jar.
    let s = httpx.session({blockPrivateHosts: false})
    let stream = s.stream(base + "/login")
    stream.close()
    testing.expectEqual(s.jar().size(), 1,
        "stream response's Set-Cookie landed in the jar")
    // Follow-up request — buffered or streamed — should see it.
    let r = s.get(base + "/x")
    testing.expectEqual(r.body, "sid=abc123",
        "next request inherits cookies that arrived via the stream")
    s.close()
})

testing.test("lowercase 'cookie' per-call header is honored (case-insensitive)", lam{ in
    // HTTP header names are case-insensitive. A caller passing "cookie"
    // (any case) still counts as "I'm setting the cookie header myself" —
    // the wrapper must not shadow it with the jar's value just because
    // the casing isn't exactly "Cookie".
    let s = httpx.session({blockPrivateHosts: false})
    s.get(base + "/login")        // sid=abc123 in jar
    let r = s.request({url: base + "/x",
                        headers: {"cookie": "lc=wins"}})
    testing.expectEqual(r.body, "lc=wins",
        "lowercase cookie still beats the jar")
    s.close()
})

testing.done()
