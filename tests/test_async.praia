use "testing"

testing.test("async/await basic", lam{ in
    func add(a, b) { return a + b }
    let f = async add(3, 4)
    testing.assertEqual(await f, 7, nil)
})

testing.test("async/await multiple", lam{ in
    func double(x) { return x * 2 }
    let f1 = async double(5)
    let f2 = async double(10)
    testing.assertEqual(await f1, 10, nil)
    testing.assertEqual(await f2, 20, nil)
})

testing.test("await precedence", lam{ in
    func id(x) { return x }
    let f1 = async id(3)
    let f2 = async id(4)
    testing.assertEqual(await f1 + await f2, 7, nil)
})

testing.test("async with closure", lam{ in
    let base = 100
    func addBase(x) { return x + base }
    let f = async addBase(42)
    testing.assertEqual(await f, 142, nil)
})

testing.test("future prints as <future>", lam{ in
    func noop() { return nil }
    let f = async noop()
    testing.assertEqual(str(f), "<future>", nil)
    await f
})

testing.test("async class construction runs init", lam{ in
    class Point {
        func init(x, y) { this.x = x; this.y = y }
    }
    let fut = async Point(10, 20)
    let p = await fut
    testing.assertEqual(p.x, 10, nil)
    testing.assertEqual(p.y, 20, nil)
})

testing.test("async class construction with named args", lam{ in
    class Pair {
        func init(a, b) { this.a = a; this.b = b }
    }
    let fut = async Pair(b: 99, a: 42)
    let p = await fut
    testing.assertEqual(p.a, 42, nil)
    testing.assertEqual(p.b, 99, nil)
})

testing.test("async class no-init with no args", lam{ in
    class Empty {}
    let fut = async Empty()
    let e = await fut
    testing.assertEqual(type(e), "instance", nil)
})

testing.test("async class no-init rejects args", lam{ in
    class Empty {}
    testing.assertThrows(lam{ in
        let fut = async Empty(1)
        await fut
    }, nil)
})

testing.test("async native too few args throws", lam{ in
    testing.assertThrows(lam{ in
        let fut = async len()
        await fut
    }, nil)
})

testing.test("async native too many args throws", lam{ in
    testing.assertThrows(lam{ in
        let fut = async len([1, 2], 99)
        await fut
    }, nil)
})

// Regression: bare `async fn()` (without binding the future) used to block
// the calling thread for the full duration of the task because the only
// reference to the std::async-launched shared state was destroyed on
// statement completion, and the C++ standard makes that destructor wait.
testing.test("bare async returns immediately (no binding)", lam{ in
    let start = time.now()
    async sys.exec(["sleep", "1"])
    let elapsed = time.now() - start
    testing.assert(elapsed < 200,
        "bare async blocked for " + elapsed.toString() + "ms (expected <200ms)")
})

// SharedMap is the cross-VM key-value primitive. Like Channel and Lock,
// it survives the deep-copy that `async` performs on globals/args because
// the C++ state is captured in shared_ptr closures inside each method.
testing.test("SharedMap basic ops", lam{ in
    let m = SharedMap()
    m.set("a", 1)
    testing.assertEqual(m.get("a"), 1, nil)
    testing.assertEqual(m.get("missing"), nil, nil)
    testing.assertEqual(m.get("missing", 99), 99, nil)
    testing.assert(m.has("a"), "has a")
    testing.assert(!m.has("missing"), "no missing")
    testing.assertEqual(m.size(), 1, nil)
    testing.assert(m.delete("a"), "delete found")
    testing.assert(!m.delete("a"), "delete second time false")
})

testing.test("SharedMap.update is atomic read-modify-write", lam{ in
    let m = SharedMap()
    m.set("c", 0)
    let result = m.update("c", lam{ v in v + 5 })
    testing.assertEqual(result, 5, "update returns new value")
    testing.assertEqual(m.get("c"), 5, "stored")
    // update on missing key receives nil
    let r2 = m.update("new", lam{ v in v == nil ? 1 : v + 1 })
    testing.assertEqual(r2, 1, nil)
    testing.assertEqual(m.get("new"), 1, nil)
})

testing.test("SharedMap survives async deep-copy", lam{ in
    let m = SharedMap()
    m.set("k", 0)
    let f = async lam{ in m.update("k", lam{ v in v + 100 }) }()
    await f
    testing.assertEqual(m.get("k"), 100,
        "mutation in async task visible to caller")
})

testing.done()
