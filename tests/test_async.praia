use "testing"

testing.test("async/await basic", lam{ in
    func add(a, b) { return a + b }
    let f = async add(3, 4)
    testing.expectEqual(await f, 7, nil)
})

testing.test("async/await multiple", lam{ in
    func double(x) { return x * 2 }
    let f1 = async double(5)
    let f2 = async double(10)
    testing.expectEqual(await f1, 10, nil)
    testing.expectEqual(await f2, 20, nil)
})

testing.test("await precedence", lam{ in
    func id(x) { return x }
    let f1 = async id(3)
    let f2 = async id(4)
    testing.expectEqual(await f1 + await f2, 7, nil)
})

testing.test("async with closure", lam{ in
    let base = 100
    func addBase(x) { return x + base }
    let f = async addBase(42)
    testing.expectEqual(await f, 142, nil)
})

testing.test("future prints as <future>", lam{ in
    func noop() { return nil }
    let f = async noop()
    testing.expectEqual(str(f), "<future>", nil)
    await f
})

testing.test("async class construction runs init", lam{ in
    class Point {
        func init(x, y) { this.x = x; this.y = y }
    }
    let fut = async Point(10, 20)
    let p = await fut
    testing.expectEqual(p.x, 10, nil)
    testing.expectEqual(p.y, 20, nil)
})

testing.test("async class construction with named args", lam{ in
    class Pair {
        func init(a, b) { this.a = a; this.b = b }
    }
    let fut = async Pair(b: 99, a: 42)
    let p = await fut
    testing.expectEqual(p.a, 42, nil)
    testing.expectEqual(p.b, 99, nil)
})

testing.test("async class no-init with no args", lam{ in
    class Empty {}
    let fut = async Empty()
    let e = await fut
    testing.expectEqual(type(e), "instance", nil)
})

testing.test("async class no-init rejects args", lam{ in
    class Empty {}
    testing.expectThrows(lam{ in
        let fut = async Empty(1)
        await fut
    }, nil)
})

testing.test("async native too few args throws", lam{ in
    testing.expectThrows(lam{ in
        let fut = async len()
        await fut
    }, nil)
})

testing.test("async native too many args throws", lam{ in
    testing.expectThrows(lam{ in
        let fut = async len([1, 2], 99)
        await fut
    }, nil)
})

// Regression: bare `async fn()` (without binding the future) used to block
// the calling thread for the full duration of the task because the only
// reference to the std::async-launched shared state was destroyed on
// statement completion, and the C++ standard makes that destructor wait.
testing.test("bare async returns immediately (no binding)", lam{ in
    let start = time.now()
    async sys.exec(["sleep", "1"])
    let elapsed = time.now() - start
    // The bug was a full 1000 ms block (the entire sleep). Anything under
    // half a second proves the future destructor isn't waiting; the slack
    // makes this robust on slow/contended CI runners.
    testing.expect(elapsed < 500,
        "bare async blocked for " + elapsed.toString() + "ms (expected <500ms)")
})

// SharedMap is the cross-VM key-value primitive. Like Channel and Lock,
// it survives the deep-copy that `async` performs on globals/args because
// the C++ state is captured in shared_ptr closures inside each method.
testing.test("SharedMap basic ops", lam{ in
    let m = SharedMap()
    m.set("a", 1)
    testing.expectEqual(m.get("a"), 1, nil)
    testing.expectEqual(m.get("missing"), nil, nil)
    testing.expectEqual(m.get("missing", 99), 99, nil)
    testing.expect(m.has("a"), "has a")
    testing.expect(!m.has("missing"), "no missing")
    testing.expectEqual(m.size(), 1, nil)
    testing.expect(m.delete("a"), "delete found")
    testing.expect(!m.delete("a"), "delete second time false")
})

testing.test("SharedMap.update is atomic read-modify-write", lam{ in
    let m = SharedMap()
    m.set("c", 0)
    let result = m.update("c", lam{ v in v + 5 })
    testing.expectEqual(result, 5, "update returns new value")
    testing.expectEqual(m.get("c"), 5, "stored")
    // update on missing key receives nil
    let r2 = m.update("new", lam{ v in v == nil ? 1 : v + 1 })
    testing.expectEqual(r2, 1, nil)
    testing.expectEqual(m.get("new"), 1, nil)
})

testing.test("SharedMap survives async deep-copy", lam{ in
    let m = SharedMap()
    m.set("k", 0)
    let f = async lam{ in m.update("k", lam{ v in v + 100 }) }()
    await f
    testing.expectEqual(m.get("k"), 100,
        "mutation in async task visible to caller")
})

// CancellationToken — cooperative cancel signal that survives async
// deep-copy (same trick as Channel/SharedMap).
testing.test("CancellationToken basic", lam{ in
    let t = CancellationToken()
    testing.expectEqual(t.cancelled(), false, nil)
    t.cancel()
    testing.expectEqual(t.cancelled(), true, nil)
})

testing.test("CancellationToken throwIfCancelled", lam{ in
    let t = CancellationToken()
    t.throwIfCancelled()  // shouldn't throw
    t.cancel()
    testing.expectThrows(lam{ in t.throwIfCancelled() }, "cancelled")
})

testing.test("CancellationToken signals across async VMs", lam{ in
    let token = CancellationToken()
    // Loop budget large enough that natural completion is unambiguously
    // distinct from cancellation — if cancel never reaches the task, iters
    // hits the cap.
    let cap = 500
    let f = async lam{ in
        let i = 0
        while (!token.cancelled() && i < cap) {
            i = i + 1
            time.sleep(20)
        }
        return i
    }()
    // Give the task time to start running on a contended scheduler before
    // we cancel. The exact iteration count we observe doesn't matter; the
    // assertion below just checks cancel arrived at all.
    time.sleep(200)
    token.cancel()
    let iters = await f
    testing.expect(iters < cap,
        "cancel should bail the loop before natural end (iters=" + iters.toString() + ")")
})

// Regression: deep-copied containers passed to async tasks must not be
// swept by the parent VM's GC mid-task. Previously, gcNew in deepCopy
// tracked the clones in the parent's heap, but the lambda capture (only
// reachable from the task thread) was invisible to parent-side roots —
// after enough allocations the parent's collectIfNeeded() would clear
// the clone's entries while the task was using them. The minimal repro:
// many sequential `async fn(sharedMap)` iterations with any extra `let`
// in scope deterministically failed around iter ~40.
testing.test("async deep-copy survives parent GC pressure", lam{ in
    let m = SharedMap()
    m.set("n", 0)
    func inc(s) { s.set("n", 1) }
    let unused = 99
    for (i in 0..200) {
        let f = async inc(m)
        await f
    }
    testing.expectEqual(m.get("n"), 1, "task ran each iteration without corruption")
})

// Lazy-globals regression: with the per-task globals map rebuilt via
// unordered_map iteration (pre-fix), the task's slot for a given name
// could disagree with the parent's, and the shared chunk slot cache
// would read the wrong global. With lazy globals + verbatim indices
// copy, slot numbering matches by construction. These three tests
// exercise the relevant shapes.
testing.test("async reads parent-defined global", lam{ in
    let counter_value = 4711
    func read_counter() { return counter_value }
    let f = async read_counter()
    testing.expectEqual(await f, 4711, nil)
})

testing.test("async reads selected global among many", lam{ in
    let g0 = "g0"; let g1 = "g1"; let g2 = "g2"; let g3 = "g3"
    let g4 = "g4"; let g5 = "g5"; let g6 = "g6"; let g7 = "g7"
    let target = "found_it"
    let g8 = "g8"; let g9 = "g9"
    func read_target() { return target }
    let f = async read_target()
    testing.expectEqual(await f, "found_it", nil)
})

testing.test("nested async sees parent globals through chain", lam{ in
    let outer_unused = 1
    let needed_by_inner = 7
    func inner() { return needed_by_inner }
    func outer() {
        let f = async inner()
        return await f
    }
    let g = async outer()
    testing.expectEqual(await g, 7, nil)
})

testing.done()
