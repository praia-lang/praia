use "testing"

testing.test("basic static method", lam{ in
    class Utils {
        static func double(n) { return n * 2 }
    }
    testing.expectEqual(Utils.double(21), 42, nil)
})

testing.test("static method works without this", lam{ in
    class Foo {
        static func greet(name) { return "hi " + name }
    }
    testing.expectEqual(Foo.greet("Ada"), "hi Ada", nil)
})

testing.test("static and instance methods coexist", lam{ in
    class Counter {
        func init(n) { this.n = n }
        func value() { return this.n }
        static func zero() { return Counter(0) }
    }
    let c = Counter.zero()
    testing.expectEqual(c.value(), 0, nil)
})

testing.test("static method with multiple params", lam{ in
    class Math {
        static func clamp(x, lo, hi) {
            if (x < lo) { return lo }
            if (x > hi) { return hi }
            return x
        }
    }
    testing.expectEqual(Math.clamp(5, 0, 10), 5, nil)
    testing.expectEqual(Math.clamp(-1, 0, 10), 0, nil)
    testing.expectEqual(Math.clamp(99, 0, 10), 10, nil)
})

testing.test("static method inheritance", lam{ in
    class Animal {
        static func type() { return "animal" }
    }
    class Dog extends Animal {}
    testing.expectEqual(Dog.type(), "animal", nil)
})

testing.test("child overrides static", lam{ in
    class Base {
        static func name() { return "Base" }
    }
    class Child extends Base {
        static func name() { return "Child" }
    }
    testing.expectEqual(Base.name(), "Base", nil)
    testing.expectEqual(Child.name(), "Child", nil)
})

testing.test("static with default params", lam{ in
    class Config {
        static func create(host = "localhost", port = 8080) {
            return {host: host, port: port}
        }
    }
    let c = Config.create()
    testing.expectEqual(c.host, "localhost", nil)
    testing.expectEqual(c.port, 8080, nil)
    let c2 = Config.create("0.0.0.0", 3000)
    testing.expectEqual(c2.port, 3000, nil)
})

testing.test("static with rest params", lam{ in
    class Logger {
        static func format(...parts) {
            return parts.join(" ")
        }
    }
    testing.expectEqual(Logger.format("a", "b", "c"), "a b c", nil)
})

testing.test("static as factory method", lam{ in
    class Point {
        func init(x, y) {
            this.x = x
            this.y = y
        }
        static func origin() { return Point(0, 0) }
        static func fromArray(arr) { return Point(arr[0], arr[1]) }
    }
    let p = Point.origin()
    testing.expectEqual(p.x, 0, nil)
    let p2 = Point.fromArray([3, 4])
    testing.expectEqual(p2.x, 3, nil)
    testing.expectEqual(p2.y, 4, nil)
})

testing.test("instance cannot access static method", lam{ in
    class Foo {
        static func bar() { return 42 }
    }
    let f = Foo()
    let ok = false
    try {
        f.bar()
    } catch (e) {
        ok = true
    }
    testing.expect(ok, "static method not accessible on instance")
})

testing.done()
