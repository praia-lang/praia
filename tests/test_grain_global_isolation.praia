use "testing"

// Regression: two grains that each define a module-level `let` with the
// same name used to collide on the VM (the loader merged grain globals
// into the parent's flat name->slot table and skipped colliding names,
// so the second grain's value silently lost to the first). The tree-
// walker was already correct because each grain has its own scope.
// After the fix, both engines isolate module-level state per grain.

func writeGrain(dir, name, body) {
    fs.write(path.join(dir, name + ".praia"), body)
}

testing.test("two grains with same `let` name stay isolated", lam{ in
    let dir = testing.tempDir(nil)

    writeGrain(dir, "ga", "let state = \"a\"\nfunc get() { return state }\nexport { get }\n")
    writeGrain(dir, "gb", "let state = \"b\"\nfunc get() { return state }\nexport { get }\n")
    writeGrain(dir, "main",
        "use \"./ga\"\nuse \"./gb\"\nprint(ga.get() + \"/\" + gb.get())\n")

    let praiaBin = path.join(sys.cwd(), "praia")
    let r = sys.exec([praiaBin, path.join(dir, "main.praia")])
    testing.assertEqual(r.exitCode, 0, r.stderr)
    testing.assertEqual(r.stdout.strip(), "a/b",
        "VM grain globals must not collide on name")
})

testing.test("class with same name in two grains stays isolated", lam{ in
    // Same shape, but the module-level binding is a class — exercises
    // OP_TAG_OR_CALL's home-VM resolution path (capitalized identifiers
    // route through a separate opcode).
    let dir = testing.tempDir(nil)

    writeGrain(dir, "ga",
        "class Box { func init() { this.v = \"a\" } }\nfunc make() { return Box() }\nexport { make }\n")
    writeGrain(dir, "gb",
        "class Box { func init() { this.v = \"b\" } }\nfunc make() { return Box() }\nexport { make }\n")
    writeGrain(dir, "main",
        "use \"./ga\"\nuse \"./gb\"\nprint(ga.make().v + \"/\" + gb.make().v)\n")

    let praiaBin = path.join(sys.cwd(), "praia")
    let r = sys.exec([praiaBin, path.join(dir, "main.praia")])
    testing.assertEqual(r.exitCode, 0, r.stderr)
    testing.assertEqual(r.stdout.strip(), "a/b",
        "Grain-scoped class names must not collide across grains")
})

testing.test("mutating a grain's module state doesn't leak across grains", lam{ in
    let dir = testing.tempDir(nil)

    writeGrain(dir, "ga",
        "let n = 0\nfunc bump() { n = n + 1; return n }\nexport { bump }\n")
    writeGrain(dir, "gb",
        "let n = 100\nfunc bump() { n = n + 1; return n }\nexport { bump }\n")
    writeGrain(dir, "main",
        "use \"./ga\"\nuse \"./gb\"\n" +
        "ga.bump()\nga.bump()\nlet a = ga.bump()\n" +
        "let b = gb.bump()\n" +
        "print(str(a) + \"/\" + str(b))\n")

    let praiaBin = path.join(sys.cwd(), "praia")
    let r = sys.exec([praiaBin, path.join(dir, "main.praia")])
    testing.assertEqual(r.exitCode, 0, r.stderr)
    testing.assertEqual(r.stdout.strip(), "3/101",
        "OP_SET_GLOBAL must write through to the grain's own slots")
})

testing.test("a transitive grain is only executed once across siblings", lam{ in
    // Two grains import the same dependency. The dependency's top-level
    // body must run exactly once — otherwise side effects (here: a
    // `print`) duplicate. Before the fix, each child grain VM had its
    // own empty grainCache so sibling imports re-executed shared deps.
    let dir = testing.tempDir(nil)

    writeGrain(dir, "c",
        "print(\"load c\")\nlet x = 1\nexport { x }\n")
    writeGrain(dir, "a",
        "use \"./c\"\nlet val = c.x\nexport { val }\n")
    writeGrain(dir, "b",
        "use \"./c\"\nlet val = c.x\nexport { val }\n")
    writeGrain(dir, "main",
        "use \"./a\"\nuse \"./b\"\nprint(a.val + b.val)\n")

    let praiaBin = path.join(sys.cwd(), "praia")
    let r = sys.exec([praiaBin, path.join(dir, "main.praia")])
    testing.assertEqual(r.exitCode, 0, r.stderr)
    testing.assertEqual(r.stdout.strip(), "load c\n2",
        "Shared grain dep must execute exactly once")
})

testing.test("async tasks observe a COW snapshot of a grain's module globals", lam{ in
    // Regression: when a grain closure was dispatched via `async`,
    // OP_*_GLOBAL routed through the closure's live grain VM
    // (chunk.homeVm), bypassing the task VM's COW snapshot. Two
    // concurrent tasks then raced on the same counter and parent
    // saw their mutations leak back. The fix routes through `this`
    // inside task VMs and seeds the task's snapshot from the grain's
    // globals when the dispatched closure is grain-owned.
    let dir = testing.tempDir(nil)
    writeGrain(dir, "g",
        "let n = 0\nfunc bump() { n = n + 1; return n }\n" +
        "func read() { return n }\nexport { bump, read }\n")
    writeGrain(dir, "main",
        "use \"./g\"\n" +
        "g.bump()\ng.bump()\n" +              // parent state: n=2
        "let t1 = async g.bump()\n" +
        "let t2 = async g.bump()\n" +
        "let r1 = await t1\n" +
        "let r2 = await t2\n" +
        "print(str(r1) + \"/\" + str(r2) + \"/\" + str(g.read()))\n")

    let praiaBin = path.join(sys.cwd(), "praia")
    let r = sys.exec([praiaBin, path.join(dir, "main.praia")])
    testing.assertEqual(r.exitCode, 0, r.stderr)
    // Both tasks see their own COW snapshot of n=2 → bump to 3.
    // Parent's n stays at 2 because task mutations don't leak back.
    testing.assertEqual(r.stdout.strip(), "3/3/2",
        "async grain tasks must observe COW snapshots, not live grain state")
})

testing.test("shared grain dep returns the same export value to both importers", lam{ in
    // Stronger than counting prints: the cache must return the *same*
    // exports map, so any state initialized in the dep is observable by
    // both importers. Mutating it via one importer changes what the
    // other sees (intentional — modules are singletons).
    let dir = testing.tempDir(nil)

    writeGrain(dir, "c",
        "let counter = {n: 0}\nfunc bump() { counter.n = counter.n + 1; return counter.n }\nexport { bump, counter }\n")
    writeGrain(dir, "a",
        "use \"./c\"\nfunc step() { return c.bump() }\nexport { step }\n")
    writeGrain(dir, "b",
        "use \"./c\"\nfunc step() { return c.bump() }\nexport { step }\n")
    writeGrain(dir, "main",
        "use \"./a\"\nuse \"./b\"\n" +
        "let s1 = a.step()\nlet s2 = b.step()\nlet s3 = a.step()\n" +
        "print(str(s1) + \"/\" + str(s2) + \"/\" + str(s3))\n")

    let praiaBin = path.join(sys.cwd(), "praia")
    let r = sys.exec([praiaBin, path.join(dir, "main.praia")])
    testing.assertEqual(r.exitCode, 0, r.stderr)
    testing.assertEqual(r.stdout.strip(), "1/2/3",
        "Both importers must observe the same singleton dep")
})

testing.done()
