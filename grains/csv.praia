// CSV parser and stringifier
//
// csv.parse(text) → array of maps (first row = headers)
// csv.parseRaw(text) → array of arrays (no header handling)
// csv.stringify(data, headers?) → CSV string

func parseRow(line) {
    let fields = []
    let current = ""
    let inQuotes = false
    let i = 0

    while (i < len(line)) {
        let ch = line[i]
        if (inQuotes) {
            if (ch == "\"") {
                if (i + 1 < len(line) && line[i + 1] == "\"") {
                    // Escaped quote
                    current = current + "\""
                    i = i + 2
                    continue
                } else {
                    inQuotes = false
                }
            } else {
                current = current + ch
            }
        } else {
            if (ch == "\"") {
                inQuotes = true
            } elif (ch == ",") {
                fields.push(current.strip())
                current = ""
            } else {
                current = current + ch
            }
        }
        i = i + 1
    }
    fields.push(current.strip())
    return fields
}

func parseRaw(text) {
    // Quote-aware row splitter: only treat \n as a row separator outside quotes,
    // so a quoted field can span newlines per RFC 4180.
    let rows = []
    let current = ""
    let inQuotes = false
    let i = 0
    while (i < len(text)) {
        let ch = text[i]
        if (ch == "\"") {
            inQuotes = !inQuotes
            current = current + ch
        } elif (ch == "\n" && !inQuotes) {
            if (len(current.strip()) > 0) {
                rows.push(parseRow(current))
            }
            current = ""
        } elif (ch == "\r" && !inQuotes) {
            // skip CR; CRLF handled by the LF branch
        } else {
            current = current + ch
        }
        i = i + 1
    }
    if (len(current.strip()) > 0) {
        rows.push(parseRow(current))
    }
    return rows
}

func parse(text) {
    let rows = parseRaw(text)
    ensure (len(rows) > 0) else { return [] }

    let headers = rows[0]
    let result = []

    for (i in 1..len(rows)) {
        let row = rows[i]
        let obj = {}
        for (j in 0..len(headers)) {
            if (j < len(row)) {
                // Try to parse numbers
                let val = row[j]
                let numVal = nil
                try { numVal = val.toNum() } catch (e) {}
                if (numVal != nil && val != "true" && val != "false") {
                    obj[headers[j]] = numVal
                } elif (val == "true") {
                    obj[headers[j]] = true
                } elif (val == "false") {
                    obj[headers[j]] = false
                } else {
                    obj[headers[j]] = val
                }
            } else {
                obj[headers[j]] = ""
            }
        }
        result.push(obj)
    }
    return result
}

func stringify(data, headers) {
    ensure (len(data) > 0) else { return "" }

    // Auto-detect headers from first row if not provided
    if (!headers) {
        headers = keys(data[0])
    }

    let lines = []

    // Header row
    lines.push(headers.join(","))

    // Data rows
    for (row in data) {
        let fields = []
        for (h in headers) {
            let val = ""
            if (type(row) == "map" && row[h] != nil) {
                val = row[h].toString()
            }
            // Quote if the value contains any character that the row /
            // field splitter treats specially. `parseRaw` (since the
            // RFC 4180 multi-line correctness fix) preserves quoted
            // newlines, so we must quote on `\n`/`\r` too — without
            // these the writer emits a row that the parser then
            // splits in half.
            if (val.contains(",") || val.contains("\"") ||
                val.contains("\n") || val.contains("\r")) {
                val = "\"" + val.replace("\"", "\"\"") + "\""
            }
            fields.push(val)
        }
        lines.push(fields.join(","))
    }

    return lines.join("\n")
}

export { parse, parseRaw, parseRow, stringify }
